<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NexusMonitor.UI.ViewModels"
        xmlns:views="using:NexusMonitor.UI.Views"
        xmlns:conv="using:NexusMonitor.UI.Converters"
        xmlns:controls="using:NexusMonitor.UI.Controls"
        x:Class="NexusMonitor.UI.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Nexus Monitor"
        Icon="avares://NexusMonitor/Assets/nexus-icon-256.png"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource BgBaseBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="Full">

  <Window.Resources>
    <conv:ProcessCategoryToBrushConverter x:Key="CategoryBrush" />
    <conv:ProcessCategoryToBgBrushConverter x:Key="CategoryBgBrush" />
    <conv:BytesFormatConverter x:Key="BytesFmt" />
    <conv:CpuHeatBrushConverter x:Key="CpuHeat" />
  </Window.Resources>

  <Window.Styles>

    <!-- ── Drag grip: subtle hint by default, brighter on hover, prominent when dragging ──
         Phase 8 UI polish (Task 3): Duration migrated to MotionBase (200ms falls in the
         "150-200ms → Base" bucket) — MotionSettingsService.Apply scales it from AnimationSpeed
         and zeroes it at speed 0. -->
    <Style Selector="TextBlock.nav-grip">
      <Setter Property="Opacity" Value="0.20"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="{DynamicResource MotionBase}"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Grid.nav-row:pointerover TextBlock.nav-grip">
      <Setter Property="Opacity" Value="0.55"/>
    </Style>
    <Style Selector="Grid.nav-row.dragging TextBlock.nav-grip">
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <!-- ── Nav item root: smooth ease-out transitions for transform + opacity ──
         Phase 8 UI polish (Task 3): the transform Duration migrated to MotionSlow (250ms falls
         in the "≥250ms → Slow" bucket); the opacity Duration migrated to MotionBase (200ms falls
         in the "150-200ms → Base" bucket). Both scale from AnimationSpeed and zero at speed 0. -->
    <Style Selector="Grid.nav-row">
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="{DynamicResource MotionSlow}">
            <TransformOperationsTransition.Easing>
              <CubicEaseOut/>
            </TransformOperationsTransition.Easing>
          </TransformOperationsTransition>
          <DoubleTransition Property="Opacity" Duration="{DynamicResource MotionBase}"/>
        </Transitions>
      </Setter>
    </Style>

    <!-- ── Dragging state: subtly lifted, slightly translucent ── -->
    <Style Selector="Grid.nav-row.dragging">
      <Setter Property="RenderTransform" Value="scale(1.01)"/>
      <Setter Property="Opacity" Value="0.94"/>
      <Setter Property="ZIndex" Value="10"/>
    </Style>

  </Window.Styles>

  <Grid RowDefinitions="Auto,*" PointerMoved="OnGlobalPointerMoved">

    <!-- ===== TITLEBAR ===== -->
    <Border Grid.Row="0"
            Classes="glass-surface"
            Height="52"
            Background="{DynamicResource GlassBgBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="0,0,0,1"
            BoxShadow="inset 0 1 3 0 #18FFFFFF"
            PointerPressed="OnTitleBarPointerPressed">
      <Panel>
        <!-- Phase 8 UI polish (Task 5): logo relocated to the upper-right corner (Josh's
             final directive, 2026-07-06, supersedes an earlier sidebar-gutter idea) — the
             titlebar's left/center now stay clean. On macOS the native traffic lights
             (close/minimize/zoom) own the left corner (rendered by the OS itself, outside
             this Grid — see ApplyMacOSTitleBarPadding in MainWindow.axaml.cs); on
             Windows/Linux the custom traffic-light buttons below still anchor the window's
             far right edge, unchanged from before. Grid.Margin's right value (8) and the
             logo group's Margin.Top (0) below were derived by pixel-probing a launched-app
             screenshot of the macOS native traffic lights: the three dots span x=8..59,
             y=8..19 (12px circles) — an 8px left inset from the window edge and a vertical
             center line at y=13.5, well above the 52px titlebar's geometric center (y=26).
             Mirroring the 8px inset on the right, and matching the measured center line
             instead of the titlebar's own center, is why the logo group is Top-aligned
             with a small Margin.Top rather than simply VerticalAlignment="Center". -->
        <Grid x:Name="TitleBarGrid"
              ColumnDefinitions="Auto,*,Auto"
              Margin="18,0,8,0">

          <!-- Column 0 intentionally left empty — see comment above: traffic lights only
               on the left, titlebar center stays clean for the drag region. -->

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="20"
                      VerticalAlignment="Top">

            <!-- App icon + name — 28×28 icon, 12px spacing, per Josh's directive -->
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
              <Image Source="avares://NexusMonitor/Assets/nexus-icon-256.png"
                     Width="28" Height="28"/>
              <TextBlock Text="Nexus Monitor"
                         FontSize="{DynamicResource NxFont13}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Window controls — hidden on macOS (ApplyMacOSTitleBarPadding sets
                 IsVisible=false so the native traffic lights are the only controls);
                 stays visible and anchored at the true right edge on Windows/Linux. -->
            <StackPanel x:Name="WindowControls"
                        Orientation="Horizontal"
                        Spacing="2"
                        VerticalAlignment="Center">
              <Button Classes="nx-btn-ghost" Padding="10,7"
                      Click="OnMinimize"
                      ToolTip.Tip="Minimize">
                <TextBlock Text="—" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Button>
              <Button Classes="nx-btn-ghost" Padding="10,7"
                      Click="OnMaximize"
                      ToolTip.Tip="Maximize">
                <TextBlock Text="⬜" FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Button>
              <Button Classes="nx-btn-ghost" Padding="10,7"
                      Click="OnClose"
                      ToolTip.Tip="Close">
                <TextBlock Text="✕" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Button>
            </StackPanel>
          </StackPanel>

        </Grid>

        <!-- ── Crystal Glass specular stack (pointer-transparent, 3 layers) ── -->

        <!-- Layer 1: Broad soft wash — pointer-tracked specular highlight -->
        <Border x:Name="TitleSpecularWash"
                IsHitTestVisible="False"
                Opacity="{DynamicResource GlassSpecularOpacity}">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#58FFFFFF" Offset="0"/>
              <GradientStop Color="#20FFFFFF" Offset="0.35"/>
              <GradientStop Color="#00FFFFFF" Offset="0.7"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- Layer 2: Sharp bright rim — compressed to top 5px for iOS-glass "lip" -->
        <Border IsHitTestVisible="False"
                Height="5"
                VerticalAlignment="Top"
                Opacity="{DynamicResource GlassSpecularOpacity}">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
              <GradientStop Color="#D8FFFFFF" Offset="0"/>
              <GradientStop Color="#60FFFFFF" Offset="0.6"/>
              <GradientStop Color="#00FFFFFF" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- Layer 3: Prismatic shimmer — rotating rainbow tint (animated in code) -->
        <Border x:Name="TitlePrismatic"
                IsHitTestVisible="False"
                Opacity="{DynamicResource GlassSpecularOpacity}">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#10FF8888" Offset="0.0"/>
              <GradientStop Color="#08FFFFFF" Offset="0.33"/>
              <GradientStop Color="#1088FFFF" Offset="0.66"/>
              <GradientStop Color="#00FFFFFF" Offset="1.0"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

      </Panel>
    </Border>

    <!-- ===== MAIN LAYOUT ===== -->
    <Grid Grid.Row="1" ColumnDefinitions="210,*">

      <!-- ===== LEFT SIDEBAR ===== -->
      <Border Grid.Column="0"
              Classes="glass-surface"
              Background="{DynamicResource GlassBgBrush}"
              BorderBrush="{DynamicResource GlassBorderBrush}"
              BorderThickness="0,0,1,0"
              BoxShadow="inset 1 0 4 0 #14FFFFFF">

        <Panel>
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="NavItemsControl"
                          ItemsSource="{Binding NavItems}"
                          Margin="10,14">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:NavItem">
                  <Panel>

                    <!-- ── Group separator row — shown when IsSeparator=true ── -->
                    <StackPanel IsVisible="{Binding IsSeparator}" Margin="0,6,0,0">
                      <Border Height="1" Margin="14,0,14,0"
                              Background="{DynamicResource SeparatorBrush}"/>
                      <!-- Phase 8 UI polish (Task 5, alignment audit): the group label's left
                           margin was 18 (absolute x=28 from the sidebar edge: ItemsControl's
                           own Margin=10 + this 18), while a nav row's icon/label content
                           starts at absolute x=40 (ItemsControl Margin=10 + the nav-row Grid's
                           20-wide grip column + the nav Button's own Padding=10) — a 12px
                           mismatch. Bumped to 30 (10+30=40) so section headers and nav-row
                           content share one left edge, per the audit. The separator rule
                           itself is left at its original inset (14) — a decorative full-width
                           divider, not "content" the audit's shared-gutter rule targets. -->
                      <TextBlock Text="{Binding GroupLabel}"
                                 FontSize="{DynamicResource NxFont10}"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 Margin="30,5,0,2"
                                 LetterSpacing="1.2"/>
                    </StackPanel>

                    <!-- ── Nav item row — shown when IsSeparator=false ── -->
                    <Grid ColumnDefinitions="20,*"
                          Classes="nav-row"
                          Classes.dragging="{Binding IsDragging}"
                          IsVisible="{Binding !IsSeparator}"
                          Background="Transparent">
                      <!-- Drag grip — hidden for pinned items -->
                      <TextBlock Grid.Column="0"
                                 Classes="nav-grip"
                                 IsVisible="{Binding !IsPinned}"
                                 Text="&#x2807;"
                                 FontSize="{DynamicResource NxFont12}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 Cursor="Hand"
                                 ToolTip.Tip="Drag to reorder"/>
                      <!-- Navigation button -->
                      <Button Grid.Column="1"
                              Classes="nx-btn-ghost"
                              Classes.active="{Binding IsActive}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Padding="10,10"
                              Margin="0,1"
                              CornerRadius="10"
                              Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateCommand}"
                              CommandParameter="{Binding}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                          <TextBlock Text="{Binding Icon}"
                                     FontFamily="{StaticResource NexusIcons}"
                                     FontSize="{DynamicResource NxFont16}"
                                     Width="20"
                                     TextAlignment="Center"
                                     VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding Label}"
                                     FontSize="{DynamicResource NxFont13}"
                                     VerticalAlignment="Center"/>
                          <!-- Status badge (e.g. 🌙 for Quiet Hours) -->
                          <TextBlock Text="{Binding StatusBadge}"
                                     IsVisible="{Binding HasStatusBadge}"
                                     FontSize="{DynamicResource NxFont10}"
                                     Margin="4,0,0,0"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                      </Button>
                    </Grid>

                  </Panel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <!-- ── Crystal Glass specular stack (pointer-transparent, 3 layers) ── -->

          <!-- Layer 1: Broad diagonal wash — pointer-tracked specular highlight -->
          <Border x:Name="SideSpecularWash"
                  IsHitTestVisible="False"
                  Opacity="{DynamicResource GlassSpecularOpacity}">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="60%,100%">
                <GradientStop Color="#40FFFFFF" Offset="0"/>
                <GradientStop Color="#14FFFFFF" Offset="0.35"/>
                <GradientStop Color="#00FFFFFF" Offset="0.7"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>

          <!-- Layer 2: Left-edge rim — compressed to leading 4px for glass thickness -->
          <Border IsHitTestVisible="False"
                  Width="4"
                  HorizontalAlignment="Left"
                  Opacity="{DynamicResource GlassSpecularOpacity}">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#B0FFFFFF" Offset="0"/>
                <GradientStop Color="#30FFFFFF" Offset="0.6"/>
                <GradientStop Color="#00FFFFFF" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>

          <!-- Layer 3: Prismatic shimmer — rotating iridescent tint (animated in code) -->
          <Border x:Name="SidePrismatic"
                  IsHitTestVisible="False"
                  Opacity="{DynamicResource GlassSpecularOpacity}">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#0EFF8888" Offset="0.0"/>
                <GradientStop Color="#08FFFFFF" Offset="0.4"/>
                <GradientStop Color="#0E88FFFF" Offset="0.75"/>
                <GradientStop Color="#00FFFFFF" Offset="1.0"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>

        </Panel>

      </Border>

      <!-- ===== CONTENT AREA ===== -->
      <Border Grid.Column="1" Background="{DynamicResource BgPrimaryBrush}">
        <Panel>
          <!-- Content -->
          <!-- Phase 8 UI polish (Task 3): PageTransition is set from code (MainWindow.axaml.cs,
               UpdatePageTransition) instead of a static XAML CrossFade. Avalonia.Animation.CrossFade
               is a plain object — its Duration is a normal CLR property, not an AvaloniaProperty —
               so `Duration="{DynamicResource MotionBase}"` cannot live-track AnimationSpeed changes
               here the way it can on a Transition (DoubleTransition/TransformOperationsTransition/
               BoxShadowsTransition), confirmed via reflection (CrossFade : object, no *Property
               static fields). UpdatePageTransition instead reads the already-Apply()'d MotionBase
               resource value and swaps PageTransition to null when AnimatePageTransitions is off
               (or AnimationSpeed is 0) — an instant page swap instead of a zero-duration CrossFade,
               per the task's own suggested "swap to null transition when disabled" resolution. -->
          <TransitioningContentControl x:Name="PageHost" Content="{Binding CurrentPage}">
          <TransitioningContentControl.DataTemplates>
            <DataTemplate DataType="vm:AutomationViewModel">
              <views:AutomationView />
            </DataTemplate>
            <DataTemplate DataType="vm:DashboardViewModel">
              <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="vm:DiagnosticsViewModel">
              <views:DiagnosticsView />
            </DataTemplate>
            <DataTemplate DataType="vm:ProcessesViewModel">
              <views:ProcessesView />
            </DataTemplate>
            <DataTemplate DataType="vm:PerformanceViewModel">
              <views:PerformanceView />
            </DataTemplate>
            <DataTemplate DataType="vm:ServicesViewModel">
              <views:ServicesView />
            </DataTemplate>
            <DataTemplate DataType="vm:StartupViewModel">
              <views:StartupView />
            </DataTemplate>
            <DataTemplate DataType="vm:NetworkViewModel">
              <views:NetworkView />
            </DataTemplate>
            <DataTemplate DataType="vm:OptimizationViewModel">
              <views:OptimizationView />
            </DataTemplate>
            <DataTemplate DataType="vm:GamingModeViewModel">
              <views:GamingModeView />
            </DataTemplate>
            <DataTemplate DataType="vm:AlertsViewModel">
              <views:AlertsView />
            </DataTemplate>
            <DataTemplate DataType="vm:DiskAnalyzerViewModel">
              <views:DiskAnalyzerView />
            </DataTemplate>
            <DataTemplate DataType="vm:SystemInfoViewModel">
              <views:SystemInfoView />
            </DataTemplate>
            <DataTemplate DataType="vm:ProBalanceViewModel">
              <views:ProBalanceView />
            </DataTemplate>
            <DataTemplate DataType="vm:RulesViewModel">
              <views:RulesView />
            </DataTemplate>
            <DataTemplate DataType="vm:HistoryViewModel">
              <views:HistoryView />
            </DataTemplate>
            <DataTemplate DataType="vm:LanScannerViewModel">
              <views:LanScannerView />
            </DataTemplate>
            <DataTemplate DataType="vm:SettingsViewModel">
              <views:SettingsView />
            </DataTemplate>
            <DataTemplate DataType="vm:PerformanceProfilesViewModel">
              <views:PerformanceProfilesView />
            </DataTemplate>
          </TransitioningContentControl.DataTemplates>
          </TransitioningContentControl>

          <!-- ── Crystal Glass specular layers for content area (pointer-transparent) ── -->

          <!-- Layer 1: Content specular wash — pointer-tracked light source -->
          <Border x:Name="ContentSpecularWash"
                  IsHitTestVisible="False"
                  Height="80"
                  VerticalAlignment="Top"
                  Opacity="{DynamicResource GlassSpecularOpacity}">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#18FFFFFF" Offset="0"/>
                <GradientStop Color="#08FFFFFF" Offset="0.35"/>
                <GradientStop Color="#00FFFFFF" Offset="0.7"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>

          <!-- Layer 2: Prismatic shimmer — rotating iridescent tint (animated in code) -->
          <Border x:Name="ContentPrismatic"
                  IsHitTestVisible="False"
                  Opacity="{DynamicResource GlassSpecularOpacity}">
            <Border.Background>
              <LinearGradientBrush StartPoint="100%,0%" EndPoint="0%,100%">
                <GradientStop Color="#08FF8888" Offset="0.0"/>
                <GradientStop Color="#04FFFFFF" Offset="0.4"/>
                <GradientStop Color="#0888FFFF" Offset="0.8"/>
                <GradientStop Color="#00FFFFFF" Offset="1.0"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>

        </Panel>
      </Border>

    </Grid>

    <!-- ===== IN-APP NOTIFICATION OVERLAY ===== -->
    <!-- Spans entire window; host is pointer-transparent, individual toasts are hit-testable -->
    <controls:NotificationHost x:Name="AppNotificationHost"
                                Grid.Row="0" Grid.RowSpan="2"
                                IsHitTestVisible="False"
                                ZIndex="100"/>

    <!-- ===== COMMAND PALETTE OVERLAY ===== -->
    <!-- Spans entire window; sits above notifications. DataContext wired in code-behind on first Ctrl+K. -->
    <controls:CommandPaletteControl x:Name="CommandPalette"
                                     Grid.Row="0" Grid.RowSpan="2"
                                     ZIndex="200"/>

  </Grid>
</Window>
