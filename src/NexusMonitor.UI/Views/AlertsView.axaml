<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.AlertsView"
             x:DataType="vm:AlertsViewModel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="System Alerts"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <!-- Search box -->
        <Border DockPanel.Dock="Right"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerSM}"
                Padding="0" Margin="10,0,0,0"
                VerticalAlignment="Center" Width="200">
          <TextBox Name="SearchBox"
                   Text="{Binding SearchText}"
                   Watermark="Search alerts…"
                   BorderThickness="0"
                   Background="Transparent"
                   FontSize="{DynamicResource NxFont12}"
                   Padding="8,5"/>
        </Border>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button Classes="nx-btn"
                  Command="{Binding AddRuleCommand}"
                  ToolTip.Tip="Create a new alert rule">
            <TextBlock Text="＋ Add Rule" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding EditRuleCommand}"
                  IsEnabled="{Binding SelectedRule, Converter={x:Static ObjectConverters.IsNotNull}}"
                  ToolTip.Tip="Edit the selected rule">
            <TextBlock Text="✏ Edit" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding DeleteRuleCommand}"
                  IsEnabled="{Binding SelectedRule, Converter={x:Static ObjectConverters.IsNotNull}}"
                  ToolTip.Tip="Delete the selected rule">
            <TextBlock Text="🗑 Delete" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding ClearLogCommand}"
                  ToolTip.Tip="Clear alert log and reset session counters">
            <TextBlock Text="Clear Log" FontSize="{DynamicResource NxFont12}"/>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══ Main content ═════════════════════════════════════════════════════ -->
    <Grid>

      <!-- ── Rules list view (when editor is hidden) ─────────────────────── -->
      <DockPanel IsVisible="{Binding IsEditorVisible, Converter={x:Static BoolConverters.Not}}">

        <!-- Intro blurb -->
        <Border DockPanel.Dock="Top"
                Padding="16,10"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
          <TextBlock Text="Alerts notify you when system metrics (CPU, RAM, Disk, GPU, Temperature) exceed configured thresholds for a sustained period. Each rule can have its own severity, sustain duration, and cooldown to prevent alert fatigue."
                     FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>

        <ScrollViewer>
          <StackPanel Spacing="14" Margin="16">

            <!-- ── Session stat cards ──────────────────────────────────── -->
            <Grid ColumnDefinitions="*,8,*,8,*">

              <Border Grid.Column="0"
                      Padding="14,12"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="4">
                  <TextBlock Text="TOTAL ALERTS" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Text="{Binding AlertCount}"
                             FontSize="28" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBlueBrush}"/>
                  <TextBlock Text="this session" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
              </Border>

              <Border Grid.Column="2"
                      Padding="14,12"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="4">
                  <TextBlock Text="CRITICAL" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Text="{Binding CriticalCount}"
                             FontSize="28" FontWeight="Bold"
                             Foreground="{StaticResource ColorDangerBrush}"/>
                  <TextBlock Text="this session" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
              </Border>

              <Border Grid.Column="4"
                      Padding="14,12"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="4">
                  <TextBlock Text="WARNINGS" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Text="{Binding WarningCount}"
                             FontSize="28" FontWeight="Bold"
                             Foreground="{StaticResource ColorWarningBrush}"/>
                  <TextBlock Text="this session" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
              </Border>

            </Grid>

            <!-- ── Alert rules list ───────────────────────────────────── -->
            <Border Padding="0"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerLG}"
                    ClipToBounds="True">
              <StackPanel>

                <!-- Card header -->
                <Border Padding="16,12"
                        Background="{DynamicResource BgSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="Alert Rules"
                               FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding FilteredRules.Count, StringFormat='{}{0} rules'}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                  </DockPanel>
                </Border>

                <!-- Empty state -->
                <Border Padding="24,36"
                        IsVisible="{Binding !HasFilteredRules}">
                  <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="🔔" FontSize="36" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Text="No alert rules configured"
                               FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Click + Add Rule to create your first alert."
                               FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>

                <!-- Rule items -->
                <ItemsControl ItemsSource="{Binding FilteredRules}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="14,11"
                              BorderBrush="{DynamicResource BorderSubtleBrush}"
                              BorderThickness="0,0,0,1"
                              Cursor="Hand"
                              PointerPressed="OnRuleBorderPointerPressed">
                        <Border.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Edit Rule"
                                      Command="{Binding DataContext.EditRuleCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <MenuItem Header="Toggle Enabled"
                                      Command="{Binding DataContext.ToggleEnabledCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding}"/>
                            <Separator/>
                            <MenuItem Header="Delete Rule"
                                      Command="{Binding DataContext.DeleteRuleCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                          </ContextMenu>
                        </Border.ContextMenu>
                        <Border.Styles>
                          <Style Selector="Border:pointerover">
                            <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                          </Style>
                        </Border.Styles>
                        <DockPanel>

                          <!-- Severity color bar -->
                          <Border DockPanel.Dock="Left"
                                  Width="4" CornerRadius="2"
                                  VerticalAlignment="Stretch"
                                  Margin="0,0,12,0"
                                  Background="{Binding Severity, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Border.Styles>
                              <Style Selector="Border">
                                <Setter Property="Background" Value="#636366"/>
                              </Style>
                            </Border.Styles>
                          </Border>

                          <!-- Severity icon + name -->
                          <StackPanel DockPanel.Dock="Left"
                                      VerticalAlignment="Center"
                                      Spacing="2" MinWidth="160">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <TextBlock Text="{Binding SeverityIcon}"
                                         FontSize="{DynamicResource NxFont13}"
                                         VerticalAlignment="Center"/>
                              <TextBlock Text="{Binding Name}"
                                         FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding IsEnabled,
                                              StringFormat='{}Enabled: {0}'}"
                                       FontSize="{DynamicResource NxFont10}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                          </StackPanel>

                          <!-- Metric + threshold -->
                          <StackPanel DockPanel.Dock="Left"
                                      VerticalAlignment="Center"
                                      Spacing="2" Margin="12,0" MinWidth="180">
                            <TextBlock Text="{Binding Metric}"
                                       FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                                       Foreground="{DynamicResource AccentBlueBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                              <TextBlock Text="Threshold:"
                                         FontSize="{DynamicResource NxFont11}"
                                         Foreground="{DynamicResource TextTertiaryBrush}"/>
                              <TextBlock Text="{Binding Threshold, StringFormat='{}{0:F0}'}"
                                         FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                          </StackPanel>

                          <!-- Sustain / Cooldown -->
                          <StackPanel DockPanel.Dock="Left"
                                      VerticalAlignment="Center"
                                      Spacing="2" Margin="0,0,12,0">
                            <TextBlock Text="{Binding SustainSec,
                                              StringFormat='{}Sustain: {0}s'}"
                                       FontSize="{DynamicResource NxFont11}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding CooldownSec,
                                              StringFormat='{}Cooldown: {0}s'}"
                                       FontSize="{DynamicResource NxFont11}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                          </StackPanel>

                          <!-- Enable toggle + Edit button -->
                          <StackPanel DockPanel.Dock="Right"
                                      Orientation="Horizontal" Spacing="8"
                                      VerticalAlignment="Center">
                            <ToggleButton Classes="nx-toggle"
                                          IsChecked="{Binding IsEnabled}"
                                          Command="{Binding DataContext.ToggleEnabledCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"/>
                            <Button Classes="nx-btn"
                                    Padding="8,4"
                                    FontSize="{DynamicResource NxFont11}"
                                    Content="Edit"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.EditRuleCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Click="OnRuleRowClick"/>
                          </StackPanel>

                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </Border>

            <!-- ── Activity log ────────────────────────────────────────── -->
            <Border Padding="0"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerLG}"
                    ClipToBounds="True">
              <StackPanel>

                <!-- Card header -->
                <Border Padding="16,12"
                        Background="{DynamicResource BgSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="Alert Log"
                               FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding FilteredEventLog.Count, StringFormat='{}{0} events'}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                  </DockPanel>
                </Border>

                <!-- Empty state -->
                <Border Padding="24,28"
                        IsVisible="{Binding !HasFilteredEventLog}">
                  <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="🔕" FontSize="28" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Text="No alerts fired yet"
                               FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Configure alert rules above — alerts will appear here when thresholds are exceeded."
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
                  </StackPanel>
                </Border>

                <!-- Log entries (newest first) -->
                <ItemsControl ItemsSource="{Binding FilteredEventLog}"
                              MaxHeight="300">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="14,7"
                              BorderBrush="{DynamicResource BorderSubtleBrush}"
                              BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="22,60,*,Auto">

                          <!-- Severity icon -->
                          <TextBlock Grid.Column="0"
                                     Text="{Binding SeverityIcon}"
                                     FontSize="{DynamicResource NxFont14}"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Center"/>

                          <!-- Timestamp -->
                          <TextBlock Grid.Column="1"
                                     Text="{Binding TimeDisplay}"
                                     FontSize="{DynamicResource NxFont11}"
                                     FontFamily="Consolas,Courier New,monospace"
                                     Foreground="{DynamicResource TextTertiaryBrush}"
                                     VerticalAlignment="Center"
                                     Margin="6,0"/>

                          <!-- Description -->
                          <TextBlock Grid.Column="2"
                                     Text="{Binding Description}"
                                     FontSize="{DynamicResource NxFont12}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis"/>

                          <!-- Value badge -->
                          <Border Grid.Column="3"
                                  Padding="8,3"
                                  CornerRadius="4"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0"
                                  Background="{Binding SeverityColor}">
                            <TextBlock Text="{Binding ValueDisplay}"
                                       FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                                       Foreground="White"/>
                          </Border>

                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>

      </DockPanel>

      <!-- ══ Editor panel (shown when IsEditorVisible) ════════════════════ -->
      <Border IsVisible="{Binding IsEditorVisible}"
              Background="{DynamicResource BgBaseBrush}">
        <DockPanel>

          <!-- Editor header -->
          <Border DockPanel.Dock="Top"
                  Padding="16,10"
                  Background="{DynamicResource BgSecondaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left"
                         Text="{Binding EditorTitle}"
                         FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
                <Button Classes="nx-btn"
                        Command="{Binding SaveEditCommand}"
                        ToolTip.Tip="Save this alert rule">
                  <TextBlock Text="💾 Save" FontSize="{DynamicResource NxFont12}"/>
                </Button>
                <Button Classes="nx-btn"
                        Command="{Binding CancelEditCommand}">
                  <TextBlock Text="Cancel" FontSize="{DynamicResource NxFont12}"/>
                </Button>
              </StackPanel>
            </DockPanel>
          </Border>

          <ScrollViewer>
            <StackPanel Spacing="16" MaxWidth="700" Margin="16">

              <!-- ── Identity ─────────────────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <TextBlock Text="RULE IDENTITY" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>

                  <Grid ColumnDefinitions="*,14,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Rule Name" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditName}" Watermark="My CPU Alert"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Bottom">
                      <CheckBox IsChecked="{Binding EditEnabled}"
                                Content="Rule is enabled"
                                FontSize="{DynamicResource NxFont12}"/>
                    </StackPanel>
                  </Grid>

                </StackPanel>
              </Border>

              <!-- ── Metric + Threshold ────────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <TextBlock Text="METRIC &amp; THRESHOLD" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>

                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Metric to monitor" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:AlertsViewModel.MetricOptions}"
                                SelectedIndex="{Binding EditMetricIndex}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="Severity" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:AlertsViewModel.SeverityOptions}"
                                SelectedIndex="{Binding EditSeverityIndex}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                  </Grid>

                  <!-- Threshold slider -->
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0"
                                 Text="Alert threshold"
                                 FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding EditThreshold, StringFormat='{}{0:F0}'}"
                                 FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AccentBlueBrush}"
                                 VerticalAlignment="Center"/>
                    </Grid>
                    <Slider Minimum="1" Maximum="100" TickFrequency="5"
                            Value="{Binding EditThreshold}"/>
                    <TextBlock FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               Text="For CPU/RAM/Disk/GPU: threshold is a percentage (%). For CPU Temperature: threshold is degrees Celsius (°C)."/>
                  </StackPanel>

                </StackPanel>
              </Border>

              <!-- ── Timing ────────────────────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <StackPanel Spacing="2">
                    <TextBlock Text="TIMING" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                               LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Text="Control how long the metric must stay over threshold before alerting, and how long to wait before repeating."
                               FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Sustain duration (seconds)" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <NumericUpDown Value="{Binding EditSustainSec}"
                                     Minimum="0" Maximum="3600" Increment="1"
                                     FormatString="0"/>
                      <TextBlock Text="Metric must stay above threshold for this many seconds before the alert fires."
                                 FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                                 Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="Cooldown period (seconds)" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <NumericUpDown Value="{Binding EditCooldownSec}"
                                     Minimum="0" Maximum="86400" Increment="10"
                                     FormatString="0"/>
                      <TextBlock Text="Minimum seconds between repeated alerts for this rule (prevents alert spam)."
                                 FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                                 Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                  </Grid>

                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>

        </DockPanel>
      </Border>

    </Grid>

  </DockPanel>

</UserControl>
