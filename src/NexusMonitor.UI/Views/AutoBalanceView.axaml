<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.AutoBalanceView"
             x:DataType="vm:AutoBalanceViewModel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Auto-Balance"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button Classes="nx-btn"
                  Command="{Binding ClearLogCommand}"
                  ToolTip.Tip="Clear activity log and reset session counters">
            <TextBlock Text="Clear Log" FontSize="{DynamicResource NxFont12}"/>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══ Content ══════════════════════════════════════════════════════════ -->
    <ScrollViewer>
      <StackPanel Spacing="14" Margin="16">

        <!-- ── Master enable card ───────────────────────────────────────── -->
        <Border Padding="20,16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}">
          <Grid ColumnDefinitions="*,Auto">

            <StackPanel Grid.Column="0" Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="⚖" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text="Auto-Balance CPU Balancer"
                           FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <!-- Status indicator -->
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusLabel}"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock TextWrapping="Wrap" MaxWidth="520"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         Text="{Binding HowItWorks, Mode=OneTime}"
                         Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Enable toggle -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4"
                        HorizontalAlignment="Right" Margin="20,0,0,0">
              <ToggleButton Classes="nx-toggle" IsChecked="{Binding IsEnabled}"/>
            </StackPanel>

          </Grid>
        </Border>

        <!-- ── Session stats ─────────────────────────────────────────────── -->
        <Grid ColumnDefinitions="*,8,*,8,*">

          <Border Grid.Column="0"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="CURRENTLY THROTTLED" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Text="{Binding ThrottledNow}"
                         FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorWarningBrush}"/>
              <TextBlock Text="background processes" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="2"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="TOTAL THROTTLED" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Text="{Binding TotalThrottled}"
                         FontSize="28" FontWeight="Bold"
                         Foreground="{DynamicResource AccentBlueBrush}"/>
              <TextBlock Text="this session" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="4"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="TOTAL RESTORED" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Text="{Binding TotalRestored}"
                         FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorSuccessBrush}"/>
              <TextBlock Text="this session" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>

        </Grid>

        <!-- ── Two-column config section ─────────────────────────────────── -->
        <Grid ColumnDefinitions="*,14,*">

          <!-- Left: CPU Threshold -->
          <Border Grid.Column="0"
                  Padding="16"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="12">
              <TextBlock Text="THROTTLE THRESHOLD" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="CPU usage to trigger throttling"
                             FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding CpuThreshold, StringFormat='{}{0:F0}%'}"
                             FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentBlueBrush}"
                             VerticalAlignment="Center"/>
                </Grid>
                <Slider Minimum="50" Maximum="99" TickFrequency="5"
                        Value="{Binding CpuThreshold}"/>
              </StackPanel>

              <!-- Explanation -->
              <Border Padding="10,8"
                      Background="{DynamicResource BgSecondaryBrush}"
                      CornerRadius="{StaticResource CornerMD}">
                <StackPanel Spacing="4">
                  <TextBlock Text="How the threshold works:"
                             FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBlock TextWrapping="Wrap" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             Text="When total CPU ≥ threshold, background processes using &gt;5% CPU are lowered to Below Normal. When CPU drops to 70% of threshold, all are restored. The 70% restore band prevents rapid on/off oscillation."/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <!-- Right: Exclusion list -->
          <Border Grid.Column="2"
                  Padding="16"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="10">
              <TextBlock Text="PROTECTED PROCESSES" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         Text="These processes will never be throttled (one name per line, no .exe needed):"/>
              <TextBox Text="{Binding ExclusionsText}"
                       AcceptsReturn="True"
                       MinHeight="120"
                       MaxHeight="200"
                       FontSize="{DynamicResource NxFont12}"
                       FontFamily="Consolas,Courier New,monospace"
                       Padding="8,6"
                       Watermark="chrome&#x0A;spotify&#x0A;teams"/>
              <TextBlock FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         Text="The foreground window process is always protected automatically."/>
            </StackPanel>
          </Border>

        </Grid>

        <!-- ── Activity log ──────────────────────────────────────────────── -->
        <Border Padding="0"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}"
                ClipToBounds="True">
          <StackPanel>

            <!-- Card header -->
            <Border Padding="16,12"
                    Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1">
              <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Activity Log"
                           FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding EventLog.Count, StringFormat='{}{0} events'}"
                           FontSize="{DynamicResource NxFont11}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
              </DockPanel>
            </Border>

            <!-- Empty state -->
            <Border Padding="24,28"
                    IsVisible="{Binding EventLog.Count,
                                        Converter={x:Static BoolConverters.Not}}">
              <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="⚖" FontSize="28" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                <TextBlock Text="No activity yet"
                           FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Enable Auto-Balance above and the log will populate as processes are throttled and restored."
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
              </StackPanel>
            </Border>

            <!-- Log entries (newest first) -->
            <ItemsControl ItemsSource="{Binding EventLog}"
                          MaxHeight="320">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="14,7"
                          BorderBrush="{DynamicResource BorderSubtleBrush}"
                          BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="22,60,*">

                      <!-- Type icon -->
                      <TextBlock Grid.Column="0"
                                 Text="{Binding TypeIcon}"
                                 FontSize="{DynamicResource NxFont14}"
                                 Foreground="{Binding TypeColor}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"/>

                      <!-- Timestamp -->
                      <TextBlock Grid.Column="1"
                                 Text="{Binding TimeDisplay}"
                                 FontSize="{DynamicResource NxFont11}"
                                 FontFamily="Consolas,Courier New,monospace"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 VerticalAlignment="Center"
                                 Margin="6,0"/>

                      <!-- Description -->
                      <TextBlock Grid.Column="2"
                                 Text="{Binding Description}"
                                 FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"/>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>

</UserControl>
