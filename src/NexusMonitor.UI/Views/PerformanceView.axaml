<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             x:Class="NexusMonitor.UI.Views.PerformanceView"
             x:DataType="vm:PerformanceViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:CpuHeatBrushConverter x:Key="CpuHeat"/>
    <conv:MacOsUnavailableConverter x:Key="MacOsNa"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Perf sidebar drag grip. Phase 8 UI polish (Task 4 fold-in): migrated to Motion tokens —
         mirrors MainWindow.axaml's identical nav-grip/nav-row drag pair (Task 3's own mapping:
         ≤120ms→Fast, 150-200ms→Base, ≥250ms→Slow), which these device-row Transitions duplicate
         almost verbatim. Duration-zeroing only (no AnimateHoverEffects toggle gate), same
         CONDUCTOR RULING Task 3 applied to MainWindow's own nav-row pair. -->
    <Style Selector="TextBlock.perf-grip">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Transitions">
        <Transitions><DoubleTransition Property="Opacity" Duration="{DynamicResource MotionBase}"/></Transitions>
      </Setter>
    </Style>
    <Style Selector="Grid.perf-device-row:pointerover TextBlock.perf-grip">
      <Setter Property="Opacity" Value="0.35"/>
    </Style>
    <Style Selector="Grid.perf-device-row.dragging TextBlock.perf-grip">
      <Setter Property="Opacity" Value="0.7"/>
    </Style>
    <Style Selector="Grid.perf-device-row">
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="{DynamicResource MotionSlow}">
            <TransformOperationsTransition.Easing><CubicEaseOut/></TransformOperationsTransition.Easing>
          </TransformOperationsTransition>
          <DoubleTransition Property="Opacity" Duration="{DynamicResource MotionBase}"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Grid.perf-device-row.dragging">
      <Setter Property="RenderTransform" Value="scale(1.01)"/>
      <Setter Property="Opacity" Value="0.94"/>
      <Setter Property="ZIndex" Value="10"/>
    </Style>
    <!-- Sidebar item selected and hover states -->
    <Style Selector="Border.perf-item-selected">
      <Setter Property="Background" Value="{DynamicResource AccentBlueDimBrush}"/>
    </Style>
    <Style Selector="ItemsControl#PerfDeviceList Border.perf-item-body:pointerover">
      <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="180,1,*">

    <!-- ===== LEFT SIDEBAR ===== -->
    <Border Grid.Column="0"
            Background="{DynamicResource BgSecondaryBrush}"
            Padding="0">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl x:Name="PerfDeviceList"
                      ItemsSource="{Binding Devices}"
                      Margin="4,8">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="16,*"
                    Classes="perf-device-row"
                    Classes.dragging="{Binding IsDragging}"
                    Background="Transparent"
                    Margin="0,1">
                <!-- Drag grip -->
                <TextBlock Grid.Column="0" Classes="perf-grip"
                           Text="&#x2807;" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Cursor="Hand" ToolTip.Tip="Drag to reorder"/>
                <!-- Clickable device item -->
                <Border Grid.Column="1" Padding="8,6" CornerRadius="8"
                        Background="Transparent"
                        Cursor="Hand"
                        Classes="perf-item-body"
                        Classes.perf-item-selected="{Binding IsSelected}"
                        PointerPressed="OnDeviceItemClick">
                  <Grid RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="{Binding DeviceName}"
                               FontSize="{DynamicResource NxFont13}" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,2,0,3">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding DeviceSubName}"
                                 FontSize="{DynamicResource NxFont11}"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding ValueDisplay}"
                                 FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AccentBlueBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>
                    <lvc:CartesianChart Grid.Row="2"
                                        Series="{Binding MiniSeries}"
                                        XAxes="{Binding MiniXAxes}"
                                        YAxes="{Binding MiniYAxes}"
                                        Height="30"
                                        Background="Transparent"
                                        AnimationsSpeed="0:0:0"/>
                  </Grid>
                </Border>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- Separator -->
    <GridSplitter Grid.Column="1"
                  Width="1"
                  Background="{DynamicResource BorderSubtleBrush}"
                  ResizeDirection="Columns"/>

    <!-- ===== DETAIL PANEL ===== -->
    <!-- Phase 8 UI polish (Task 4 fold-in): CrossFade.Duration is a plain CLR property (not an
         AvaloniaProperty — confirmed via reflection in Task 3), so it can't be a
         {DynamicResource MotionFast} XAML binding the way an ordinary Transition's Duration can.
         Wired the same way MainWindow.axaml's own page CrossFade was (Task 3): named here,
         PageTransition set/rebuilt from code — see PerformanceView.axaml.cs's
         UpdateDeviceTransition(). -->
    <TransitioningContentControl x:Name="DeviceHost" Grid.Column="2"
                                 Content="{Binding SelectedDevice}">
      <TransitioningContentControl.DataTemplates>

        <!-- ════════════════════════════════════════════════════════════════════
             OVERVIEW PANEL
             ════════════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="vm:OverviewDeviceViewModel">
          <ContentControl Content="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ContentControl.ContentTemplate>
              <DataTemplate>
                <Grid RowDefinitions="Auto,*,*,Auto" Margin="20,16,20,10">

                  <!-- Row 0: Title + Summary cards -->
                  <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,10">
                    <TextBlock Text="Performance"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Grid ColumnDefinitions="*,12,*,12,*">
                      <!-- CPU card -->
                      <Border Grid.Column="0" Padding="14"
                              Background="{DynamicResource BgElevatedBrush}"
                              BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                              CornerRadius="{StaticResource CornerLG}">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="CPU" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                                       Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.8"/>
                            <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0:F1}%'}"
                                       FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding CpuFrequencyGhz, StringFormat='{}{0:F2} GHz'}"
                                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding CpuTempC, StringFormat='{}{0}°C'}"
                                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Right"/>
                          </StackPanel>
                        </Grid>
                      </Border>
                      <!-- Memory card -->
                      <Border Grid.Column="2" Padding="14"
                              Background="{DynamicResource BgElevatedBrush}"
                              BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                              CornerRadius="{StaticResource CornerLG}">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="MEMORY" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                                       Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.8"/>
                            <TextBlock Text="{Binding MemPercent, StringFormat='{}{0:F1}%'}"
                                       FontSize="24" FontWeight="Bold" Foreground="{StaticResource ColorSuccessBrush}"/>
                          </StackPanel>
                          <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                     FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding MemUsedGb, StringFormat='{}{0:F1}'}"/>
                            <Run Text="/" FontSize="9"/>
                            <Run Text="{Binding MemTotalGb, StringFormat='{}{0:F0} GB'}"/>
                          </TextBlock>
                        </Grid>
                      </Border>
                      <!-- GPU card -->
                      <Border Grid.Column="4" Padding="14"
                              IsVisible="{Binding HasGpuData}"
                              Background="{DynamicResource BgElevatedBrush}"
                              BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                              CornerRadius="{StaticResource CornerLG}">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="GPU" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                                       Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.8"/>
                            <TextBlock Text="{Binding GpuPercent, StringFormat='{}{0:F1}%'}"
                                       FontSize="24" FontWeight="Bold" Foreground="{StaticResource ColorInfoBrush}"/>
                          </StackPanel>
                          <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                     FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding GpuMemGb, StringFormat='{}{0:F1}'}"/>
                            <Run Text="/" FontSize="9"/>
                            <Run Text="{Binding GpuMemTotalGb, StringFormat='{}{0:F0} GB'}"/>
                          </TextBlock>
                        </Grid>
                      </Border>
                    </Grid>
                  </StackPanel>

                  <!-- Row 1: CPU chart + Memory chart side by side -->
                  <Grid Grid.Row="1" ColumnDefinitions="*,10,*" Margin="0,0,0,10">
                    <Border Grid.Column="0" Padding="14"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                            CornerRadius="{StaticResource CornerLG}">
                      <Grid RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                          <TextBlock Grid.Column="0" Text="CPU Utilization"
                                     FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding CpuPercent, StringFormat='{}{0:F1}%'}"
                                     FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource AccentBlueBrush}"/>
                        </Grid>
                        <lvc:CartesianChart Grid.Row="1"
                                             Series="{Binding CpuSeries}"
                                             XAxes="{Binding CpuXAxes}" YAxes="{Binding CpuYAxes}"
                                             MinHeight="60"
                                             Background="Transparent"
                                             AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                      </Grid>
                    </Border>
                    <Border Grid.Column="2" Padding="14"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                            CornerRadius="{StaticResource CornerLG}">
                      <Grid RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                          <TextBlock Grid.Column="0" Text="Memory Usage"
                                     FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding MemUsedGb, StringFormat='{}{0:F1} GB'}"
                                     FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                                     Foreground="{StaticResource ColorSuccessBrush}"/>
                        </Grid>
                        <lvc:CartesianChart Grid.Row="1"
                                             Series="{Binding MemSeries}"
                                             XAxes="{Binding CpuXAxes}" YAxes="{Binding MemYAxes}"
                                             MinHeight="60"
                                             Background="Transparent"
                                             AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                      </Grid>
                    </Border>
                  </Grid>

                  <!-- Row 2: Disk I/O + Network side by side -->
                  <Grid Grid.Row="2" ColumnDefinitions="*,10,*" Margin="0,0,0,10">
                    <Border Grid.Column="0" Padding="14"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                            CornerRadius="{StaticResource CornerLG}">
                      <Grid RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                          <TextBlock Grid.Column="0" Text="Disk I/O"
                                     FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding DiskReadMbps, StringFormat='R: {0:F1} MB/s'}"
                                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource ColorInfoBrush}"/>
                            <TextBlock Text="{Binding DiskWriteMbps, StringFormat='W: {0:F1} MB/s'}"
                                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource ColorWarningBrush}"/>
                          </StackPanel>
                        </Grid>
                        <lvc:CartesianChart Grid.Row="1"
                                             Series="{Binding DiskSeries}"
                                             XAxes="{Binding CpuXAxes}"
                                             MinHeight="50"
                                             Background="Transparent"
                                             AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                      </Grid>
                    </Border>
                    <Border Grid.Column="2" Padding="14"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                            CornerRadius="{StaticResource CornerLG}">
                      <Grid RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                          <TextBlock Grid.Column="0" Text="Network"
                                     FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding NetRecvMbps, StringFormat='&#x2193; {0:F2} MB/s'}"
                                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource ProcDotNetBrush}"/>
                            <TextBlock Text="{Binding NetSendMbps, StringFormat='&#x2191; {0:F2} MB/s'}"
                                       FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource ColorDangerBrush}"/>
                          </StackPanel>
                        </Grid>
                        <lvc:CartesianChart Grid.Row="1"
                                             Series="{Binding NetSeries}"
                                             XAxes="{Binding CpuXAxes}"
                                             MinHeight="50"
                                             Background="Transparent"
                                             AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                      </Grid>
                    </Border>
                  </Grid>

                  <!-- Row 3: Per-Core heatmap + Disk Drives side by side (compact) -->
                  <Grid Grid.Row="3" ColumnDefinitions="*,10,*">
                    <!-- Per-Core -->
                    <Border Grid.Column="0" Padding="12"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                            CornerRadius="{StaticResource CornerLG}">
                      <StackPanel Spacing="6">
                        <TextBlock Text="Per-Core Utilization"
                                   FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ItemsControl ItemsSource="{Binding CoreCells}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="42" Height="34" Margin="0,0,3,3" CornerRadius="6"
                                      Background="{Binding Percent, Converter={StaticResource CpuHeat}}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="0">
                                  <TextBlock Text="{Binding Index, StringFormat='C{0}'}"
                                             FontSize="7" Foreground="White" HorizontalAlignment="Center"/>
                                  <TextBlock Text="{Binding Percent, StringFormat='{}{0:F0}%'}"
                                             FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                                             Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                    <!-- Disk Drives -->
                    <Border Grid.Column="2" Padding="12"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                            CornerRadius="{StaticResource CornerLG}">
                      <StackPanel Spacing="6">
                        <TextBlock Text="Disk Drives"
                                   FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ItemsControl ItemsSource="{Binding DriveRows}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Grid ColumnDefinitions="36,*,Auto" Margin="0,3,0,0">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DriveLetter}"
                                           FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Value="{Binding UsedPercent}"
                                             Minimum="0" Maximum="100" Height="5" Margin="4,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding UsedPercent, StringFormat='{}{0:F0}%'}"
                                           FontSize="{DynamicResource NxFont10}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Grid>
              </DataTemplate>
            </ContentControl.ContentTemplate>
          </ContentControl>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════════════════
             CPU DETAIL PANEL
             ════════════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="vm:CpuDeviceViewModel">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="20">

              <!-- Title -->
              <TextBlock Text="{Binding DeviceName}" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>

              <!-- Utilization chart -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="% Utilization"
                               FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="100% max · 60s"
                               FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                  </Grid>
                  <lvc:CartesianChart Series="{Binding HistorySeries}"
                                       XAxes="{Binding HistoryXAxes}" YAxes="{Binding HistoryYAxes}"
                                       Height="150" Background="Transparent"
                                       AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                </StackPanel>
              </Border>

              <!-- Top stats row -->
              <Grid ColumnDefinitions="*,*,*,*">
                <Border Grid.Column="0" Padding="12" Margin="0,0,6,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UtilPercent, StringFormat='{}{0:F1}%'}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBlueBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Utilization" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="12" Margin="3,0,3,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding SpeedDisplay}" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Speed" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="12" Margin="3,0,3,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TempC, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F0}°C'}" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                               Foreground="{StaticResource ColorWarningBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Temperature" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="3" Padding="12" Margin="6,0,0,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UptimeDisplay}" FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Up time" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Per-Core Utilization heatmap -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="8">
                  <TextBlock Text="Per-Core Utilization" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <ItemsControl ItemsSource="{Binding CoreCells}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="52" Height="44" Margin="0,0,4,4" CornerRadius="8"
                                Background="{Binding Percent, Converter={StaticResource CpuHeat}}">
                          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding Index, StringFormat='C{0}'}"
                                       FontSize="8" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Percent, StringFormat='{}{0:F0}%'}"
                                       FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <!-- System Info card -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="0">
                  <TextBlock Text="System Info" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                  <!-- Base speed -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Base speed"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BaseSpeedDisplay}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- Sockets -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Sockets"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Sockets}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- Cores -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Cores"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding PhysicalCores}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- Logical processors -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Logical processors"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding LogicalCores}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- Virtualization -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Virtualization"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Virtualization}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- Separator -->
                  <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>

                  <!-- Processes -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Processes"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProcessCount}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- Threads -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Threads"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding ThreadCount}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- Handles -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Handles"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding HandleCount, Converter={StaticResource MacOsNa}}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- Separator -->
                  <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>

                  <!-- L1 cache -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="L1 cache"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding L1CacheDisplay}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- L2 cache -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="L2 cache"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding L2CacheDisplay}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <!-- L3 cache -->
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,0">
                    <TextBlock Grid.Column="0" Text="L3 cache"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding L3CacheDisplay}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>
                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════════════════
             MEMORY DETAIL PANEL
             ════════════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="vm:MemoryDeviceViewModel">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="20">

              <!-- Title -->
              <TextBlock Text="Memory" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>

              <!-- Memory composition chart -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Memory usage"
                               FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center">
                      <Run Text="{Binding TotalGb, StringFormat='{}{0:F0}'}"/>
                      <Run Text=" GB total"/>
                    </TextBlock>
                  </Grid>
                  <lvc:CartesianChart Series="{Binding HistorySeries}"
                                       XAxes="{Binding HistoryXAxes}" YAxes="{Binding HistoryYAxes}"
                                       Height="150" Background="Transparent"
                                       AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                </StackPanel>
              </Border>

              <!-- Top stats row -->
              <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0" Padding="12" Margin="0,0,6,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource ColorSuccessBrush}" HorizontalAlignment="Center">
                      <Run Text="{Binding UsedGb, StringFormat='{}{0:F1}'}"/>
                      <Run Text=" GB" FontSize="{DynamicResource NxFont12}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding UsedPercent, StringFormat='In use ({0:F1}%)'}"
                               FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="12" Margin="3,0,3,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding AvailGb, StringFormat='{}{0:F1} GB'}" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Available" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="12" Margin="6,0,0,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CommittedDisplay}" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Committed" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Two-column layout: Composition + Hardware -->
              <Grid ColumnDefinitions="*,12,*">

                <!-- Composition card -->
                <Border Grid.Column="0" Padding="16"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerLG}">
                  <StackPanel Spacing="0">
                    <TextBlock Text="Composition" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="In use"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding UsedGb, StringFormat='{}{0:F1} GB'}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Compressed"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding CompressedDisplay}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Available"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding AvailGb, StringFormat='{}{0:F1} GB'}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Cached"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding CachedGb, StringFormat='{}{0:F1} GB'}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Paged pool"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding PagedPoolGb, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F2} GB'}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,0">
                      <TextBlock Grid.Column="0" Text="Non-paged pool"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding NonPagedPoolGb, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F2} GB'}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Hardware card -->
                <Border Grid.Column="2" Padding="16"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerLG}">
                  <StackPanel Spacing="0">
                    <TextBlock Text="Hardware" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Speed"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}"
                                 Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right">
                        <Run Text="{Binding SpeedMhz}"/>
                        <Run Text=" MHz"/>
                      </TextBlock>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Slots used"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding SlotsDisplay}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Form factor"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding FormFactor}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,0">
                      <TextBlock Grid.Column="0" Text="Hardware reserved"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding HwReservedDisplay}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>
                  </StackPanel>
                </Border>

              </Grid>

            </StackPanel>
          </ScrollViewer>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════════════════
             DISK DETAIL PANEL
             ════════════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="vm:DiskDeviceViewModel">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="20">

              <!-- Title + subtitle -->
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding PhysicalName}" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding DriveLetters}" FontSize="{DynamicResource NxFont11}"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
              </StackPanel>

              <!-- Transfer rate chart -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Disk transfer rate"
                               FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="10" Height="3" CornerRadius="1" Background="{StaticResource ColorInfoBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Read" FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="10" Height="3" CornerRadius="1" Background="{StaticResource ColorWarningBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Write" FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                    </StackPanel>
                  </Grid>
                  <lvc:CartesianChart Series="{Binding HistorySeries}"
                                       XAxes="{Binding HistoryXAxes}"
                                       Height="140" Background="Transparent"
                                       AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                </StackPanel>
              </Border>

              <!-- Top stats row -->
              <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0" Padding="12" Margin="0,0,6,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ActivePercent, StringFormat='{}{0:F0}%'}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource ColorInfoBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Active time" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="12" Margin="3,0,3,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ReadRateDisplay}" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                               Foreground="{StaticResource ColorInfoBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Read" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="12" Margin="6,0,0,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding WriteRateDisplay}" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                               Foreground="{StaticResource ColorWarningBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Write" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Two-column: Info + Storage -->
              <Grid ColumnDefinitions="*,12,*">

                <!-- Disk Info card -->
                <Border Grid.Column="0" Padding="16"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerLG}">
                  <StackPanel Spacing="0">
                    <TextBlock Text="Disk Info" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Type"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding DiskType}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Capacity"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding TotalGb, StringFormat='{}{0:F0} GB'}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Avg. response time"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding AvgResponseDisplay}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="System disk"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right">
                        <TextBlock.Text>
                          <Binding Path="IsSystemDisk">
                            <Binding.Converter>
                              <conv:BoolToYesNoConverter/>
                            </Binding.Converter>
                          </Binding>
                        </TextBlock.Text>
                      </TextBlock>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,0">
                      <TextBlock Grid.Column="0" Text="Page file"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right">
                        <TextBlock.Text>
                          <Binding Path="HasPageFile">
                            <Binding.Converter>
                              <conv:BoolToYesNoConverter/>
                            </Binding.Converter>
                          </Binding>
                        </TextBlock.Text>
                      </TextBlock>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Storage usage card -->
                <Border Grid.Column="2" Padding="16"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerLG}">
                  <StackPanel Spacing="0">
                    <TextBlock Text="Storage" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                    <ProgressBar Value="{Binding CapacityUsedPercent}" Minimum="0" Maximum="100" Height="8"
                                 Margin="0,0,0,6"/>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                      <TextBlock Grid.Column="0" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding TotalGb, StringFormat='{}{0:F0} GB total'}"/>
                      </TextBlock>
                      <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"
                                 HorizontalAlignment="Right">
                        <Run Text="{Binding FreeGb, StringFormat='{}{0:F0} GB free'}"/>
                      </TextBlock>
                    </Grid>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Volumes card -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="8">
                  <TextBlock Text="Volumes" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <ItemsControl ItemsSource="{Binding Volumes}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="10"
                                Background="{DynamicResource BgSecondaryBrush}"
                                CornerRadius="{StaticResource CornerSM}">
                          <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding DriveLetter}" FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Label}" FontSize="{DynamicResource NxFont11}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                              </StackPanel>
                              <TextBlock Grid.Column="1" Text="{Binding FileSystem}" FontSize="{DynamicResource NxFont10}"
                                         Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar Value="{Binding UsedPercent}" Minimum="0" Maximum="100" Height="5"/>
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock Grid.Column="0" FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}">
                                <Run Text="{Binding FreeGb, StringFormat='{}{0:F1} GB free'}"/>
                                <Run Text=" of "/>
                                <Run Text="{Binding TotalGb, StringFormat='{}{0:F1} GB'}"/>
                              </TextBlock>
                              <TextBlock Grid.Column="1" Text="{Binding UsedPercent, StringFormat='{}{0:F0}% used'}"
                                         FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </Grid>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════════════════
             NETWORK DETAIL PANEL
             ════════════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="vm:NetworkDeviceViewModel">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="20">

              <!-- Title -->
              <TextBlock Text="{Binding AdapterName}" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>

              <!-- Throughput chart -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Throughput"
                               FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="10" Height="3" CornerRadius="1" Background="{StaticResource ProcDotNetBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Download" FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="10" Height="3" CornerRadius="1" Background="{StaticResource ColorDangerBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Upload" FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                    </StackPanel>
                  </Grid>
                  <lvc:CartesianChart Series="{Binding HistorySeries}"
                                       XAxes="{Binding HistoryXAxes}"
                                       Height="140" Background="Transparent"
                                       AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                </StackPanel>
              </Border>

              <!-- Top stats row -->
              <Grid ColumnDefinitions="*,*">
                <Border Grid.Column="0" Padding="16" Margin="0,0,6,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding RecvRateDisplay}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource ProcDotNetBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="&#x2193; Download" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="16" Margin="6,0,0,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding SendRateDisplay}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource ColorDangerBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="&#x2191; Upload" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Two-column: Connection info + Totals -->
              <Grid ColumnDefinitions="*,12,*">

                <!-- Connection Info card -->
                <Border Grid.Column="0" Padding="16"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerLG}">
                  <StackPanel Spacing="0">
                    <TextBlock Text="Connection" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Adapter type"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding AdapterType}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Connection type"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding ConnectionType}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Link speed"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding LinkSpeedDisplay}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="DNS suffix"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding DnsSuffix}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Addresses + Totals card -->
                <Border Grid.Column="2" Padding="16"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerLG}">
                  <StackPanel Spacing="0">
                    <TextBlock Text="Addresses" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="IPv4 address"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding Ipv4Display}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="IPv6 address"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding Ipv6Display}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                    </Grid>

                    <!-- Separator -->
                    <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                      <TextBlock Grid.Column="0" Text="Total sent"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding TotalSentDisplay}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,0">
                      <TextBlock Grid.Column="0" Text="Total received"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding TotalRecvDisplay}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>
                  </StackPanel>
                </Border>

              </Grid>

            </StackPanel>
          </ScrollViewer>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════════════════
             GPU DETAIL PANEL
             ════════════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="vm:GpuDeviceViewModel">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="20">

              <!-- Title -->
              <TextBlock Text="{Binding DeviceName}" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>

              <!-- GPU utilization chart -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="GPU utilization"
                               FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="100% max · 60s"
                               FontSize="9" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                  </Grid>
                  <lvc:CartesianChart Series="{Binding HistorySeries}"
                                       XAxes="{Binding HistoryXAxes}" YAxes="{Binding HistoryYAxes}"
                                       Height="150" Background="Transparent"
                                       AnimationsSpeed="0:0:0.3" EasingFunction="{x:Null}"/>
                </StackPanel>
              </Border>

              <!-- Top stats row -->
              <Grid ColumnDefinitions="*,*,*,*">
                <Border Grid.Column="0" Padding="10" Margin="0,0,4,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UsagePercent, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F1}%'}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource ColorWarningBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="GPU" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="10" Margin="2,0,2,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center">
                      <Run Text="{Binding DedicatedUsedGb, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F1}'}"/>
                      <Run Text="/" FontSize="{DynamicResource NxFont10}"/>
                      <Run Text="{Binding DedicatedTotalGb, StringFormat='{}{0:F0}'}"/>
                      <Run Text=" GB" FontSize="{DynamicResource NxFont10}"/>
                    </TextBlock>
                    <TextBlock Text="Dedicated" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="10" Margin="2,0,2,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding SharedUsedGb, StringFormat='{}{0:F1} GB'}" FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Shared" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="3" Padding="10" Margin="4,0,0,0"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerMD}">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TempC, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F0}°C'}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource ColorWarningBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Temp" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Engine Utilization card -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="0">
                  <TextBlock Text="Engine Utilization" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                  <Grid ColumnDefinitions="60,*,50" RowDefinitions="Auto,Auto,Auto,Auto">
                    <!-- 3D -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="3D" FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Row="0" Grid.Column="1" Value="{Binding Engine3DPercent}"
                                 Minimum="0" Maximum="100" Height="6" Margin="0,0,8,8" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Engine3DPercent, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F0}%'}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right" Margin="0,0,0,8" VerticalAlignment="Center"/>

                    <!-- Copy -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Copy" FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Row="1" Grid.Column="1" Value="{Binding EngineCopyPercent}"
                                 Minimum="0" Maximum="100" Height="6" Margin="0,0,8,8" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding EngineCopyPercent, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F0}%'}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right" Margin="0,0,0,8" VerticalAlignment="Center"/>

                    <!-- Decode -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Decode" FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Row="2" Grid.Column="1" Value="{Binding EngineDecodePercent}"
                                 Minimum="0" Maximum="100" Height="6" Margin="0,0,8,8" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding EngineDecodePercent, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F0}%'}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right" Margin="0,0,0,8" VerticalAlignment="Center"/>

                    <!-- Encode -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Encode" FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,0" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Row="3" Grid.Column="1" Value="{Binding EngineEncodePercent}"
                                 Minimum="0" Maximum="100" Height="6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding EngineEncodePercent, Converter={StaticResource MacOsNa}, ConverterParameter='{}{0:F0}%'}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- GPU Info card -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="0">
                  <TextBlock Text="GPU Info" FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Driver version"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding DriverVersion}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6"
                        IsVisible="{Binding DirectXVersion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Grid.Column="0" Text="DirectX version"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding DirectXVersion}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                  </Grid>

                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Physical location"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding PhysicalLocation}"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                  </Grid>

                  <!-- Separator -->
                  <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>

                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Dedicated GPU memory"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right">
                      <Run Text="{Binding DedicatedTotalGb, StringFormat='{}{0:F1}'}"/>
                      <Run Text=" GB"/>
                    </TextBlock>
                  </Grid>

                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,0">
                    <TextBlock Grid.Column="0" Text="Shared GPU memory"
                               FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right">
                      <Run Text="{Binding SharedTotalGb, StringFormat='{}{0:F1}'}"/>
                      <Run Text=" GB"/>
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>
        </DataTemplate>

      </TransitioningContentControl.DataTemplates>
    </TransitioningContentControl>

  </Grid>
</UserControl>
