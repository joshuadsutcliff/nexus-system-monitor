<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:views="using:NexusMonitor.UI.Views"
             xmlns:controls="using:NexusMonitor.UI.Controls"
             x:Class="NexusMonitor.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             x:CompileBindings="False">

  <Panel>
  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0" Text="System Health"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <!-- View-mode: single pencil toggle (page engine only); hidden while editing -->
          <StackPanel Orientation="Horizontal" IsVisible="{Binding UsePageEngine}">
            <Button Classes="nx-btn-ghost"
                    IsVisible="{Binding !IsEditMode}"
                    Command="{Binding EnterEditModeCommand}"
                    ToolTip.Tip="Edit layout">
              <TextBlock Text="✏" FontSize="{DynamicResource NxFont14}" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Button>
          </StackPanel>
          <!-- Edit-mode toolbar -->
          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsEditMode}">
            <Button Classes="nx-btn" Command="{Binding OpenGalleryCommand}">
              <TextBlock Text="＋ Add widget" FontSize="{DynamicResource NxFont12}"/>
            </Button>
            <Button Classes="nx-btn" Command="{Binding TidyLayoutCommand}">
              <TextBlock Text="Tidy" FontSize="{DynamicResource NxFont12}"/>
            </Button>
            <Button Classes="nx-btn" Command="{Binding UndoEditCommand}" IsEnabled="{Binding CanUndoEdit}">
              <TextBlock Text="Undo" FontSize="{DynamicResource NxFont12}"/>
            </Button>
            <Button Classes="nx-btn" Command="{Binding CancelEditCommand}">
              <TextBlock Text="Cancel" FontSize="{DynamicResource NxFont12}"/>
            </Button>
            <Button Classes="nx-btn-accent" Command="{Binding SaveEditCommand}">
              <TextBlock Text="Save" FontSize="{DynamicResource NxFont12}"/>
            </Button>
          </StackPanel>
          <!-- Data-stale indicator — visible only when the health pipeline has stalled -->
          <Border IsVisible="{Binding IsDataStale}"
                  Padding="8,3"
                  CornerRadius="{StaticResource CornerSM}"
                  Background="#33FF9F0A"
                  BorderBrush="#FF9F0A"
                  BorderThickness="1"
                  VerticalAlignment="Center">
            <TextBlock Text="Data stale"
                       FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                       Foreground="#FF9F0A"
                       VerticalAlignment="Center"/>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <Grid>
      <!-- ══ Content ══════════════════════════════════════════════════════════ -->
      <ScrollViewer IsVisible="{Binding !UsePageEngine}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14" Margin="16">

          <!-- ── Overall Health Ring Card ─────────────────────────────────── -->
          <Border Padding="24,20"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <Grid ColumnDefinitions="Auto,*">

              <!-- Health score panel -->
              <Border Grid.Column="0" Width="120" Height="120" Margin="0,0,24,0"
                      CornerRadius="60"
                      BorderBrush="{Binding HealthRingBrush}"
                      BorderThickness="6"
                      Background="{DynamicResource BgPrimaryBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding OverallScore, StringFormat={}{0:F0}}"
                             FontSize="{DynamicResource NxFont28}" FontWeight="Bold"
                             Foreground="{Binding HealthRingBrush}"
                             HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding TrendArrow}"
                             FontSize="{DynamicResource NxFont16}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>

              <!-- Health label + description -->
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="{Binding OverallLabel}"
                           FontSize="{DynamicResource NxFont24}" FontWeight="Bold"
                           Foreground="{Binding HealthRingBrush}"/>
                <TextBlock Text="{Binding OverallDescription}"
                           FontSize="{DynamicResource NxFont14}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding AutomationStatus}"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- ── Subsystem Cards (2×2 grid) ──────────────────────────────── -->
          <Grid ColumnDefinitions="*,10,*" RowDefinitions="Auto,10,Auto">

            <!-- CPU Card -->
            <Border Grid.Row="0" Grid.Column="0"
                    Padding="16"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerMD}">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding CpuCard.Icon}"
                             FontFamily="{StaticResource NexusIcons}"
                             FontSize="{DynamicResource NxFont16}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding CpuCard.Name}"
                             FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding CpuCard.TrendArrow}"
                             FontSize="{DynamicResource NxFont13}"
                             Foreground="{Binding CpuCard.LevelBrush}"
                             VerticalAlignment="Center"
                             Margin="4,0,0,0"/>
                </StackPanel>
                <TextBlock Text="{Binding CpuCard.Level}"
                           FontSize="{DynamicResource NxFont20}" FontWeight="Bold"
                           Foreground="{Binding CpuCard.LevelBrush}"/>
                <TextBlock Text="{Binding CpuCard.Summary}"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Memory Card -->
            <Border Grid.Row="0" Grid.Column="2"
                    Padding="16"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerMD}">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding MemoryCard.Icon}"
                             FontFamily="{StaticResource NexusIcons}"
                             FontSize="{DynamicResource NxFont16}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding MemoryCard.Name}"
                             FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding MemoryCard.TrendArrow}"
                             FontSize="{DynamicResource NxFont13}"
                             Foreground="{Binding MemoryCard.LevelBrush}"
                             VerticalAlignment="Center"
                             Margin="4,0,0,0"/>
                </StackPanel>
                <TextBlock Text="{Binding MemoryCard.Level}"
                           FontSize="{DynamicResource NxFont20}" FontWeight="Bold"
                           Foreground="{Binding MemoryCard.LevelBrush}"/>
                <TextBlock Text="{Binding MemoryCard.Summary}"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Disk Card -->
            <Border Grid.Row="2" Grid.Column="0"
                    Padding="16"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerMD}">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding DiskCard.Icon}"
                             FontFamily="{StaticResource NexusIcons}"
                             FontSize="{DynamicResource NxFont16}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding DiskCard.Name}"
                             FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding DiskCard.TrendArrow}"
                             FontSize="{DynamicResource NxFont13}"
                             Foreground="{Binding DiskCard.LevelBrush}"
                             VerticalAlignment="Center"
                             Margin="4,0,0,0"/>
                </StackPanel>
                <TextBlock Text="{Binding DiskCard.Level}"
                           FontSize="{DynamicResource NxFont20}" FontWeight="Bold"
                           Foreground="{Binding DiskCard.LevelBrush}"/>
                <TextBlock Text="{Binding DiskCard.Summary}"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- GPU Card -->
            <Border Grid.Row="2" Grid.Column="2"
                    Padding="16"
                    Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerMD}">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding GpuCard.Icon}"
                             FontFamily="{StaticResource NexusIcons}"
                             FontSize="{DynamicResource NxFont16}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding GpuCard.Name}"
                             FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding GpuCard.TrendArrow}"
                             FontSize="{DynamicResource NxFont13}"
                             Foreground="{Binding GpuCard.LevelBrush}"
                             VerticalAlignment="Center"
                             Margin="4,0,0,0"/>
                </StackPanel>
                <TextBlock Text="{Binding GpuCard.Level}"
                           FontSize="{DynamicResource NxFont20}" FontWeight="Bold"
                           Foreground="{Binding GpuCard.LevelBrush}"/>
                <TextBlock Text="{Binding GpuCard.Summary}"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

          </Grid>

          <!-- ── Bottleneck Analysis Card ─────────────────────────────────── -->
          <Border Padding="20,16"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}"
                  DataContext="{Binding BottleneckCard}">
            <StackPanel Spacing="12">

              <!-- Header row -->
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="{Binding BottleneckIcon}"
                             FontSize="{DynamicResource NxFont20}" VerticalAlignment="Center"/>
                  <StackPanel Spacing="2">
                    <TextBlock Text="Performance Bottleneck Analysis"
                               FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding !IsIdle}">
                      <TextBlock Text="{Binding WorkloadLabel}"
                                 FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                                 Foreground="{DynamicResource AccentBrush}"/>
                      <TextBlock Text="{Binding WorkloadProcess}"
                                 FontSize="{DynamicResource NxFont11}"
                                 Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Run Analysis"
                        Command="{Binding $parent[UserControl].DataContext.RunAnalysisCommand}"
                        FontSize="{DynamicResource NxFont11}"
                        Padding="12,5"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        CornerRadius="{StaticResource CornerSM}"
                        VerticalAlignment="Center"
                        Cursor="Hand"/>
              </Grid>

              <!-- Verdict headline -->
              <TextBlock Text="{Binding Headline}"
                         FontSize="{DynamicResource NxFont15}" FontWeight="Bold"
                         Foreground="{Binding SeverityBrush}"
                         TextWrapping="Wrap"/>

              <!-- Explanation -->
              <TextBlock Text="{Binding Explanation}"
                         FontSize="{DynamicResource NxFont12}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap"/>

              <!-- Utilisation bars -->
              <StackPanel Spacing="6">
                <TextBlock Text="Current Utilisation"
                           FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>

                <!-- CPU bar -->
                <Grid ColumnDefinitions="55,*,45">
                  <TextBlock Grid.Column="0" Text="CPU"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <Border Grid.Column="1" Height="6" CornerRadius="3"
                          Background="{DynamicResource BorderSubtleBrush}"
                          ClipToBounds="True">
                    <ProgressBar Value="{Binding CpuPercent}"
                                 Minimum="0" Maximum="100"
                                 Height="6"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AccentBrush}"
                                 CornerRadius="3"/>
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding CpuPercent, StringFormat={}{0:F0}%}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- GPU bar -->
                <Grid ColumnDefinitions="55,*,45">
                  <TextBlock Grid.Column="0" Text="GPU"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <Border Grid.Column="1" Height="6" CornerRadius="3"
                          Background="{DynamicResource BorderSubtleBrush}"
                          ClipToBounds="True">
                    <ProgressBar Value="{Binding GpuPercent}"
                                 Minimum="0" Maximum="100"
                                 Height="6"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AccentBrush}"
                                 CornerRadius="3"/>
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding GpuPercent, StringFormat={}{0:F0}%}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- VRAM bar -->
                <Grid ColumnDefinitions="55,*,45">
                  <TextBlock Grid.Column="0" Text="VRAM"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <Border Grid.Column="1" Height="6" CornerRadius="3"
                          Background="{DynamicResource BorderSubtleBrush}"
                          ClipToBounds="True">
                    <ProgressBar Value="{Binding VramPercent}"
                                 Minimum="0" Maximum="100"
                                 Height="6"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AccentBrush}"
                                 CornerRadius="3"/>
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding VramPercent, StringFormat={}{0:F0}%}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- RAM bar -->
                <Grid ColumnDefinitions="55,*,45">
                  <TextBlock Grid.Column="0" Text="RAM"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <Border Grid.Column="1" Height="6" CornerRadius="3"
                          Background="{DynamicResource BorderSubtleBrush}"
                          ClipToBounds="True">
                    <ProgressBar Value="{Binding MemPercent}"
                                 Minimum="0" Maximum="100"
                                 Height="6"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AccentBrush}"
                                 CornerRadius="3"/>
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding MemPercent, StringFormat={}{0:F0}%}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Temperatures + thermal throttle warning -->
                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                  <TextBlock Text="{Binding CpuTempLabel, StringFormat=CPU temp: {0}}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Text="{Binding GpuTempLabel, StringFormat=GPU temp: {0}}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>

                <Border Padding="10,8" CornerRadius="{StaticResource CornerSM}"
                        Background="{DynamicResource DangerBgBrush}"
                        IsVisible="{Binding ShowThermalWarning}">
                  <TextBlock Text="⚠ Thermal throttling detected — your hardware is running slower than it should due to heat."
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource DangerTextBrush}"
                             TextWrapping="Wrap"/>
                </Border>

                <!-- CPU temp unavailable — HVCI info + fix button -->
                <Border Padding="10,8" CornerRadius="{StaticResource CornerSM}"
                        Background="{DynamicResource BgPrimaryBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        IsVisible="{Binding ShowCpuTempHint}"
                        Margin="0,4,0,0">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding CpuTempHintText}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <Button Content="Disable Memory Integrity"
                            Command="{Binding DisableMemoryIntegrityCommand}"
                            FontSize="{DynamicResource NxFont11}"
                            Padding="12,5"
                            Background="Transparent"
                            Foreground="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerSM}"
                            Cursor="Hand"
                            HorizontalAlignment="Left"/>
                  </StackPanel>
                </Border>
              </StackPanel>

              <!-- Upgrade / tuning advice (shown only when relevant) -->
              <Border Padding="12,10" CornerRadius="{StaticResource CornerSM}"
                      Background="{DynamicResource BgPrimaryBrush}"
                      BorderBrush="{DynamicResource AccentBrush}"
                      BorderThickness="1"
                      IsVisible="{Binding HasUpgradeAdvice}">
                <StackPanel Spacing="4">
                  <TextBlock Text="💡 Upgrade / Tuning Advice"
                             FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentBrush}"/>
                  <TextBlock Text="{Binding UpgradeAdvice}"
                             FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

            </StackPanel>
          </Border>

          <!-- ── Top 5 Impact Consumers ───────────────────────────────────── -->
          <Border Padding="20,16"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="Top Resource Consumers"
                             FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock Text="Apps having the biggest impact on your system"
                             FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="↻ Refresh"
                        Command="{Binding RefreshConsumersCommand}"
                        FontSize="{DynamicResource NxFont11}"
                        Padding="12,5"
                        Background="Transparent"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CornerSM}"
                        VerticalAlignment="Center"
                        Cursor="Hand"/>
              </Grid>

              <ItemsControl ItemsSource="{Binding TopConsumers}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ProcessImpactViewModel">
                    <Grid ColumnDefinitions="*,60,60" Margin="0,4,0,0">
                      <!-- Name + bar -->
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="{DynamicResource NxFont13}" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <!-- Impact bar -->
                        <Border Height="4" CornerRadius="2"
                                Background="{DynamicResource BorderSubtleBrush}"
                                ClipToBounds="True">
                          <ProgressBar Value="{Binding BarWidth}"
                                       Minimum="0" Maximum="100"
                                       Height="4"
                                       Background="Transparent"
                                       Foreground="{DynamicResource AccentBrush}"
                                       CornerRadius="2"/>
                        </Border>
                      </StackPanel>
                      <!-- CPU% -->
                      <TextBlock Grid.Column="1"
                                 Text="{Binding CpuPercent, StringFormat={}{0:F1}%}"
                                 FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"/>
                      <!-- Memory -->
                      <TextBlock Grid.Column="2"
                                 Text="{Binding MemoryLabel}"
                                 FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- ── Recommendations ──────────────────────────────────────────── -->
          <Border Padding="20,16"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="10">
              <TextBlock Text="Recommendations"
                         FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>

              <ItemsControl ItemsSource="{Binding Recommendations}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:RecommendationViewModel">
                    <Border Padding="12,10" Margin="0,3,0,0"
                            Background="{DynamicResource BgPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerSM}">
                      <StackPanel Orientation="Horizontal" Spacing="12">
                        <!-- Icon -->
                        <TextBlock Text="{Binding Icon}"
                                   FontFamily="{StaticResource NexusIcons}"
                                   FontSize="{DynamicResource NxFont18}"
                                   Foreground="{Binding IconBrush}"
                                   VerticalAlignment="Top"/>
                        <!-- Text -->
                        <StackPanel Spacing="3">
                          <TextBlock Text="{Binding Title}"
                                     FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                          <TextBlock Text="{Binding Body}"
                                     FontSize="{DynamicResource NxFont12}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- ── Resource Predictions ────────────────────────────────────────────── -->
          <Border Padding="20,16"
                  IsVisible="{Binding HasPredictions}"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="10">
              <TextBlock Text="Resource Predictions"
                         FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Text="Based on recent trends, these resources may need attention."
                         FontSize="{DynamicResource NxFont12}"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>

              <ItemsControl ItemsSource="{Binding PredictionCards}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PredictionCardViewModel">
                    <Border Padding="12,10" Margin="0,3,0,0"
                            IsVisible="{Binding !IsDismissed}"
                            Background="{DynamicResource BgPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerSM}">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding SeverityLabel}"
                                       FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="{Binding Resource}"
                                       FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                          </StackPanel>
                          <TextBlock Text="{Binding Description}"
                                     FontSize="{DynamicResource NxFont12}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     TextWrapping="Wrap"/>
                          <TextBlock Text="{Binding DepletionLabel}"
                                     FontSize="{DynamicResource NxFont11}"
                                     Foreground="{DynamicResource TextTertiaryBrush}"
                                     IsVisible="{Binding DepletionLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="&#x2715;"
                                Command="{Binding DismissCommand}"
                                FontSize="{DynamicResource NxFont12}"
                                VerticalAlignment="Top"
                                Padding="6,4"
                                Background="Transparent"
                                Foreground="{DynamicResource TextTertiaryBrush}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- ── Health Trends ────────────────────────────────────────────────── -->
          <views:HealthTrendsView DataContext="{Binding HealthTrendsViewModel}"/>

          <!-- Bottom spacer so last card isn't flush with window edge -->
          <Border Height="16"/>

        </StackPanel>
      </ScrollViewer>

      <!-- ══ Content (page engine) ═══════════════════════════════════════════ -->
      <ScrollViewer IsVisible="{Binding UsePageEngine}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Padding="20,0,20,20">
        <Panel>
          <controls:PageHostControl Page="{Binding EnginePage}"/>
          <controls:EditAdornerControl x:Name="EditAdorner"
                                       Page="{Binding EnginePage}"
                                       IsActive="{Binding IsEditMode}"/>
        </Panel>
      </ScrollViewer>
    </Grid>

  </DockPanel>

  <!-- ═ Add-widget gallery overlay ═══════════════════════════════════════ -->
  <!-- Spans the whole view. Visibility is driven by DashboardViewModel.IsGalleryOpen. -->
  <controls:WidgetGalleryControl/>

  </Panel>

</UserControl>
