<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:controls="using:NexusMonitor.UI.Controls"
             x:Class="NexusMonitor.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             x:CompileBindings="False">

  <Panel>
  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0" Text="System Health"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <!-- View-mode: single pencil toggle; hidden while editing -->
          <StackPanel Orientation="Horizontal">
            <Button Classes="nx-btn-ghost"
                    IsVisible="{Binding !IsEditMode}"
                    IsEnabled="{Binding CanEditLayout}"
                    Command="{Binding EnterEditModeCommand}"
                    ToolTip.Tip="Edit layout">
              <TextBlock Text="✏" FontSize="{DynamicResource NxFont14}" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Button>
          </StackPanel>
          <!-- Edit-mode toolbar. Phase 8 Task 3 gate fix: fades in when entering edit mode — see
               DashboardView.axaml.cs's OnEditToolbarPropertyChanged, gated on
               DashboardViewModel.EditChromeMotionEnabled (MotionEffect.EditChrome). Fade-in only:
               IsVisible flips straight to false on exit, collapsing the toolbar before any
               fade-out transition could play — same trade-off CommandPaletteControl and
               WidgetGalleryControl already accept for their own overlays. -->
          <StackPanel x:Name="EditToolbar" Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsEditMode}">
            <StackPanel.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="{DynamicResource MotionBase}"/>
              </Transitions>
            </StackPanel.Transitions>
            <Button Classes="nx-btn" Command="{Binding OpenGalleryCommand}">
              <TextBlock Text="＋ Add widget" FontSize="{DynamicResource NxFont12}"/>
            </Button>
            <Button Classes="nx-btn" Command="{Binding TidyLayoutCommand}">
              <TextBlock Text="Tidy" FontSize="{DynamicResource NxFont12}"/>
            </Button>
            <Button Classes="nx-btn" Command="{Binding UndoEditCommand}" IsEnabled="{Binding CanUndoEdit}">
              <TextBlock Text="Undo" FontSize="{DynamicResource NxFont12}"/>
            </Button>
            <Button Classes="nx-btn" Command="{Binding CancelEditCommand}">
              <TextBlock Text="Cancel" FontSize="{DynamicResource NxFont12}"/>
            </Button>
            <Button Classes="nx-btn-accent" Command="{Binding SaveEditCommand}">
              <TextBlock Text="Save" FontSize="{DynamicResource NxFont12}"/>
            </Button>
          </StackPanel>
          <!-- Data-stale indicator — visible only when the health pipeline has stalled -->
          <Border IsVisible="{Binding IsDataStale}"
                  Padding="8,3"
                  CornerRadius="{StaticResource CornerSM}"
                  Background="#33FF9F0A"
                  BorderBrush="#FF9F0A"
                  BorderThickness="1"
                  VerticalAlignment="Center">
            <TextBlock Text="Data stale"
                       FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                       Foreground="#FF9F0A"
                       VerticalAlignment="Center"/>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <Grid>
      <!-- ══ Content — page engine (Phase 7: the only dashboard) ════════════════ -->
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Padding="20,0,20,20">
        <Panel>
          <controls:PageHostControl Page="{Binding EnginePage}"
                                     IsEditMode="{Binding IsEditMode}"
                                     HoverLiftEnabled="{Binding HoverEffectsEnabled}"/>
          <controls:EditAdornerControl x:Name="EditAdorner"
                                       Page="{Binding EnginePage}"
                                       IsActive="{Binding IsEditMode}"/>
        </Panel>
      </ScrollViewer>
    </Grid>

  </DockPanel>

  <!-- ═ Add-widget gallery overlay ═══════════════════════════════════════ -->
  <!-- Spans the whole view. Visibility is driven by DashboardViewModel.IsGalleryOpen. -->
  <controls:WidgetGalleryControl/>

  </Panel>

</UserControl>
