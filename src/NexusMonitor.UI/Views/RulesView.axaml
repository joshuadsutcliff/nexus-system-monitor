<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.RulesView"
             x:DataType="vm:RulesViewModel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Process Rules"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <!-- Search box -->
        <Border DockPanel.Dock="Right"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerSM}"
                Padding="0" Margin="10,0,0,0"
                VerticalAlignment="Center" Width="200">
          <TextBox Name="SearchBox"
                   Text="{Binding SearchText}"
                   Watermark="Search rules…"
                   BorderThickness="0"
                   Background="Transparent"
                   FontSize="{DynamicResource NxFont12}"
                   Padding="8,5"/>
        </Border>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button Classes="nx-btn"
                  Command="{Binding AddRuleCommand}"
                  ToolTip.Tip="Create a new process rule">
            <TextBlock Text="＋ Add Rule" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding EditRuleCommand}"
                  IsEnabled="{Binding SelectedRule, Converter={x:Static ObjectConverters.IsNotNull}}"
                  ToolTip.Tip="Edit the selected rule">
            <TextBlock Text="✏ Edit" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding DeleteRuleCommand}"
                  IsEnabled="{Binding SelectedRule, Converter={x:Static ObjectConverters.IsNotNull}}"
                  ToolTip.Tip="Delete the selected rule">
            <TextBlock Text="🗑 Delete" FontSize="{DynamicResource NxFont12}"/>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══ Main content ═════════════════════════════════════════════════════ -->
    <Grid ColumnDefinitions="*">

      <!-- Rules list + empty state -->
      <Grid IsVisible="{Binding IsEditorVisible, Converter={x:Static BoolConverters.Not}}">
        <DockPanel>

          <!-- Intro blurb -->
          <Border DockPanel.Dock="Top"
                  Padding="16,10"
                  Background="{DynamicResource BgSecondaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1">
            <TextBlock Text="Rules automatically apply priority, affinity, I/O priority, and other settings to matching processes when they launch. Watchdog conditions can act when a process exceeds a threshold."
                       FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </Border>

          <!-- Empty state -->
          <Border DockPanel.Dock="Top"
                  Padding="24,48"
                  IsVisible="{Binding !HasFilteredRules}">
            <StackPanel HorizontalAlignment="Center" Spacing="10">
              <TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Text="No rules configured"
                         FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Click + Add Rule to create your first process rule."
                         FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextTertiaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Rule list -->
          <ScrollViewer>
            <StackPanel Spacing="6" Margin="16">
              <ItemsControl ItemsSource="{Binding FilteredRules}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="14,12"
                            Margin="0,0,0,1"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerMD}"
                            Cursor="Hand"
                            PointerPressed="OnRuleBorderPointerPressed">
                      <Border.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="Edit Rule"
                                    Command="{Binding DataContext.EditRuleCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                          <MenuItem Header="Toggle Enabled"
                                    Command="{Binding DataContext.ToggleEnabledCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                          <Separator/>
                          <MenuItem Header="Delete Rule"
                                    Command="{Binding DataContext.DeleteRuleCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </ContextMenu>
                      </Border.ContextMenu>
                      <Border.Styles>
                        <Style Selector="Border:pointerover">
                          <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                        </Style>
                      </Border.Styles>
                      <DockPanel>

                        <!-- Enable/disable dot indicator -->
                        <Border DockPanel.Dock="Left"
                                Width="6" Height="6"
                                CornerRadius="3"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                          <Border.Background>
                            <SolidColorBrush Color="{Binding IsEnabled,
                                             Converter={x:Static BoolConverters.Not},
                                             ConverterParameter=#636366}"/>
                          </Border.Background>
                        </Border>

                        <!-- Main info -->
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center"
                                    Spacing="2" Width="200">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding ProcessNamePattern}"
                                     FontSize="{DynamicResource NxFont11}"
                                     FontFamily="Consolas,Courier New,monospace"
                                     Foreground="{DynamicResource AccentBlueBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Actions summary -->
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding Summary}"
                                   FontSize="{DynamicResource NxFont11}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="12,0"/>

                        <!-- Edit button -->
                        <Button DockPanel.Dock="Right"
                                Classes="nx-btn"
                                Padding="8,4"
                                FontSize="{DynamicResource NxFont11}"
                                Content="Edit"
                                VerticalAlignment="Center"
                                Command="{Binding DataContext.EditRuleCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Click="OnRuleRowClick"/>

                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

        </DockPanel>
      </Grid>

      <!-- ══ Editor panel (shown when IsEditorVisible) ═══════════════════ -->
      <Border IsVisible="{Binding IsEditorVisible}"
              Background="{DynamicResource BgBaseBrush}">
        <DockPanel>

          <!-- Editor header -->
          <Border DockPanel.Dock="Top"
                  Padding="16,10"
                  Background="{DynamicResource BgSecondaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left"
                         Text="{Binding EditorTitle}"
                         FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
                <Button Classes="nx-btn"
                        Command="{Binding SaveEditCommand}"
                        ToolTip.Tip="Save this rule">
                  <TextBlock Text="💾 Save" FontSize="{DynamicResource NxFont12}"/>
                </Button>
                <Button Classes="nx-btn"
                        Command="{Binding CancelEditCommand}">
                  <TextBlock Text="Cancel" FontSize="{DynamicResource NxFont12}"/>
                </Button>
              </StackPanel>
            </DockPanel>
          </Border>

          <!-- Validation error -->
          <Border DockPanel.Dock="Top"
                  Padding="16,8"
                  Background="{StaticResource ProcSuspiciousBgBrush}"
                  IsVisible="{Binding HasValidationError}">
            <TextBlock Text="{Binding ValidationError}"
                       FontSize="{DynamicResource NxFont12}" Foreground="{StaticResource ColorDangerBrush}"/>
          </Border>

          <ScrollViewer>
            <StackPanel Spacing="16" MaxWidth="740" Margin="16">

              <!-- ── Identity ──────────────────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <TextBlock Text="IDENTITY" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Rule Name" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditName}" Watermark="My Rule"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="Process Name Pattern *" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditPattern}"
                               FontFamily="Consolas,Courier New,monospace"
                               Watermark="chrome  or  *helper*"/>
                      <TextBlock Text="Supports * wildcard. Case-insensitive. No .exe needed."
                                 FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                  </Grid>
                  <!-- Group targeting -->
                  <StackPanel Spacing="4">
                    <TextBlock Text="Target Group (optional)" FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding AvailableGroupNames}"
                              SelectedItem="{Binding EditGroupName}"
                              Width="200" HorizontalAlignment="Left"/>
                    <TextBlock Text="Rule will match all processes in this group"
                               FontSize="11" Opacity="0.7" Margin="0,2,0,8"/>
                  </StackPanel>

                  <WrapPanel Orientation="Horizontal">
                    <CheckBox Margin="0,0,12,4"
                              IsChecked="{Binding EditEnabled}"
                              Content="Rule is enabled"/>
                    <CheckBox Margin="0,0,12,4"
                              IsChecked="{Binding EditDisallowed}"
                              Content="Disallowed (terminate on launch)"
                              Foreground="{StaticResource ColorDangerBrush}"/>
                    <CheckBox Margin="0,0,12,4"
                              IsChecked="{Binding EditKeepRunning}"
                              Content="Keep running (restart on exit)"
                              Foreground="{StaticResource ColorSuccessBrush}"/>
                    <CheckBox Margin="0,0,12,4"
                              IsChecked="{Binding EditPreventSleep}"
                              Content="Prevent sleep while running"/>
                  </WrapPanel>

                  <!-- Max instances + CPU sets -->
                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Max Instances" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditMaxInstances}"
                               Watermark="(unlimited)"
                               FontFamily="Consolas,Courier New,monospace"/>
                      <TextBlock Text="Newest excess instances will be terminated."
                                 FontSize="{DynamicResource NxFont10}"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4"
                                IsVisible="{Binding Platform.SupportsCpuAffinity}">
                      <TextBlock Text="CPU Set IDs (comma-separated)" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditCpuSetIds}"
                               Watermark="e.g. 256,257,258"
                               FontFamily="Consolas,Courier New,monospace"/>
                      <TextBlock Text="Windows 10+ preferred-core hint (softer than affinity). Leave blank to use default."
                                 FontSize="{DynamicResource NxFont10}"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- ── Persistent Actions ──────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <StackPanel Spacing="2">
                    <TextBlock Text="PERSISTENT ACTIONS" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                               LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Text="Applied every time this process launches."
                               FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,14,*,14,*">
                    <!-- Priority -->
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="CPU Priority" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.PriorityOptions}"
                                SelectedIndex="{Binding EditPriorityIndex}"/>
                    </StackPanel>
                    <!-- I/O Priority -->
                    <StackPanel Grid.Column="2" Spacing="4"
                                IsVisible="{Binding Platform.SupportsIoPriority}">
                      <TextBlock Text="I/O Priority" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.IoPriorityOptions}"
                                SelectedIndex="{Binding EditIoPriorityIndex}"/>
                    </StackPanel>
                    <!-- Memory Priority -->
                    <StackPanel Grid.Column="4" Spacing="4"
                                IsVisible="{Binding Platform.SupportsMemoryPriority}">
                      <TextBlock Text="Memory Priority" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.MemPriorityOptions}"
                                SelectedIndex="{Binding EditMemPriorityIndex}"/>
                    </StackPanel>
                  </Grid>

                  <Grid ColumnDefinitions="*,14,*">
                    <!-- Efficiency Mode -->
                    <StackPanel Grid.Column="0" Spacing="4"
                                IsVisible="{Binding Platform.SupportsEfficiencyMode}">
                      <TextBlock Text="Efficiency Mode" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.EfficiencyOptions}"
                                SelectedIndex="{Binding EditEfficiencyIndex}"/>
                      <TextBlock Text="Reduces power and heat for background apps (Windows EcoQoS / macOS background QoS clamp)."
                                 FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                    <!-- CPU Affinity -->
                    <StackPanel Grid.Column="2" Spacing="4"
                                IsVisible="{Binding Platform.SupportsCpuAffinity}">
                      <TextBlock Text="CPU Affinity Mask (hex)" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBox Text="{Binding EditAffinityHex}"
                               FontFamily="Consolas,Courier New,monospace"
                               Watermark="e.g. 0xF  (first 4 cores)"/>
                      <TextBlock Text="Bitmask of allowed CPUs. 0xFF = all 8 cores. Leave blank to keep default."
                                 FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- ── Watchdog Condition ──────────────────────────────── -->
              <Border Padding="16"
                      Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerLG}">
                <StackPanel Spacing="12">
                  <StackPanel Spacing="2">
                    <TextBlock Text="WATCHDOG CONDITION" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                               LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Text="Action taken when the process exceeds a threshold for a sustained duration."
                               FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Trigger Condition" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.ConditionTypeOptions}"
                                SelectedIndex="{Binding EditConditionTypeIndex}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="Watchdog Action" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <ComboBox ItemsSource="{x:Static vm:RulesViewModel.WatchdogActionOptions}"
                                SelectedIndex="{Binding EditWatchdogActionIndex}"/>
                    </StackPanel>
                  </Grid>

                  <!-- ReduceAffinity parameter (shown only for that action) -->
                  <StackPanel IsVisible="{Binding IsReduceAffinitySelected}" Spacing="4">
                    <TextBlock Text="Reduce by N cores" FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox Text="{Binding EditReduceCoreCount}"
                             Watermark="1"
                             FontFamily="Consolas,Courier New,monospace"
                             Width="100" HorizontalAlignment="Left"/>
                    <TextBlock Text="How many cores to remove from affinity mask when condition fires."
                               FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               TextWrapping="Wrap"/>
                  </StackPanel>

                  <!-- Condition parameters (shown when condition != Always) -->
                  <Grid ColumnDefinitions="*,14,*,14,*"
                        IsVisible="{Binding IsConditionEnabled}">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="CPU Threshold (%)" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <Grid ColumnDefinitions="*,Auto">
                        <Slider Grid.Column="0" Minimum="1" Maximum="99"
                                Value="{Binding EditConditionCpuThreshold}"
                                IsEnabled="{Binding EditConditionTypeIndex,
                                            Converter={x:Static BoolConverters.Not},
                                            ConverterParameter=0}"/>
                        <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}"
                                   Text="{Binding EditConditionCpuThreshold, StringFormat='{}{0:F0}%'}"
                                   Foreground="{DynamicResource AccentBlueBrush}"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                      </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="RAM Threshold (MB)" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <Grid ColumnDefinitions="*,Auto">
                        <Slider Grid.Column="0" Minimum="64" Maximum="8192"
                                Value="{Binding EditConditionRamMb}"
                                IsEnabled="{Binding EditConditionTypeIndex,
                                            Converter={x:Static BoolConverters.Not},
                                            ConverterParameter=0}"/>
                        <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}"
                                   Text="{Binding EditConditionRamMb, StringFormat='{}{0:F0} MB'}"
                                   Foreground="{DynamicResource AccentBlueBrush}"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                      </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="4">
                      <TextBlock Text="Duration (seconds)" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <NumericUpDown Value="{Binding EditConditionDurationSecs}"
                                     Minimum="1" Maximum="3600" Increment="1"
                                     FormatString="0"/>
                    </StackPanel>
                  </Grid>

                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>

        </DockPanel>
      </Border>

    </Grid>

  </DockPanel>

</UserControl>
