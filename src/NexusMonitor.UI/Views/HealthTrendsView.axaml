<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="NexusMonitor.UI.Views.HealthTrendsView"
             x:DataType="vm:HealthTrendsViewModel"
             x:CompileBindings="False">
  <Border Classes="nx-widget-chrome"
          Padding="20,16"
          Background="{DynamicResource BgElevatedBrush}"
          BorderBrush="{DynamicResource GlassBorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource CornerLG}">
    <StackPanel Spacing="12">

      <!-- Header row with title and range selector -->
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="Health Score Trend"
                   FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding RangeOptions}"
                  SelectedItem="{Binding SelectedRange}"
                  MinWidth="80"/>
      </Grid>

      <!-- Summary text -->
      <TextBlock Text="{Binding SummaryText}"
                 FontSize="{DynamicResource NxFont12}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap"/>

      <!-- Chart (only shown when metrics enabled) -->
      <lvc:CartesianChart
          IsVisible="{Binding MetricsEnabled}"
          Series="{Binding HealthSeries}"
          XAxes="{Binding XAxes}"
          YAxes="{Binding YAxes}"
          Height="180"
          TooltipPosition="Hidden"/>

    </StackPanel>
  </Border>
</UserControl>
