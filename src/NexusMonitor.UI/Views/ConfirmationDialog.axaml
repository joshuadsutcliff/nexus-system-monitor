<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NexusMonitor.UI.Views.ConfirmationDialog"
        x:CompileBindings="False"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="BorderOnly"
        Background="{DynamicResource BgBaseBrush}">

  <Border Padding="20" Background="{DynamicResource BgPrimaryBrush}" CornerRadius="8">
    <StackPanel Spacing="14">

      <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>

      <TextBlock Text="{Binding Message}"
                 FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap"/>

      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
        <Button Classes="nx-btn" Content="Cancel" Width="80" Click="OnCancel"/>
        <Button Classes="nx-btn" Content="OK" Width="80" Click="OnOk"/>
      </StackPanel>

    </StackPanel>
  </Border>
</Window>
