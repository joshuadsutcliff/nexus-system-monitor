<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             x:Class="NexusMonitor.UI.Views.SystemInfoView"
             x:DataType="vm:SystemInfoViewModel">

  <UserControl.Resources>
    <conv:BytesToGigabytesConverter x:Key="GbConv"/>
  </UserControl.Resources>

  <Grid>

    <!-- Loading state -->
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12"
                IsVisible="{Binding IsLoading}">
      <ProgressBar IsIndeterminate="True" Width="200"/>
      <TextBlock Text="Reading hardware information&#x2026;"
                 FontSize="{DynamicResource NxFont13}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Error state -->
    <TextBlock Text="{Binding LoadError}"
               IsVisible="{Binding LoadError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
               FontSize="{DynamicResource NxFont13}"
               Foreground="{DynamicResource AccentBlueBrush}"
               VerticalAlignment="Center" HorizontalAlignment="Center"
               TextWrapping="Wrap" Margin="32"/>

    <!-- Content -->
    <ScrollViewer IsVisible="{Binding !IsLoading}" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="16" Margin="20,16,20,20">

        <!-- Page title -->
        <TextBlock Text="System Information"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,4"/>

        <!-- ═══════════════════════════════════════════════════════════════
             SYSTEM / OS SECTION
             ═══════════════════════════════════════════════════════════════ -->
        <Border Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                CornerRadius="14" Padding="20">
          <StackPanel Spacing="14">
            <!-- Section header with icon badge -->
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="28" Height="28" CornerRadius="8"
                      Background="{DynamicResource AccentBlueDimBrush}">
                <TextBlock Text="&#xE770;" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBlueBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="System" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Opacity="0.6"/>

            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,2,0,0">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Hostname" Margin="0,0,0,8"
                         FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Info.Hostname}" Margin="0,0,0,8"
                         FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBlueBrush}"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Operating System" Margin="0,0,0,8"
                         FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Info.OsName}" Margin="0,0,0,8"
                         FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Medium"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Build / Arch" Margin="0,0,0,8"
                         FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="{Binding Info.OsBuild}"
                           FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Border Padding="6,2" CornerRadius="4" Background="{DynamicResource AccentBlueDimBrush}">
                  <TextBlock Text="{Binding Info.OsArchitecture}"
                             FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             Foreground="{DynamicResource AccentBlueBrush}"/>
                </Border>
              </StackPanel>

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Uptime" Margin="0,0,0,8"
                         FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <!-- Backslashes must be doubled: the markup-extension parser consumes one level of
                   \-escaping, and TimeSpan custom formats REQUIRE the . and : literals escaped —
                   a single \ reaches string.Format as bare "d.hh:mm:ss", which throws
                   FormatException and rendered this field permanently blank. -->
              <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"
                         Text="{Binding Info.Uptime, StringFormat='{}{0:d\\.hh\\:mm\\:ss}'}"
                         FontSize="{DynamicResource NxFont12}" Foreground="{StaticResource ColorSuccessBrush}" FontWeight="Medium"/>

              <TextBlock Grid.Row="4" Grid.Column="0" Text="BIOS" Margin="0,0,0,8"
                         FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="{Binding Info.BiosVendor}"
                           FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Info.BiosVersion}"
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"/>
              </StackPanel>

              <TextBlock Grid.Row="5" Grid.Column="0" Text="Motherboard"
                         FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding Info.MotherboardManufacturer}"
                           FontSize="{DynamicResource NxFont12}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Medium"/>
                <TextBlock Text="{Binding Info.MotherboardModel}"
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             PROCESSOR SECTION
             ═══════════════════════════════════════════════════════════════ -->
        <Border Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                CornerRadius="14" Padding="20">
          <StackPanel Spacing="14">
            <!-- Section header with icon badge -->
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="28" Height="28" CornerRadius="8"
                      Background="#1A34C759">
                <TextBlock Text="&#xE950;" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource ColorSuccessBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="Processor" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Opacity="0.6"/>

            <!-- CPU Model name — prominent -->
            <TextBlock Text="{Binding Info.Cpu.Name}"
                       FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                       Foreground="{StaticResource ColorSuccessBrush}" TextWrapping="Wrap"/>

            <!-- Stat tiles row -->
            <Grid ColumnDefinitions="*,*,*" Margin="0,2,0,0">
              <Border Grid.Column="0" Padding="12" Margin="0,0,6,0"
                      Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Info.Cpu.PhysicalCores}" FontSize="22" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                  <TextBlock Text="Physical Cores" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Padding="12" Margin="3,0,3,0"
                      Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding Info.Cpu.LogicalCores}" FontSize="22" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                  <TextBlock Text="Logical Cores" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Padding="12" Margin="6,0,0,0"
                      Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding MaxClockDisplay}" ToolTip.Tip="{Binding MaxClockUnavailableTooltip}" FontSize="22" FontWeight="Bold"
                             Foreground="{StaticResource ColorWarningBrush}" HorizontalAlignment="Center"/>
                  <TextBlock Text="Max MHz" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
              </Border>
            </Grid>

            <!-- Detail grid -->
            <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
              <StackPanel Grid.Column="0" Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="L2 Cache" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding Info.Cpu.L2CacheKB, StringFormat='{}{0} KB'}"
                             FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="L3 Cache" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding L3CacheDisplay}" ToolTip.Tip="{Binding L3CacheUnavailableTooltip}"
                             FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Architecture" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding Info.Cpu.Architecture}"
                             FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Grid>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6" Margin="12,0,0,0">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Socket" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding SocketDisplay}" ToolTip.Tip="{Binding SocketUnavailableTooltip}"
                             FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Stepping" FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding Info.Cpu.Stepping}"
                             FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Grid>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             MEMORY SECTION
             ═══════════════════════════════════════════════════════════════ -->
        <Border Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                CornerRadius="14" Padding="20">
          <StackPanel Spacing="14">
            <!-- Section header -->
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="28" Height="28" CornerRadius="8"
                      Background="#1ABF5AF2">
                <TextBlock Text="&#xE964;" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource ProcDotNetBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Memory" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                           Foreground="{StaticResource ProcDotNetBrush}">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:F1} GB">
                      <Binding Path="Info.TotalRamBytes" Converter="{StaticResource GbConv}"/>
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>
            </StackPanel>

            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Opacity="0.6"/>

            <!-- Slot table header — hidden when there's no slot data to show (see below) -->
            <Grid ColumnDefinitions="80,70,70,70,110,*" Margin="0,2,0,0"
                  IsVisible="{Binding HasRamSlots}">
              <TextBlock Grid.Column="0" Text="Slot" FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.5"/>
              <TextBlock Grid.Column="1" Text="Size" FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.5"/>
              <TextBlock Grid.Column="2" Text="Speed" FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.5"/>
              <TextBlock Grid.Column="3" Text="Type" FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.5"/>
              <TextBlock Grid.Column="4" Text="Manufacturer" FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.5"/>
              <TextBlock Grid.Column="5" Text="Part Number" FontSize="{DynamicResource NxFont10}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}" LetterSpacing="0.5"/>
            </Grid>
            <ItemsControl ItemsSource="{Binding Info.RamSlots}" IsVisible="{Binding HasRamSlots}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="0,5" Margin="0,1" CornerRadius="6"
                          Background="{DynamicResource BgSecondaryBrush}">
                    <Grid ColumnDefinitions="80,70,70,70,110,*" Margin="4,0">
                      <TextBlock Grid.Column="0" Text="{Binding DeviceLocator}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                                 Foreground="{StaticResource ProcDotNetBrush}">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="{}{0:F0} GB">
                            <Binding Path="CapacityBytes" Converter="{StaticResource GbConv}"/>
                          </MultiBinding>
                        </TextBlock.Text>
                      </TextBlock>
                      <TextBlock Grid.Column="2" Text="{Binding SpeedMhz, StringFormat='{}{0} MHz'}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                      <TextBlock Grid.Column="3" Text="{Binding MemoryType}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource ColorInfoBrush}"/>
                      <TextBlock Grid.Column="4" Text="{Binding Manufacturer}"
                                 FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="5" Text="{Binding PartNumber}"
                                 FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Unified memory (e.g. Apple Silicon): no discrete slots to enumerate — collapse the
                 table to a single quiet line instead of headers over zero rows. -->
            <TextBlock Text="Unified memory — no discrete slots"
                       IsVisible="{Binding !HasRamSlots}"
                       FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
          </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             GPU(s) SECTION
             ═══════════════════════════════════════════════════════════════ -->
        <ItemsControl ItemsSource="{Binding Info.Gpus}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="14" Padding="20" Margin="0,0,0,12">
                <StackPanel Spacing="14">
                  <!-- Section header -->
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="28" Height="28" CornerRadius="8"
                            Background="#1AFF9F0A">
                      <TextBlock Text="&#xE7F4;" FontSize="14" FontWeight="Bold"
                                 Foreground="{StaticResource ColorWarningBrush}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Graphics" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                  </StackPanel>

                  <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Opacity="0.6"/>

                  <!-- GPU name -->
                  <TextBlock Text="{Binding Name}"
                             FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                             Foreground="{StaticResource ColorWarningBrush}" TextWrapping="Wrap"/>

                  <!-- Stat tiles -->
                  <Grid ColumnDefinitions="*,*,*" Margin="0,2,0,0">
                    <Border Grid.Column="0" Padding="10" Margin="0,0,6,0"
                            Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource ColorWarningBrush}" HorizontalAlignment="Center">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F1} GB">
                              <Binding Path="VramBytes" Converter="{StaticResource GbConv}"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="VRAM" FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="10" Margin="3,0,3,0"
                            Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding DriverVersion}" FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Driver" FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="10" Margin="6,0,0,0"
                            Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding VideoProcessor}" FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Processor" FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                  </Grid>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ═══════════════════════════════════════════════════════════════
             STORAGE SECTION
             ═══════════════════════════════════════════════════════════════ -->
        <ItemsControl ItemsSource="{Binding Info.Storage}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{DynamicResource BgElevatedBrush}"
                      BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                      CornerRadius="14" Padding="20" Margin="0,0,0,12">
                <StackPanel Spacing="14">
                  <!-- Section header -->
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="28" Height="28" CornerRadius="8"
                            Background="#1A64D2FF">
                      <TextBlock Text="&#xE958;" FontSize="14" FontWeight="Bold"
                                 Foreground="{StaticResource ColorInfoBrush}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Storage" FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                  </StackPanel>

                  <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Opacity="0.6"/>

                  <!-- Drive model name -->
                  <TextBlock Text="{Binding Model}"
                             FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                             Foreground="{StaticResource ColorInfoBrush}" TextWrapping="Wrap"/>

                  <!-- Stat tiles -->
                  <Grid ColumnDefinitions="*,*,*,*" Margin="0,2,0,0">
                    <Border Grid.Column="0" Padding="10" Margin="0,0,4,0"
                            Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:F0} GB">
                              <Binding Path="SizeBytes" Converter="{StaticResource GbConv}"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="Capacity" FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="10" Margin="2,0,2,0"
                            Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Interface}" FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                                   Foreground="{StaticResource ColorInfoBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Interface" FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="10" Margin="2,0,2,0"
                            Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MediaType}" FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Media" FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="10" Margin="4,0,0,0"
                            Background="{DynamicResource BgSecondaryBrush}" CornerRadius="10">
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Status}" FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                                   Foreground="{StaticResource ColorSuccessBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Status" FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                  </Grid>

                  <!-- Serial number -->
                  <TextBlock Text="{Binding SerialNumber, StringFormat='S/N: {0}'}"
                             FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
