<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.GamingModeView"
             x:DataType="vm:GamingModeViewModel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Gaming Mode"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button Classes="nx-btn"
                  Command="{Binding ClearLogCommand}"
                  ToolTip.Tip="Clear activity log">
            <TextBlock Text="Clear Log" FontSize="{DynamicResource NxFont12}"/>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══ Content ══════════════════════════════════════════════════════════ -->
    <ScrollViewer>
      <StackPanel Spacing="14" Margin="16">

        <!-- ── Master toggle card ────────────────────────────────────────── -->
        <Border Padding="20,16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}">
          <Grid ColumnDefinitions="*,Auto">

            <StackPanel Grid.Column="0" Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="&#x1F3AE;" FontSize="22" VerticalAlignment="Center"/>
                <TextBlock Text="Gaming Mode"
                           FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <!-- Status dot + label -->
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8"
                         Fill="{Binding StatusColor}"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusLabel}"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock TextWrapping="Wrap" MaxWidth="520"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         Margin="0,4,0,0"
                         Text="Switches to High Performance power plan and lowers all non-game background processes to Below Normal priority. Everything is restored when deactivated."
                         />
            </StackPanel>

            <!-- Toggle button -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                        HorizontalAlignment="Right" Margin="20,0,0,0">
              <ToggleButton Classes="nx-toggle" IsChecked="{Binding IsActive}"/>
            </StackPanel>

          </Grid>
        </Border>

        <!-- ── Status stat cards ─────────────────────────────────────────── -->
        <Grid ColumnDefinitions="*,8,*,8,*">

          <!-- Currently Throttled -->
          <Border Grid.Column="0"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="THROTTLED" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Text="{Binding ThrottledCount}"
                         FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorWarningBrush}"/>
              <TextBlock Text="background processes" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>

          <!-- Current Power Plan -->
          <Border Grid.Column="2"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="POWER PLAN" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Text="{Binding CurrentPlanName}"
                         FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="active plan" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>

          <!-- Mode status -->
          <Border Grid.Column="4"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="STATUS" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10"
                         Fill="{Binding StatusColor}"
                         VerticalAlignment="Center"/>
                <TextBlock FontSize="{DynamicResource NxFont14}" FontWeight="Bold"
                           Foreground="{Binding StatusColor}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsActive}"
                           Text="Active"/>
                <TextBlock FontSize="{DynamicResource NxFont14}" FontWeight="Bold"
                           Foreground="{Binding StatusColor}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsActive,
                             Converter={x:Static BoolConverters.Not}}"
                           Text="Inactive"/>
              </StackPanel>
              <TextBlock Text="gaming mode state" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>

        </Grid>

        <!-- ── Two-column config ─────────────────────────────────────────── -->
        <Grid ColumnDefinitions="*,14,*">

          <!-- Left: Game process + Exclusions -->
          <Border Grid.Column="0"
                  Padding="16"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="12">
              <TextBlock Text="GAME PROCESS" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <StackPanel Spacing="6">
                <TextBlock FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Process name of your game (will not be throttled):"/>
                <TextBox Text="{Binding GameProcessName}"
                         FontSize="{DynamicResource NxFont12}"
                         Padding="8,6"
                         Watermark="e.g. Cyberpunk2077"/>
              </StackPanel>

              <TextBlock Text="PROTECTED PROCESSES" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"
                         Margin="0,4,0,0"/>
              <StackPanel Spacing="6">
                <TextBlock FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Additional processes to protect from throttling (one per line):"/>
                <TextBox Text="{Binding ExclusionsText}"
                         AcceptsReturn="True"
                         MinHeight="100"
                         MaxHeight="160"
                         FontSize="{DynamicResource NxFont12}"
                         FontFamily="Consolas,Courier New,monospace"
                         Padding="8,6"
                         Watermark="discord&#x0A;streamlabs&#x0A;obs64"/>
                <TextBlock FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Text="Nexus Monitor itself and system kernel processes are always protected."/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Right: Power plan selector -->
          <Border Grid.Column="2"
                  Padding="16"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="12">
              <TextBlock Text="POWER PLAN" FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                         LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         Text="Gaming Mode automatically switches to High Performance (or Ultimate Performance if available). You can also set a plan manually here:"/>
              <TextBlock FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         IsVisible="{Binding !Platform.SupportsPowerPlan}"
                         Text="Power-plan switching isn't available on this platform; Gaming Mode still manages process priorities."/>

              <ComboBox ItemsSource="{Binding AvailablePlans}"
                        SelectedItem="{Binding SelectedPlan}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Ellipse Width="6" Height="6"
                               Fill="{DynamicResource AccentBlueBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsActive}"/>
                      <Ellipse Width="6" Height="6"
                               Fill="{StaticResource ProcSuspendedBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsActive,
                                 Converter={x:Static BoolConverters.Not}}"/>
                      <TextBlock Text="{Binding Name}" FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <Button Classes="nx-btn"
                      Command="{Binding SetPlanCommand}"
                      HorizontalAlignment="Left"
                      ToolTip.Tip="Apply the selected power plan immediately">
                <TextBlock Text="Apply Power Plan" FontSize="{DynamicResource NxFont12}"/>
              </Button>

              <!-- Power plan guide -->
              <Border Padding="10,8"
                      Background="{DynamicResource BgSecondaryBrush}"
                      CornerRadius="{StaticResource CornerMD}"
                      Margin="0,4,0,0">
                <StackPanel Spacing="6">
                  <TextBlock Text="Plan guide:" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <Grid ColumnDefinitions="130,*">
                    <TextBlock Grid.Column="0" Text="Power Saver" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="Reduces CPU clock to save power"
                               FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                               TextWrapping="Wrap"/>
                  </Grid>
                  <Grid ColumnDefinitions="130,*">
                    <TextBlock Grid.Column="0" Text="Balanced" FontSize="{DynamicResource NxFont10}"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="Default — balances performance and efficiency"
                               FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                               TextWrapping="Wrap"/>
                  </Grid>
                  <Grid ColumnDefinitions="130,*">
                    <TextBlock Grid.Column="0" Text="High Performance"
                               FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource AccentBlueBrush}"/>
                    <TextBlock Grid.Column="1" Text="Keeps CPU at full speed — best for gaming"
                               FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                               TextWrapping="Wrap"/>
                  </Grid>
                  <Grid ColumnDefinitions="130,*">
                    <TextBlock Grid.Column="0" Text="Ultimate Perf."
                               FontSize="{DynamicResource NxFont10}" Foreground="{StaticResource ColorSuccessBrush}"/>
                    <TextBlock Grid.Column="1" Text="Eliminates micro-latency — gaming and workstations"
                               FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                               TextWrapping="Wrap"/>
                  </Grid>
                </StackPanel>
              </Border>

            </StackPanel>
          </Border>

        </Grid>

        <!-- ── Activity log ──────────────────────────────────────────────── -->
        <Border Padding="0"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}"
                ClipToBounds="True">
          <StackPanel>

            <!-- Card header -->
            <Border Padding="16,12"
                    Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1">
              <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Activity Log"
                           FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusLog.Count, StringFormat='{}{0} entries'}"
                           FontSize="{DynamicResource NxFont11}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
              </DockPanel>
            </Border>

            <!-- Empty state -->
            <Border Padding="24,28"
                    IsVisible="{Binding StatusLog.Count,
                                        Converter={x:Static BoolConverters.Not}}">
              <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="&#x1F3AE;" FontSize="28" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                <TextBlock Text="No activity yet"
                           FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Activate Gaming Mode above and the log will populate."
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
              </StackPanel>
            </Border>

            <!-- Log entries -->
            <ItemsControl ItemsSource="{Binding StatusLog}"
                          MaxHeight="280">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="14,7"
                          BorderBrush="{DynamicResource BorderSubtleBrush}"
                          BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding}"
                               FontSize="{DynamicResource NxFont12}"
                               FontFamily="Consolas,Courier New,monospace"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>

</UserControl>
