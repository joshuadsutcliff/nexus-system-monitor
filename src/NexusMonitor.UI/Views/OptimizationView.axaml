<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.OptimizationView"
             x:DataType="vm:OptimizationViewModel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Optimization"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>

        <!-- Quick action buttons (right-aligned) -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button Classes="nx-btn"
                  Command="{Binding ThrottleAllCommand}"
                  ToolTip.Tip="Set every listed high-impact process to Below Normal priority">
            <TextBlock Text="&#x1F53D; Throttle High Impact" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding NormalizePrioritiesCommand}"
                  ToolTip.Tip="Reset all non-system processes to Normal priority">
            <TextBlock Text="&#x26A1; Normalize All" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn"
                  Command="{Binding MemoryReclaimAllCommand}"
                  ToolTip.Tip="Trim working sets of all processes to free up RAM immediately">
            <TextBlock Text="&#x1F9F9; Memory Reclaim All" FontSize="{DynamicResource NxFont12}"/>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══ Status bar ═══════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,6"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <TextBlock Text="{Binding LastAction}"
                 FontSize="{DynamicResource NxFont11}"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>
    </Border>

    <!-- ══ Content ══════════════════════════════════════════════════════════ -->
    <ScrollViewer>
      <StackPanel Spacing="14" Margin="16">

        <!-- ── Priority guide card ───────────────────────────────────────── -->
        <Border Padding="16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}">
          <StackPanel Spacing="10">
            <TextBlock Text="Priority Level Guide" FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="130,*">
                <TextBlock Grid.Column="0" Text="Real-Time / High" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="Reserved for system-critical tasks like audio drivers and input handling. Setting user apps here can cause system instability — avoid unless you know exactly what you're doing."
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"/>
              </Grid>
              <Grid ColumnDefinitions="130,*">
                <TextBlock Grid.Column="0" Text="Normal" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="The default priority for most applications. Processes share CPU time equally. This is the right choice for everyday apps like browsers, editors, and games."
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"/>
              </Grid>
              <Grid ColumnDefinitions="130,*">
                <TextBlock Grid.Column="0" Text="Below Normal" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                           Foreground="{DynamicResource AccentBlueBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="Ideal for background tasks that shouldn't compete with active work — software updaters, file indexers, backup utilities, and download managers."
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"/>
              </Grid>
              <Grid ColumnDefinitions="130,*">
                <TextBlock Grid.Column="0" Text="Idle" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                           Foreground="{DynamicResource TextAccentBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="The lowest priority level. The process only runs when no other process needs CPU time. Best for long-running batch jobs, maintenance tasks, or anything that can wait."
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ── Overview stat cards ──────────────────────────────────────── -->
        <Grid ColumnDefinitions="*,8,*,8,*">

          <!-- Total CPU -->
          <Border Grid.Column="0"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="TOTAL CPU" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Text="{Binding TotalCpuDisplay}"
                         FontSize="26" FontWeight="Bold"
                         Foreground="{DynamicResource AccentBlueBrush}"/>
              <TextBlock Text="of all running processes"
                         FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>

          <!-- Top RAM consumer -->
          <Border Grid.Column="2"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="TOP RAM CONSUMER" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
              <TextBlock Text="{Binding TopRamProcess}"
                         FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="highest working set"
                         FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>

          <!-- Attention count -->
          <Border Grid.Column="4"
                  Padding="14,12"
                  Background="{DynamicResource BgElevatedBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource CornerLG}">
            <StackPanel Spacing="4">
              <TextBlock Text="ATTENTION" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="🔴" FontSize="{DynamicResource NxFont14}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CriticalCount}" FontSize="{DynamicResource NxFont14}" FontWeight="Bold"
                           Foreground="{StaticResource ColorDangerBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="🟠" FontSize="{DynamicResource NxFont14}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding HighCount}" FontSize="{DynamicResource NxFont14}" FontWeight="Bold"
                           Foreground="{StaticResource ColorWarningBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="🟡" FontSize="{DynamicResource NxFont14}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding MediumCount}" FontSize="{DynamicResource NxFont14}" FontWeight="Bold"
                           Foreground="{StaticResource ProcCurrentBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="critical · high · medium"
                         FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- ── Summary & legend ─────────────────────────────────────────── -->
        <Border Padding="14,10"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding SummaryLine}"
                       FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="16"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource ColorDanger}" VerticalAlignment="Center"/>
                <TextBlock Text="Critical  CPU &gt;25% or RAM &gt;1 GB" FontSize="{DynamicResource NxFont10}"
                           Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="5">
                <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource ColorWarning}" VerticalAlignment="Center"/>
                <TextBlock Text="High  CPU &gt;8% or RAM &gt;512 MB" FontSize="{DynamicResource NxFont10}"
                           Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="5">
                <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource ProcCurrent}" VerticalAlignment="Center"/>
                <TextBlock Text="Medium  CPU &gt;2% or RAM &gt;200 MB" FontSize="{DynamicResource NxFont10}"
                           Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- ── Recommendations list ──────────────────────────────────────── -->
        <Border Padding="0"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}"
                ClipToBounds="True">
          <StackPanel>

            <!-- Card header -->
            <Border Padding="16,12"
                    Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1">
              <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Resource Hogs — Action Required"
                           FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <!-- Column headers (right side) -->
                <Grid DockPanel.Dock="Right" ColumnDefinitions="60,70,80,80,24">
                  <TextBlock Grid.Column="0" Text="CPU" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="RAM" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="2" Text="↓ Below Normal" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="3" Text="⏬ Idle" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="4" Text="✕" FontSize="{DynamicResource NxFont10}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
              </DockPanel>
            </Border>

            <!-- Empty state -->
            <Border Padding="24,32"
                    IsVisible="{Binding !HasRecommendations}">
              <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="No high-impact processes detected"
                           FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Your system is running efficiently. This list updates every 2 seconds."
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="340"/>
              </StackPanel>
            </Border>

            <!-- Process rows -->
            <ItemsControl ItemsSource="{Binding Recommendations}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="12,9"
                          BorderBrush="{DynamicResource BorderSubtleBrush}"
                          BorderThickness="0,0,0,1">
                    <DockPanel>

                      <!-- Impact badge -->
                      <Border DockPanel.Dock="Left"
                              Width="6"
                              CornerRadius="3"
                              Background="{Binding ImpactColor}"
                              Margin="0,0,10,0"/>

                      <!-- Process name + impact label -->
                      <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center"
                                  Width="160">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <TextBlock Text="{Binding ImpactIcon}" FontSize="{DynamicResource NxFont10}" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding ImpactLabel}"
                                     FontSize="{DynamicResource NxFont10}"
                                     Foreground="{Binding ImpactColor}"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                      </StackPanel>

                      <!-- Right side: CPU | RAM | actions -->
                      <Grid DockPanel.Dock="Right" ColumnDefinitions="60,70,80,80,28"
                            VerticalAlignment="Center">

                        <!-- CPU % -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding CpuDisplay}"
                                   FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBlueBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>

                        <!-- RAM -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding MemDisplay}"
                                   FontSize="{DynamicResource NxFont11}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>

                        <!-- Set Below Normal -->
                        <Button Grid.Column="2"
                                Classes="nx-btn"
                                HorizontalAlignment="Center"
                                Padding="6,3"
                                FontSize="{DynamicResource NxFont11}"
                                Content="↓ Below Normal"
                                Command="{Binding DataContext.SetBelowNormalCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="{Binding ActionTip}"/>

                        <!-- Set Idle -->
                        <Button Grid.Column="3"
                                Classes="nx-btn"
                                HorizontalAlignment="Center"
                                Padding="6,3"
                                FontSize="{DynamicResource NxFont11}"
                                Content="⏬ Idle"
                                Command="{Binding DataContext.SetIdleCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Set to Idle (lowest) priority — OS gives this process CPU time only when nothing else needs it"/>

                        <!-- Terminate -->
                        <Button Grid.Column="4"
                                Classes="nx-btn"
                                HorizontalAlignment="Center"
                                Padding="4,3"
                                FontSize="{DynamicResource NxFont11}"
                                Content="✕"
                                Command="{Binding DataContext.TerminateProcessCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="Terminate this process immediately (cannot be undone)"/>

                      </Grid>

                      <!-- Tooltip hint for the whole row -->
                      <ToolTip.Tip>
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                          <TextBlock Text="{Binding ActionTip}" TextWrapping="Wrap" MaxWidth="260"/>
                        </StackPanel>
                      </ToolTip.Tip>

                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>


      </StackPanel>
    </ScrollViewer>

  </DockPanel>

</UserControl>
