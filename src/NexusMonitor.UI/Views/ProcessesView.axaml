<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             xmlns:models="using:NexusMonitor.Core.Models"
             xmlns:views="using:NexusMonitor.UI.Views"
             x:Class="NexusMonitor.UI.Views.ProcessesView"
             x:DataType="vm:ProcessesViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:ProcessCategoryToBrushConverter x:Key="CategoryBrush" />
    <conv:ProcessCategoryToBgBrushConverter x:Key="CategoryBgBrush" />
    <conv:BytesFormatConverter x:Key="BytesFmt" />
    <conv:CpuHeatBrushConverter x:Key="CpuHeat" />
    <conv:NullToBoolConverter x:Key="NullToBool" />
    <conv:DepthToMarginConverter x:Key="DepthMargin" />
    <conv:HexColorToBrushConverter x:Key="HexBrush" />
  </UserControl.Resources>

  <DockPanel>

    <!-- ===== TOOLBAR ===== -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

        <!-- Search -->
        <Border Grid.Column="0"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerMD}"
                MaxWidth="320"
                HorizontalAlignment="Left">
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0"
                       Text="&#x1F50D;"
                       FontSize="{DynamicResource NxFont13}"
                       Margin="10,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <TextBox Grid.Column="1"
                     Name="SearchBox"
                     Classes="nx-input"
                     Text="{Binding SearchText}"
                     Watermark="Search processes…"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="0,6"/>
          </Grid>
        </Border>

        <!-- View toggle: Simplified -->
        <ToggleButton Grid.Column="1"
                      Classes="nx-toggle"
                      Margin="8,0,4,0"
                      IsChecked="{Binding IsSimplifiedView}"
                      ToolTip.Tip="Toggle simplified view (hide system processes)">
          <TextBlock Text="Simplified" FontSize="{DynamicResource NxFont11}"/>
        </ToggleButton>

        <!-- View toggle: Tree -->
        <ToggleButton Grid.Column="2"
                      Classes="nx-toggle"
                      Margin="0,0,4,0"
                      IsChecked="{Binding IsTreeViewActive}"
                      ToolTip.Tip="Show process parent/child hierarchy">
          <TextBlock Text="Tree" FontSize="{DynamicResource NxFont11}"/>
        </ToggleButton>

        <!-- Kill button -->
        <Button Grid.Column="3"
                Classes="nx-btn"
                Margin="0,0,4,0"
                Command="{Binding KillProcessCommand}"
                IsEnabled="{Binding SelectedProcess, Converter={StaticResource NullToBool}}"
                ToolTip.Tip="{Binding EndProcessMenuLabel}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="✕" FontSize="{DynamicResource NxFont11}" Foreground="{StaticResource ColorDangerBrush}"/>
            <TextBlock Text="End" FontSize="{DynamicResource NxFont12}"/>
          </StackPanel>
        </Button>

        <!-- Find Window crosshair -->
        <Button Grid.Column="4"
                Classes="nx-btn"
                Margin="0,0,4,0"
                Command="{Binding FindWindowCommand}"
                IsVisible="{Binding Platform.SupportsFindWindow}"
                ToolTip.Tip="Click on any window to identify its process">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="⊕" FontSize="{DynamicResource NxFont13}"/>
            <TextBlock Text="Find" FontSize="{DynamicResource NxFont11}"/>
          </StackPanel>
        </Button>

        <!-- More actions -->
        <Button Grid.Column="5"
                Classes="nx-btn"
                Margin="0,0,4,0"
                ToolTip.Tip="More actions">
          <TextBlock Text="⋮" FontSize="{DynamicResource NxFont14}"/>
        </Button>

        <!-- Detail panel toggle -->
        <ToggleButton Grid.Column="6"
                      Classes="nx-toggle"
                      Margin="0,0,4,0"
                      IsChecked="{Binding IsDetailPanelVisible}"
                      ToolTip.Tip="Show/hide process details panel">
          <TextBlock Text="Info Panel" FontSize="{DynamicResource NxFont11}"/>
        </ToggleButton>

        <!-- Groups panel toggle -->
        <ToggleButton Grid.Column="7"
                      Classes="nx-toggle"
                      Margin="0"
                      IsChecked="{Binding IsGroupPanelVisible}"
                      ToolTip.Tip="Show/hide process groups manager">
          <TextBlock Text="Groups" FontSize="{DynamicResource NxFont11}"/>
        </ToggleButton>

      </Grid>
    </Border>

    <!-- ===== GROUP SUMMARY STRIP ===== -->
    <ItemsControl ItemsSource="{Binding GroupSummaries}"
                  IsVisible="{Binding HasGroupSummaries}"
                  DockPanel.Dock="Top"
                  Margin="8,2">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Background="{Binding Color, Converter={StaticResource HexBrush}}"
                  CornerRadius="4" Padding="8,3" Margin="0,0,4,4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="{Binding CpuDisplay}" FontSize="11" Foreground="White" Opacity="0.85"/>
              <TextBlock Text="{Binding RamDisplay}" FontSize="11" Foreground="White" Opacity="0.85"/>
              <TextBlock Text="{Binding Count, StringFormat='({0})'}" FontSize="11" Foreground="White" Opacity="0.7"/>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- ===== STATUS BAR ===== -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,6"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <DockPanel>

        <!-- Error message — right-aligned, hidden when empty -->
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding LastError}"
                   IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="{DynamicResource NxFont11}"
                   Foreground="{StaticResource ColorDangerBrush}"
                   VerticalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Spacing="24">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Processes:"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="{Binding TotalProcessCount}"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontWeight="Medium"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Threads:"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="{Binding TotalThreadCount}"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontWeight="Medium"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="CPU:"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="{Binding TotalCpuPercent, StringFormat='{}{0:F1}%'}"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource AccentBlueBrush}"
                       FontWeight="Medium"/>
          </StackPanel>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- ===== MAIN CONTENT: list + details side panel + groups panel ===== -->
    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">

      <!-- ── PROCESS LIST ── -->
      <DataGrid Grid.Column="0"
                x:Name="ProcessGrid"
                Classes="nx-grid"
                ItemsSource="{Binding Processes}"
                SelectedItem="{Binding SelectedProcess}"
                CanUserSortColumns="True"
                CanUserResizeColumns="True"
                CanUserReorderColumns="True"
                SelectionMode="Extended"
                AutoGenerateColumns="False"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                Margin="0">

        <!-- Row background tinting by process category.
             :not(:selected):not(:pointerover) avoids overriding the selection / hover highlights. -->
        <DataGrid.Styles>
          <Style Selector="DataGridRow:not(:selected):not(:pointerover)">
            <Setter Property="Background"
                    Value="{Binding Category, Converter={StaticResource CategoryBgBrush}}"/>
          </Style>
        </DataGrid.Styles>

        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="{Binding EndProcessMenuLabel}" Command="{Binding KillProcessCommand}">
              <MenuItem.Icon>
                <TextBlock Text="✕" Foreground="{StaticResource ColorDangerBrush}"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding EndProcessTreeMenuLabel}" Command="{Binding KillProcessTreeCommand}"/>
            <Separator/>
            <MenuItem Header="Suspend" Command="{Binding SuspendProcessCommand}"/>
            <MenuItem Header="Resume"  Command="{Binding ResumeProcessCommand}"/>
            <Separator/>
            <MenuItem Header="Set Priority">
              <MenuItem Header="Idle"         Command="{Binding SetPriorityCommand}" CommandParameter="Idle"/>
              <MenuItem Header="Below Normal" Command="{Binding SetPriorityCommand}" CommandParameter="BelowNormal"/>
              <MenuItem Header="Normal"       Command="{Binding SetPriorityCommand}" CommandParameter="Normal"/>
              <MenuItem Header="Above Normal" Command="{Binding SetPriorityCommand}" CommandParameter="AboveNormal"/>
              <MenuItem Header="High"         Command="{Binding SetPriorityCommand}" CommandParameter="High"/>
              <MenuItem Header="Real Time"    Command="{Binding SetPriorityCommand}" CommandParameter="RealTime"/>
            </MenuItem>
            <MenuItem Header="Set CPU Affinity…" Command="{Binding SetAffinityCommand}"
                      IsVisible="{Binding Platform.SupportsCpuAffinity}"/>
            <MenuItem Header="Trim Memory"       Command="{Binding TrimMemoryCommand}"
                      IsVisible="{Binding Platform.SupportsTrimMemory}"
                      ToolTip.Tip="Release unused memory pages back to the system"/>
            <Separator/>
            <MenuItem Header="Remember Current Priority"
                      IsVisible="{Binding !HasPreference}"
                      ToolTip.Tip="Auto-apply this process's current priority every time it launches">
              <MenuItem Header="Idle"         Command="{Binding SavePreferenceWithCurrentPriorityCommand}" CommandParameter="Idle"/>
              <MenuItem Header="Below Normal" Command="{Binding SavePreferenceWithCurrentPriorityCommand}" CommandParameter="BelowNormal"/>
              <MenuItem Header="Normal"       Command="{Binding SavePreferenceWithCurrentPriorityCommand}" CommandParameter="Normal"/>
              <MenuItem Header="Above Normal" Command="{Binding SavePreferenceWithCurrentPriorityCommand}" CommandParameter="AboveNormal"/>
              <MenuItem Header="High"         Command="{Binding SavePreferenceWithCurrentPriorityCommand}" CommandParameter="High"/>
              <MenuItem Header="Real Time"    Command="{Binding SavePreferenceWithCurrentPriorityCommand}" CommandParameter="RealTime"/>
            </MenuItem>
            <MenuItem Header="Forget Saved Settings"
                      Command="{Binding ClearPreferenceCommand}"
                      IsVisible="{Binding HasPreference}"
                      ToolTip.Tip="Stop auto-applying saved settings for this process"/>
            <Separator/>
            <MenuItem Header="{Binding Platform.OpenLocationMenuLabel}" Command="{Binding OpenFileLocationCommand}"/>
            <MenuItem Header="Search Online"      Command="{Binding SearchOnlineCommand}"/>
            <Separator/>
            <MenuItem Header="Properties"         Command="{Binding ShowPropertiesCommand}"/>
            <MenuItem Header="Create Dump File…"  Command="{Binding CreateDumpFileCommand}"
                      IsVisible="{Binding Platform.SupportsCreateDump}"/>
          </ContextMenu>
        </DataGrid.ContextMenu>

        <DataGrid.Columns>

          <DataGridTemplateColumn Header="Name" Width="2.5*" MinWidth="140" SortMemberPath="Name">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProcessRowViewModel">
                <Grid ColumnDefinitions="4,Auto,*"
                      Margin="{Binding TreeDepth, Converter={StaticResource DepthMargin}}">
                  <Rectangle Grid.Column="0"
                              Width="3" Height="14"
                              RadiusX="1.5" RadiusY="1.5"
                              VerticalAlignment="Center"
                              Fill="{Binding Category, Converter={StaticResource CategoryBrush}}"/>
                  <TextBlock Grid.Column="2"
                              Text="{Binding Name}"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center"
                              FontSize="{DynamicResource NxFontSm}"
                              Foreground="{DynamicResource DataGridCellFgBrush}"
                              TextTrimming="CharacterEllipsis"/>
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="PID"
                              Binding="{Binding Pid}"
                              Width="80"
                              IsReadOnly="True"/>

          <DataGridTemplateColumn Header="CPU" Width="80" SortMemberPath="CpuPercent">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProcessRowViewModel">
                <Grid Margin="6,0" RowDefinitions="Auto,3">
                  <!-- Genuinely unreadable without root (other-uid process) — show "—", not a false 0% -->
                  <TextBlock Grid.Row="0"
                              Text="—"
                              IsVisible="{Binding IsAccessDenied}"
                              FontSize="{DynamicResource NxFont11}"
                              HorizontalAlignment="Right"
                              Foreground="{DynamicResource TextTertiaryBrush}"/>
                  <TextBlock Grid.Row="0"
                              Text="{Binding CpuPercent, StringFormat='{}{0:F1}%'}"
                              IsVisible="{Binding !IsAccessDenied}"
                              FontSize="{DynamicResource NxFont11}"
                              HorizontalAlignment="Right"
                              Foreground="{Binding CpuPercent, Converter={StaticResource CpuHeat}}"/>
                  <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                    <Rectangle Grid.Column="0"
                                Height="2" RadiusX="1" RadiusY="1"
                                HorizontalAlignment="Stretch"
                                Fill="{DynamicResource BgHoverBrush}"/>
                    <Rectangle Grid.Column="0"
                                Height="2" RadiusX="1" RadiusY="1"
                                HorizontalAlignment="Left"
                                Width="{Binding CpuPercent}"
                                MaxWidth="68"
                                Fill="{Binding CpuPercent, Converter={StaticResource CpuHeat}}"/>
                  </Grid>
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="Memory" Width="100" SortMemberPath="WorkingSetBytes">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProcessRowViewModel">
                <TextBlock Text="{Binding WorkingSetBytes, Converter={StaticResource BytesFmt}}"
                            FontSize="{DynamicResource NxFont11}"
                            HorizontalAlignment="Right"
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource TextSecondaryBrush}"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="Leak" Width="90" SortMemberPath="LeakRateMbPerHour">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProcessRowViewModel">
                <TextBlock Text="{Binding LeakRateDisplay}" Foreground="{Binding LeakRateBrush}"
                           FontSize="{DynamicResource NxFont10}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="I/O" Width="78" SortMemberPath="IoReadBytesPerSec">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProcessRowViewModel">
                <TextBlock Text="{Binding IoDisplay}"
                            FontSize="{DynamicResource NxFont10}"
                            HorizontalAlignment="Right"
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource TextTertiaryBrush}"
                            TextTrimming="CharacterEllipsis"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- Impact Score column (Phase 1) -->
          <DataGridTemplateColumn Header="Impact" Width="96" SortMemberPath="ImpactScore">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProcessRowViewModel">
                <Grid Margin="6,0" RowDefinitions="Auto,3"
                      ToolTip.Tip="How much this app is affecting your computer's speed (0–100). Higher = more impact.">
                  <TextBlock Grid.Row="0"
                             Text="{Binding ImpactScore, StringFormat={}{0:F0}}"
                             FontSize="{DynamicResource NxFont11}"
                             HorizontalAlignment="Right"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <Grid Grid.Row="1" ColumnDefinitions="*">
                    <Rectangle Grid.Column="0"
                               Height="2" RadiusX="1" RadiusY="1"
                               HorizontalAlignment="Stretch"
                               Fill="{DynamicResource BgHoverBrush}"/>
                    <Rectangle Grid.Column="0"
                               Height="2" RadiusX="1" RadiusY="1"
                               HorizontalAlignment="Left"
                               Width="{Binding ImpactScore}"
                               MaxWidth="62"
                               Fill="{DynamicResource AccentBrush}"/>
                  </Grid>
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- Rules indicator column (Phase 1) -->
          <DataGridTemplateColumn Header="Rules" Width="88" SortMemberPath="HasActiveRule">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProcessRowViewModel">
                <TextBlock Text="⚙"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           IsVisible="{Binding HasActiveRule}"
                           ToolTip.Tip="{Binding RuleSummary}"
                           Foreground="{DynamicResource AccentBrush}"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- Group badge column (Phase 22b) -->
          <DataGridTemplateColumn Header="Group" Width="Auto" SortMemberPath="GroupName" MinWidth="90">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProcessRowViewModel">
                <Border Background="{Binding GroupColor, Converter={StaticResource HexBrush}}"
                        CornerRadius="4" Padding="5,2" Margin="2,0"
                        IsVisible="{Binding GroupName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        VerticalAlignment="Center" HorizontalAlignment="Left">
                  <TextBlock Text="{Binding GroupName}"
                             FontSize="11" Foreground="White"
                             VerticalAlignment="Center"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!-- Priority/Threads/Handles: widened from 80/100/100 — those pixel widths were too
               narrow for the header text itself ("Priority"/"Threads"/"Handles" + sort glyph),
               clipping to "P"/"T"/etc. MinWidth added as a floor if the user manually resizes. -->
          <DataGridTextColumn Header="Priority"
                              Binding="{Binding BasePriority}"
                              Width="110" MinWidth="90"
                              IsReadOnly="True"/>

          <DataGridTextColumn Header="Threads"
                              Binding="{Binding ThreadCount}"
                              Width="110" MinWidth="90"
                              IsReadOnly="True"/>

          <DataGridTextColumn Header="Handles"
                              Binding="{Binding HandleCount}"
                              Width="110" MinWidth="90"
                              IsReadOnly="True"/>

          <!-- Sym-1 Task 4 (2026-07-08): MacOSProcessProvider now populates UserName (uid ->
               account name via sysctl+getpwuid_r), so the User column is shown on every
               platform (ShowUserColumn is effectively always true now). Description remains
               unpopulated on macOS (no per-process description lookup implemented), so that
               column stays gated below. DataGridColumn isn't in the visual tree, so it can't
               inherit DataContext — bind via ElementName to the named DataGrid instead. -->
          <DataGridTextColumn Header="User"
                              Binding="{Binding UserName}"
                              Width="0.8*" MinWidth="85"
                              IsVisible="{Binding DataContext.ShowUserColumn, ElementName=ProcessGrid}"
                              IsReadOnly="True"/>

          <!-- Hidden on macOS: MacOSProcessProvider never populates Description (no per-process
               description lookup implemented), so it would just be empty dead space on every row. -->
          <DataGridTextColumn Header="Description"
                              Binding="{Binding Description}"
                              Width="2.0*" MinWidth="100"
                              IsVisible="{Binding DataContext.ShowDescriptionColumn, ElementName=ProcessGrid}"
                              IsReadOnly="True"/>

        </DataGrid.Columns>

      </DataGrid>

      <!-- ── SPLITTER ── -->
      <GridSplitter Grid.Column="1"
                    Width="1"
                    Background="{DynamicResource BorderSubtleBrush}"
                    ResizeDirection="Columns"
                    IsVisible="{Binding IsDetailPanelShown}"/>

      <!-- ── DETAILS SIDE PANEL ── -->
      <!-- Width="280" on the Border causes the Auto column to collapse to 0 when IsVisible=false -->
      <Border Grid.Column="2"
              Width="280"
              Background="{DynamicResource BgSecondaryBrush}"
              IsVisible="{Binding IsDetailPanelShown}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="0"
                      DataContext="{Binding SelectedDetails}"
                      Margin="14,12">

            <!-- Header: process name + PID -->
            <TextBlock Text="{Binding Name}"
                       FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,2"/>
            <TextBlock FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,12">
              <Run Text="PID "/>
              <Run Text="{Binding Pid}" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Run Text="  ·  PPID "/>
              <Run Text="{Binding ParentPid}" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </TextBlock>

            <Separator Background="{DynamicResource BorderSubtleBrush}" Margin="0,0,0,10"/>

            <!-- Section: Identity -->
            <TextBlock Text="IDENTITY" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="User"     Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding User}" ToolTip.Tip="{Binding UserUnavailableTooltip}"      Classes="detail-value"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="State"    Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding State}"     Classes="detail-value"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Category" Classes="detail-label"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Category}"  Classes="detail-value"/>
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Started"  Classes="detail-label"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StartTime}" ToolTip.Tip="{Binding StartTimeUnavailableTooltip}" Classes="detail-value"/>
            </Grid>

            <!-- Section: Performance -->
            <TextBlock Text="PERFORMANCE" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU"         Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CpuPercent}"   Classes="detail-value" Foreground="{DynamicResource AccentBlueBrush}"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Threads"     Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Threads}"      Classes="detail-value"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Handles"     Classes="detail-label"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Handles}"      Classes="detail-value"/>
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Working Set" Classes="detail-label"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WorkingSet}"   Classes="detail-value"/>
              <TextBlock Grid.Row="4" Grid.Column="0" Text="Private"     Classes="detail-label"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PrivateBytes}" Classes="detail-value"/>
              <TextBlock Grid.Row="5" Grid.Column="0" Text="Virtual"     Classes="detail-label"/>
              <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding VirtualBytes}" Classes="detail-value"/>
            </Grid>

            <!-- CPU history sparkline — updates every tick via PropertyChanged(null) -->
            <Border Background="{DynamicResource BgElevatedBrush}"
                    CornerRadius="4"
                    ClipToBounds="True"
                    Height="46"
                    Margin="0,4,0,12">
              <Viewbox Stretch="Fill">
                <Canvas Width="240" Height="44">
                  <Polyline Points="{Binding CpuSparkPoints}"
                             Stroke="{DynamicResource AccentBlueBrush}"
                             StrokeThickness="1.5"
                             StrokeLineCap="Round"
                             StrokeJoin="Round"/>
                </Canvas>
              </Viewbox>
            </Border>

            <!-- Section: I/O -->
            <TextBlock Text="DISK I/O" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Read"  Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ReadRate}"  Classes="detail-value"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Write" Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WriteRate}" Classes="detail-value"/>
            </Grid>

            <!-- Section: Image -->
            <TextBlock Text="IMAGE" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <TextBlock Text="{Binding Description}" ToolTip.Tip="{Binding DescriptionUnavailableTooltip}"
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,6"/>

            <TextBlock Text="{Binding ImagePath}" ToolTip.Tip="{Binding ImagePathUnavailableTooltip}"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,6"/>

            <TextBlock Text="{Binding CommandLine}" ToolTip.Tip="{Binding CommandLineUnavailableTooltip}"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,6"
                       FontStyle="Italic"/>

            <!-- Section: Loaded Modules -->
            <Separator Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>

            <TextBlock Text="MODULES" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <ScrollViewer MaxHeight="160">
              <ItemsControl ItemsSource="{Binding DataContext.ProcessModules, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               ToolTip.Tip="{Binding Path}"
                               Margin="0,1"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Section: Threads -->
            <Separator Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>
            <TextBlock Text="THREADS" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>
            <ScrollViewer MaxHeight="140">
              <ItemsControl ItemsSource="{Binding DataContext.ProcessThreads,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding ThreadId, StringFormat='TID {0}'}"
                                 FontSize="{DynamicResource NxFont11}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding BasePriority, StringFormat='Pri {0}'}"
                                 FontSize="{DynamicResource NxFont11}"
                                 HorizontalAlignment="Right"
                                 Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Section: Environment Variables -->
            <Separator Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>
            <TextBlock Text="ENVIRONMENT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>
            <ScrollViewer MaxHeight="160">
              <ItemsControl ItemsSource="{Binding DataContext.ProcessEnvironment,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,1">
                      <TextBlock Text="{Binding Key}"   FontSize="{DynamicResource NxFont10}"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 TextTrimming="CharacterEllipsis" MaxWidth="90"
                                 ToolTip.Tip="{Binding Key}"/>
                      <TextBlock Text="=" FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="2,0"/>
                      <TextBlock Text="{Binding Value}" FontSize="{DynamicResource NxFont10}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis" MaxWidth="130"
                                 ToolTip.Tip="{Binding Value}"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Section: Handles -->
            <StackPanel IsVisible="{Binding DataContext.Platform.SupportsHandles, RelativeSource={RelativeSource AncestorType=UserControl}}">
              <Separator Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <TextBlock Grid.Column="0" Text="HANDLES" FontSize="{DynamicResource NxFont11}"
                           FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}"
                           LetterSpacing="0.8"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding DataContext.HandleCountLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="{DynamicResource NxFont10}"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
              </Grid>
              <ScrollViewer MaxHeight="160">
                <ItemsControl ItemsSource="{Binding DataContext.ProcessHandles, RelativeSource={RelativeSource AncestorType=UserControl}}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="90,*" Margin="0,1">
                        <TextBlock Grid.Column="0" Text="{Binding TypeName}"
                                   FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding ObjectName}"
                                   FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding ObjectName}"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>

            <!-- Section: Memory Map -->
            <StackPanel IsVisible="{Binding DataContext.Platform.SupportsMemoryMap, RelativeSource={RelativeSource AncestorType=UserControl}}">
              <Separator Background="{DynamicResource BorderSubtleBrush}" Margin="0,6,0,10"/>
              <TextBlock Text="MEMORY MAP" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         LetterSpacing="0.8" Margin="0,0,0,6"/>
              <ScrollViewer MaxHeight="160">
                <ItemsControl ItemsSource="{Binding DataContext.ProcessMemoryMap, RelativeSource={RelativeSource AncestorType=UserControl}}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="100,60,60,50,50" Margin="0,1">
                        <TextBlock Grid.Column="0" Text="{Binding BaseAddressHex}"
                                   FontSize="{DynamicResource NxFont10}" FontFamily="Consolas,Monospace"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding RegionSizeDisplay}"
                                   FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="{Binding State}"
                                   FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding RegionType}"
                                   FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="{Binding Protection}"
                                   FontSize="{DynamicResource NxFont10}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ── GROUPS PANEL SPLITTER ── -->
      <GridSplitter Grid.Column="3"
                    Width="4"
                    Background="{DynamicResource BorderSubtleBrush}"
                    ResizeDirection="Columns"
                    IsVisible="{Binding IsGroupPanelVisible}"/>

      <!-- ── GROUPS PANEL ── -->
      <!-- Width="440" on the Border causes the Auto column to collapse to 0 when IsVisible=false -->
      <Border Grid.Column="4"
              Width="440"
              Background="{DynamicResource BgSecondaryBrush}"
              IsVisible="{Binding IsGroupPanelVisible}">
        <views:ProcessGroupsView DataContext="{Binding GroupsViewModel}"/>
      </Border>

    </Grid>

  </DockPanel>
</UserControl>
