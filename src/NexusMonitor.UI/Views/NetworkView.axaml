<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             x:Class="NexusMonitor.UI.Views.NetworkView"
             x:DataType="vm:NetworkViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:TcpStateBrushConverter x:Key="TcpStateBrush"/>
    <conv:TcpStateLabelConverter x:Key="TcpStateLabel"/>
    <conv:NullToBoolConverter x:Key="NullToBool"/>
  </UserControl.Resources>

  <DockPanel>

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Network Connections"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,16,0"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <ToggleButton Classes="nx-toggle"
                        IsChecked="{Binding IsDetailPanelVisible}"
                        ToolTip.Tip="Show/hide connection details panel">
            <TextBlock Text="Info Panel" FontSize="{DynamicResource NxFont11}"/>
          </ToggleButton>
          <TextBox Name="SearchBox"
                   Classes="nx-input"
                   Text="{Binding SearchText}"
                   Watermark="Search address, port, process&#x2026;"
                   Width="260"
                   VerticalAlignment="Center"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,6"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <DockPanel>

        <!-- Adapter throughput — right-aligned -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="&#x2191;"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource AccentBlueBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding AdapterSendDisplay}"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource AccentBlueBrush}"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="&#x2193;"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{StaticResource ColorSuccessBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding AdapterRecvDisplay}"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{StaticResource ColorSuccessBrush}"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>

        <TextBlock Text="{Binding TotalCount, StringFormat='Connections: {0}'}"
                   FontSize="{DynamicResource NxFont11}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"/>

      </DockPanel>
    </Border>

    <!-- Connection table + sidebar -->
    <Grid ColumnDefinitions="*,Auto,Auto">

      <!-- DataGrid -->
      <DataGrid x:Name="ConnectionGrid"
                Grid.Column="0"
                Classes="nx-grid"
                ItemsSource="{Binding Connections}"
                SelectedItem="{Binding SelectedConnection}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                CanUserResizeColumns="True"
                CanUserReorderColumns="True"
                IsReadOnly="True"
                ScrollViewer.HorizontalScrollBarVisibility="Auto">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Copy Local Address"  Command="{Binding CopyLocalAddressCommand}"/>
            <MenuItem Header="Copy Remote Address" Command="{Binding CopyRemoteAddressCommand}"/>
            <Separator/>
            <MenuItem Header="Go to Process" Command="{Binding GoToProcessCommand}"/>
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Protocol"       Binding="{Binding Protocol}"      SortMemberPath="Protocol"      Width="112"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Local Address"  Binding="{Binding LocalAddress}"  SortMemberPath="LocalAddress"  Width="1.5*" MinWidth="130" IsReadOnly="True"/>
          <DataGridTextColumn Header="Local Port"     Binding="{Binding LocalPort}"     SortMemberPath="LocalPort"     Width="118"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Remote Address" Binding="{Binding RemoteAddress}" SortMemberPath="RemoteAddress" Width="1.5*" MinWidth="135" IsReadOnly="True"/>
          <DataGridTextColumn Header="Remote Port"    Binding="{Binding RemotePort}"    SortMemberPath="RemotePort"    Width="132"  IsReadOnly="True"/>
          <!-- Width 100 clipped the longest state label ("ESTABLISHED") to "ESTABLISH" — widened to
               fit that label (and others like "CLOSE_WAIT"/"TIME_WAIT") plus the badge's padding/margin. -->
          <DataGridTemplateColumn Header="State" Width="132" SortMemberPath="State">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border CornerRadius="4"
                        Padding="6,2"
                        Margin="4,3"
                        HorizontalAlignment="Left"
                        Background="{Binding State, Converter={StaticResource TcpStateBrush}}">
                  <TextBlock Text="{Binding State, Converter={StaticResource TcpStateLabel}}"
                             FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             Foreground="White"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="&#x2191; Send"  Binding="{Binding SendDisplay}"   SortMemberPath="SendDisplay"  Width="85"  IsReadOnly="True"/>
          <DataGridTextColumn Header="&#x2193; Recv"  Binding="{Binding RecvDisplay}"   SortMemberPath="RecvDisplay"  Width="85"  IsReadOnly="True"/>
          <DataGridTextColumn Header="PID"            Binding="{Binding ProcessId}"     SortMemberPath="ProcessId"    Width="76"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Process"        Binding="{Binding ProcessName}"   SortMemberPath="ProcessName"  Width="1.8*" MinWidth="90" IsReadOnly="True"/>
        </DataGrid.Columns>
      </DataGrid>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1"
                    Width="1"
                    Background="{DynamicResource BorderSubtleBrush}"
                    IsVisible="{Binding IsConnectionDetailShown}"/>

      <!-- Detail sidebar -->
      <Border Grid.Column="2"
              Width="260"
              Background="{DynamicResource BgSecondaryBrush}"
              IsVisible="{Binding IsConnectionDetailShown}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="0"
                      DataContext="{Binding SelectedConnection}"
                      Margin="14,12">

            <!-- Header: process name -->
            <TextBlock Text="{Binding ProcessName}"
                       FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,2"/>
            <TextBlock FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6">
              <Run Text="PID "/>
              <Run Text="{Binding ProcessId}" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </TextBlock>

            <!-- State badge -->
            <Border CornerRadius="4" Padding="8,3" Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    Background="{Binding State, Converter={StaticResource TcpStateBrush}}">
              <TextBlock Text="{Binding State, Converter={StaticResource TcpStateLabel}}"
                         FontSize="{DynamicResource NxFont11}" Foreground="White" FontWeight="Medium"/>
            </Border>

            <Separator Background="{DynamicResource BorderSubtleBrush}" Margin="0,0,0,10"/>

            <!-- Local endpoint -->
            <TextBlock Text="LOCAL ENDPOINT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Address" Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalAddress}" Classes="detail-value"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Port"    Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LocalPort}"   Classes="detail-value"/>
            </Grid>

            <!-- Remote endpoint -->
            <TextBlock Text="REMOTE ENDPOINT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       LetterSpacing="0.8" Margin="0,0,0,6"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Address" Classes="detail-label"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RemoteAddress}" Classes="detail-value"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Port"    Classes="detail-label"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RemotePort}"   Classes="detail-value"/>
            </Grid>

            <!-- Throughput (only shown when per-connection stats are available) -->
            <StackPanel IsVisible="{Binding DataContext.ShowThroughputColumns,
                        RelativeSource={RelativeSource AncestorType=UserControl}}">
              <TextBlock Text="THROUGHPUT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         LetterSpacing="0.8" Margin="0,0,0,6"/>

              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Protocol" Classes="detail-label"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Protocol}"    Classes="detail-value"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="&#x2191; Send" Classes="detail-label"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SendDisplay}" Classes="detail-value"
                           Foreground="{DynamicResource AccentBlueBrush}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="&#x2193; Recv" Classes="detail-label"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RecvDisplay}" Classes="detail-value"
                           Foreground="{DynamicResource AccentBlueBrush}"/>
              </Grid>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Border>

    </Grid>

  </DockPanel>

</UserControl>
