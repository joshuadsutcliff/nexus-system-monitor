<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:ctrl="using:NexusMonitor.UI.Controls"
             xmlns:models="clr-namespace:NexusMonitor.DiskAnalyzer.Models;assembly=NexusMonitor.DiskAnalyzer"
             x:Class="NexusMonitor.UI.Views.DiskAnalyzerView"
             x:DataType="vm:DiskAnalyzerViewModel"
             x:CompileBindings="False"
             Background="{DynamicResource BgBaseBrush}">

  <!-- RowDefinitions:
       0 = Toolbar  (drive picker, path, scan/cancel, status)
       1 = Stats bar (Total / Used / Free)   — visible only after scan
       2 = Tab bar  (Folder View | File View)
       3 = Body     (switches between views)
       4 = Splitter
       5 = Treemap  (always visible, full width) -->
  <Grid RowDefinitions="Auto,Auto,Auto,*,4,220">

    <!-- ── Row 0: Toolbar ─────────────────────────────────────────────── -->
    <Border Grid.Row="0" Padding="16,10" Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
      <!-- Status column (index 8) is a fixed 280 (not Auto) matching the TextBlock's MaxWidth
           below, so its frequent re-binding during a scan can never re-measure/shift the
           progress bar or any other toolbar column. -->
      <Grid ColumnDefinitions="Auto,8,*,8,Auto,8,Auto,8,280,*">

        <ComboBox Grid.Column="0"
                  ItemsSource="{Binding AvailableDrives}"
                  SelectedItem="{Binding SelectedPath}"
                  Width="110" VerticalAlignment="Center"/>

        <TextBox Grid.Column="2"
                 Text="{Binding SelectedPath}"
                 Watermark="Enter path to scan…"
                 VerticalAlignment="Center"/>

        <!-- Scan/Cancel swap: both buttons share one fixed-width Panel so column 4 never
             resizes (and shoves the columns after it sideways) when scanning starts/stops.
             92 = "Cancel" (the wider of the two English labels) at the button's default font
             size, plus the 16,8 Padding declared below, with a small safety margin. -->
        <Panel Grid.Column="4" Width="92" MinWidth="92" VerticalAlignment="Center">
          <!-- Scan (hidden while scanning) -->
          <Button Content="Scan"
                  Command="{Binding StartScanCommand}"
                  IsVisible="{Binding !IsScanning}"
                  Padding="16,8" VerticalAlignment="Center">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
              </Style>
              <Style Selector="Button:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource AccentBlueHoverBrush}"/>
              </Style>
            </Button.Styles>
          </Button>

          <!-- Cancel (visible while scanning) -->
          <Button Content="Cancel"
                  Command="{Binding CancelScanCommand}"
                  IsVisible="{Binding IsScanning}"
                  Padding="16,8" VerticalAlignment="Center">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="Background" Value="{StaticResource ColorDangerBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
              </Style>
            </Button.Styles>
          </Button>
        </Panel>

        <!-- Find Duplicates -->
        <Button Grid.Column="6" Content="Find Duplicates"
                Command="{Binding FindDuplicatesCommand}"
                IsEnabled="{Binding HasScanResult}"
                Padding="14,8" VerticalAlignment="Center">
          <Button.Styles>
            <Style Selector="Button">
              <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
              <Setter Property="CornerRadius" Value="8"/>
            </Style>
          </Button.Styles>
        </Button>

        <!-- Status -->
        <TextBlock Grid.Column="8"
                   Text="{Binding ScanStatus}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   FontSize="{DynamicResource NxFont12}"
                   Margin="8,0,0,0"
                   MaxWidth="280"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Inline scanning progress bar -->
        <ProgressBar Grid.Column="9"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsScanning}"
                     Height="3"
                     Background="Transparent"
                     Foreground="{DynamicResource AccentBlueBrush}"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0"/>
      </Grid>
    </Border>

    <!-- ── Row 1: Volume stats bar ────────────────────────────────────── -->
    <!-- Height is fixed (not just IsVisible-toggled) so this row never collapses/expands at
         scan start or completion — that vertical jitter was the root cause of the reported
         page reflow. 34 = Padding 8+8 vertical + ~18px natural line height for the NxFont12
         (14px) stat text. Only the inner content's visibility toggles now; the Border itself
         (and its reserved row space) stays constant. -->
    <Border Grid.Row="1" Padding="16,8" Height="34"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,1,*,1,*" IsVisible="{Binding HasScanResult}">

        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
          <TextBlock Text="Total:"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding VolumeTotalDisplay}"
                     FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource BorderSubtleBrush}"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
          <TextBlock Text="Used:"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding VolumeUsedDisplay}"
                     FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                     Foreground="{DynamicResource AccentBlueBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding VolumeUsedPercent, StringFormat='({0:F1}%)'}"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <Rectangle Grid.Column="3" Width="1" Fill="{DynamicResource BorderSubtleBrush}"/>

        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
          <TextBlock Text="Free:"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding VolumeFreeDisplay}"
                     FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                     Foreground="{StaticResource ColorSuccessBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ── Row 2: Tab bar ─────────────────────────────────────────────── -->
    <Border Grid.Row="2" Padding="12,0"
            Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal">
        <Button Command="{Binding SelectFolderViewCommand}" Padding="16,9" CornerRadius="0">
          <Button.Styles>
            <Style Selector="Button">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
            </Style>
          </Button.Styles>
          <Panel>
            <TextBlock Text="Folder View"
                       FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <Border Height="2" VerticalAlignment="Bottom"
                    Background="{DynamicResource AccentBlueBrush}"
                    IsVisible="{Binding IsFolderViewActive}"/>
          </Panel>
        </Button>
        <Button Command="{Binding SelectFileViewCommand}" Padding="16,9" CornerRadius="0">
          <Button.Styles>
            <Style Selector="Button">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
            </Style>
          </Button.Styles>
          <Panel>
            <TextBlock Text="File View"
                       FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <Border Height="2" VerticalAlignment="Bottom"
                    Background="{DynamicResource AccentBlueBrush}"
                    IsVisible="{Binding IsFileViewActive}"/>
          </Panel>
        </Button>
        <Button Command="{Binding SelectDuplicateViewCommand}" Padding="16,9" CornerRadius="0">
          <Button.Styles>
            <Style Selector="Button">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
            </Style>
          </Button.Styles>
          <Panel>
            <TextBlock Text="Duplicates"
                       FontSize="{DynamicResource NxFont12}" FontWeight="Medium"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <Border Height="2" VerticalAlignment="Bottom"
                    Background="{DynamicResource AccentBlueBrush}"
                    IsVisible="{Binding IsDuplicateViewActive}"/>
          </Panel>
        </Button>
      </StackPanel>
    </Border>

    <!-- ── Row 3: Body ────────────────────────────────────────────────── -->
    <Panel Grid.Row="3">

      <!-- ═══════ FOLDER VIEW ═══════ -->
      <Grid IsVisible="{Binding IsFolderViewActive}" ColumnDefinitions="*,4,280">

        <!-- Left: breadcrumb + folder DataGrid -->
        <Grid Grid.Column="0" RowDefinitions="Auto,*">

          <Border Grid.Row="0" Padding="10,7"
                  Background="{DynamicResource BgPrimaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Button Content="Up" Command="{Binding NavigateUpCommand}" Padding="8,4"
                      IsEnabled="{Binding SelectedNode.Parent, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Button.Styles>
                  <Style Selector="Button">
                    <Setter Property="CornerRadius" Value="6"/>
                    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                  </Style>
                </Button.Styles>
              </Button>
              <ItemsControl ItemsSource="{Binding Breadcrumb}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="0"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="models:DiskNode">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                      <TextBlock Text=" > " Foreground="{DynamicResource TextTertiaryBrush}"
                                 VerticalAlignment="Center" FontSize="{DynamicResource NxFont11}"/>
                      <Button Content="{Binding Name}"
                              Command="{Binding $parent[UserControl].DataContext.NavigateToBreadcrumbCommand}"
                              CommandParameter="{Binding}" Padding="5,3">
                        <Button.Styles>
                          <Style Selector="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
                            <Setter Property="CornerRadius" Value="5"/>
                            <Setter Property="FontSize" Value="{DynamicResource NxFont12}"/>
                          </Style>
                        </Button.Styles>
                      </Button>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Folder tree: flat-list with depth-indented rows + in-place expand/collapse -->
          <DataGrid Grid.Row="1"
                    x:Name="FolderTree"
                    ItemsSource="{Binding TreeRows}"
                    SelectedItem="{Binding SelectedRow}"
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    CanUserSortColumns="False"
                    CanUserResizeColumns="True"
                    FontSize="{DynamicResource NxFont12}"
                    Background="{DynamicResource BgPrimaryBrush}">
            <DataGrid.Columns>
              <!-- Name column: indented + expander button + icon -->
              <DataGridTemplateColumn Header="Name" Width="2.5*" MinWidth="120">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate DataType="vm:FolderTreeRow">
                    <StackPanel Orientation="Horizontal" Spacing="2"
                                Margin="{Binding NameMargin}"
                                VerticalAlignment="Center">
                      <!-- Expander toggle (▶/▼) for directories with children -->
                      <Button IsVisible="{Binding HasChildren}"
                              Command="{Binding $parent[UserControl].DataContext.ToggleRowCommand}"
                              CommandParameter="{Binding}"
                              Width="16" Height="16" Padding="0"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Center">
                        <Button.Styles>
                          <Style Selector="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="9"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                          </Style>
                        </Button.Styles>
                        <Panel>
                          <TextBlock Text="▶" IsVisible="{Binding !IsExpanded}" FontSize="9" VerticalAlignment="Center"/>
                          <TextBlock Text="▼" IsVisible="{Binding IsExpanded}"  FontSize="9" VerticalAlignment="Center"/>
                        </Panel>
                      </Button>
                      <!-- Placeholder spacer for files (no expander) -->
                      <Border Width="16" IsVisible="{Binding !HasChildren}"/>
                      <!-- Icon -->
                      <TextBlock Text="&#x1F4C1;" FontSize="11" VerticalAlignment="Center"
                                 IsVisible="{Binding Node.IsDirectory}"/>
                      <!-- Name -->
                      <TextBlock Text="{Binding Node.Name}"
                                 FontSize="{DynamicResource NxFont12}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="%"         Binding="{Binding PercentDisplay}"   Width="0.55*" MinWidth="50"  IsReadOnly="True"/>
              <DataGridTextColumn Header="Size"      Binding="{Binding SizeDisplay}"      Width="0.8*"  MinWidth="60"  IsReadOnly="True"/>
              <DataGridTextColumn Header="Allocated" Binding="{Binding AllocatedDisplay}" Width="0.8*"  MinWidth="60"  IsReadOnly="True"/>
              <DataGridTextColumn Header="Files"     Binding="{Binding FileCount}"        Width="0.65*" MinWidth="50"  IsReadOnly="True"/>
              <DataGridTextColumn Header="Folders"   Binding="{Binding FolderCount}"      Width="0.65*" MinWidth="50"  IsReadOnly="True"/>
              <DataGridTextColumn Header="Modified"  Binding="{Binding Modified}"         Width="0.9*"  MinWidth="75"  IsReadOnly="True"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>

        <!-- Vertical splitter -->
        <GridSplitter Grid.Column="1" Width="4" VerticalAlignment="Stretch"
                      Background="{DynamicResource BorderSubtleBrush}"/>

        <!-- Right panel: File Types + Selected File -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">

          <!-- File Types header -->
          <Border Grid.Row="0" Padding="12,10"
                  Background="{DynamicResource BgPrimaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1">
            <TextBlock Text="FILE TYPES"
                       FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                       LetterSpacing="0.8"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
          </Border>

          <!-- File type list -->
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FileTypeStats}" Padding="8,4">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:FileTypeStatRow">
                  <Grid ColumnDefinitions="54,*,Auto" Margin="0,2">
                    <Border Grid.Column="0"
                            CornerRadius="4" Padding="4,2"
                            Background="{DynamicResource BgElevatedBrush}"
                            HorizontalAlignment="Left">
                      <TextBlock Text="{Binding Extension}"
                                 FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="6,0">
                      <TextBlock Text="{Binding SizeDisplay}"
                                 FontSize="{DynamicResource NxFont11}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding PercentDisplay}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <!-- Selected file mini-details -->
          <Border Grid.Row="2" Padding="12,10"
                  Background="{DynamicResource BgPrimaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,1,0,1"
                  IsVisible="{Binding SelectedFile, Converter={x:Static ObjectConverters.IsNotNull}}">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding SelectedFile.Name, FallbackValue=''}"
                         FontSize="{DynamicResource NxFont12}" FontWeight="SemiBold"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <Grid ColumnDefinitions="70,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Size"
                           Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{DynamicResource NxFont11}"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding SelectedFile.SizeDisplay}"
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Modified"
                           Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{DynamicResource NxFont11}"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding SelectedFile.LastModified, StringFormat='yyyy-MM-dd HH:mm'}"
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="% Parent"
                           Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{DynamicResource NxFont11}"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="{Binding SelectedFile.PercentOfParent, StringFormat='{}{0:F1}%'}"
                           FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </Grid>
              <TextBlock Text="{Binding SelectedFile.FullPath}"
                         FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
          </Border>

        </Grid><!-- end right panel -->
      </Grid><!-- end folder view -->

      <!-- ═══════ FILE VIEW ═══════ -->
      <Grid IsVisible="{Binding IsFileViewActive}" RowDefinitions="Auto,Auto,*">

        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0"
                     Name="SearchBox"
                     Classes="nx-input"
                     Text="{Binding FileSearchText}"
                     Watermark="Search file name or path…"
                     MaxWidth="480"
                     HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding FileViewSummary}"
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       VerticalAlignment="Center"
                       Margin="12,0,4,0"/>
          </Grid>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="Run a scan to populate the file list."
                   FontSize="{DynamicResource NxFont14}"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,24,0,0"
                   IsVisible="{Binding !HasScanResult}"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredFiles}"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  FontSize="{DynamicResource NxFont12}"
                  Background="{DynamicResource BgPrimaryBrush}">
          <DataGrid.Columns>
            <DataGridTextColumn Header="File Name"  Binding="{Binding Name}"       Width="3*"   MinWidth="120" IsReadOnly="True"/>
            <DataGridTextColumn Header="Path"       Binding="{Binding FullPath}"   Width="3.5*" MinWidth="150" IsReadOnly="True"/>
            <DataGridTextColumn Header="% Parent"   Binding="{Binding PercentOfParent, StringFormat='{}{0:F1}%'}" Width="0.7*" MinWidth="55"  IsReadOnly="True"/>
            <DataGridTextColumn Header="Size"       Binding="{Binding SizeDisplay}"       Width="0.8*" MinWidth="60"  IsReadOnly="True"/>
            <DataGridTextColumn Header="Allocated"  Binding="{Binding AllocatedDisplay}"  Width="0.8*" MinWidth="60"  IsReadOnly="True"/>
            <DataGridTextColumn Header="Modified"   Binding="{Binding LastModified, StringFormat='yyyy-MM-dd'}" Width="1*" MinWidth="75" IsReadOnly="True"/>
          </DataGrid.Columns>
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="{Binding $parent[ContextMenu].PlacementTarget.DataContext.Platform.OpenLocationMenuLabel}"
                        Command="{Binding $parent[ContextMenu].PlacementTarget.DataContext.OpenFileLocationCommand}"
                        CommandParameter="{Binding $parent[ContextMenu].PlacementTarget.SelectedItem}"/>
              <MenuItem Header="Copy Path"
                        Command="{Binding $parent[ContextMenu].PlacementTarget.DataContext.CopyPathCommand}"
                        CommandParameter="{Binding $parent[ContextMenu].PlacementTarget.SelectedItem}"/>
            </ContextMenu>
          </DataGrid.ContextMenu>
        </DataGrid>

      </Grid><!-- end file view -->

      <!-- ═══════ DUPLICATES VIEW ═══════ -->
      <Grid IsVisible="{Binding IsDuplicateViewActive}" RowDefinitions="Auto,*">

        <!-- Header: Find button + summary + progress -->
        <Border Grid.Row="0" Padding="16,10"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
          <DockPanel>
            <Button DockPanel.Dock="Left"
                    Content="Find Duplicates"
                    Command="{Binding FindDuplicatesCommand}"
                    IsEnabled="{Binding HasScanResult}"
                    Padding="14,7" CornerRadius="8"
                    FontSize="{DynamicResource NxFont12}">
              <Button.Styles>
                <Style Selector="Button">
                  <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                  <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                </Style>
              </Button.Styles>
            </Button>
            <ProgressBar DockPanel.Dock="Right"
                         IsVisible="{Binding IsDuplicateScanning}"
                         IsIndeterminate="True"
                         Width="100" Height="3"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         Background="Transparent"
                         VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DuplicateSummary}"
                       FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"
                       IsVisible="{Binding DuplicateSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          </DockPanel>
        </Border>

        <!-- Body: prompt or results -->
        <Panel Grid.Row="1">
          <!-- Prompt: no scan result yet -->
          <TextBlock Text="Run a scan first, then click 'Find Duplicates' to locate duplicate files."
                     FontSize="{DynamicResource NxFont14}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsVisible="{Binding !HasScanResult}"/>

          <!-- Prompt: scanned but not yet searched -->
          <TextBlock Text="Click 'Find Duplicates' above to scan for duplicate files."
                     FontSize="{DynamicResource NxFont14}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsVisible="{Binding !HasDuplicates}"/>

          <!-- Results -->
          <ScrollViewer IsVisible="{Binding HasDuplicates}">
            <ItemsControl ItemsSource="{Binding Duplicates}" Padding="16">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:DuplicateGroup">
                  <Border Margin="0,0,0,8" Padding="14"
                          CornerRadius="10"
                          Background="{DynamicResource BgElevatedBrush}"
                          BorderBrush="{DynamicResource BorderSubtleBrush}"
                          BorderThickness="1">
                    <StackPanel Spacing="6">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding WastedDisplay}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ColorWarningBrush}"
                                   FontSize="{DynamicResource NxFont13}"/>
                        <TextBlock Text="wasted"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="{DynamicResource NxFont13}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Files.Count, StringFormat='({0} copies)'}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="{DynamicResource NxFont12}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                      <ItemsControl ItemsSource="{Binding Files}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="models:DiskNode">
                            <TextBlock Text="{Binding FullPath}"
                                       FontSize="{DynamicResource NxFont11}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,1"/>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Panel>

      </Grid><!-- end duplicates view -->

      <!-- ═══════ EMPTY STATE OVERLAY ═══════ (renders on top when no scan) -->
      <Border Background="{DynamicResource BgBaseBrush}"
              IsVisible="{Binding ShowEmptyState}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
          <TextBlock Text="&#x1F4BE;"
                     FontSize="56"
                     HorizontalAlignment="Center"
                     Opacity="0.35"/>
          <TextBlock Text="Select a drive above and click Scan to analyze disk usage"
                     FontSize="{DynamicResource NxFont16}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Supports fast scanning on all local file systems"
                     FontSize="{DynamicResource NxFont12}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>

    </Panel><!-- end body Panel -->

    <!-- ── Row 4: Splitter above treemap ──────────────────────────────── -->
    <GridSplitter Grid.Row="4" Height="4" HorizontalAlignment="Stretch"
                  Background="{DynamicResource BorderSubtleBrush}"/>

    <!-- ── Row 5: Treemap (always visible) ───────────────────────────── -->
    <Border Grid.Row="5" Background="{DynamicResource BgBaseBrush}" ClipToBounds="True">
      <Panel>
        <TextBlock Text="Click 'Scan' to analyze disk usage"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   FontSize="{DynamicResource NxFont14}"
                   IsVisible="{Binding !HasScanResult}"/>
        <ctrl:TreemapControl x:Name="TheTreemap"
                             RootNode="{Binding RootNode}"
                             SelectedNode="{Binding SelectedNode}"
                             IsVisible="{Binding HasScanResult}"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"/>
      </Panel>
    </Border>

  </Grid>
</UserControl>
