<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.AutomationView"
             x:DataType="vm:AutomationViewModel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Automation Services"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <Button DockPanel.Dock="Right"
                Classes="nx-btn"
                Command="{Binding SaveCommand}">
          <TextBlock Text="💾 Save All" FontSize="{DynamicResource NxFont12}"/>
        </Button>
      </DockPanel>
    </Border>

    <ScrollViewer>
      <StackPanel Spacing="12" Margin="16" MaxWidth="820">

        <!-- Intro -->
        <TextBlock Text="These services run continuously in the background and automatically manage process priorities, CPU affinity, and memory — no manual intervention required."
                   FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <!-- ══ Foreground Boost ══════════════════════════════════════════ -->
        <Border Padding="16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}">
          <StackPanel Spacing="12">
            <DockPanel>
              <ToggleSwitch DockPanel.Dock="Right"
                            IsChecked="{Binding ForegroundBoostEnabled}"
                            IsEnabled="{Binding Platform.SupportsFindWindow}"
                            VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Left" Spacing="2">
                <TextBlock Text="FOREGROUND BOOST" FontSize="{DynamicResource NxFont10}"
                           FontWeight="Medium" LetterSpacing="0.6"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                <TextBlock Text="Boosts the active window's process to Above Normal priority. Restores when focus moves away."
                           FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </DockPanel>
            <TextBlock Text="Not available on this platform — the OS does not expose foreground-window tracking to Nexus."
                       FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       IsVisible="{Binding !Platform.SupportsFindWindow}"/>
            <StackPanel Spacing="4" IsVisible="{Binding ForegroundBoostEnabled}">
              <TextBlock Text="Excluded processes (comma-separated)"
                         FontSize="{DynamicResource NxFont12}"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBox Text="{Binding ForegroundBoostExclusionsText}"
                       Watermark="e.g. devenv, chrome, winlogon"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ══ IdleThrottle ════════════════════════════════════════════════ -->
        <Border Padding="16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}">
          <StackPanel Spacing="12">
            <DockPanel>
              <ToggleSwitch DockPanel.Dock="Right"
                            IsChecked="{Binding IdleThrottleEnabled}"
                            VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Left" Spacing="2">
                <TextBlock Text="IDLE THROTTLE" FontSize="{DynamicResource NxFont10}"
                           FontWeight="Medium" LetterSpacing="0.6"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                <TextBlock Text="Throttles background processes that have been idle for several consecutive ticks. Restores when they become active again."
                           FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </DockPanel>
            <StackPanel Spacing="10" IsVisible="{Binding IdleThrottleEnabled}">
              <Grid ColumnDefinitions="*,14,*">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="CPU Idle Threshold (%)"
                             FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <Slider Grid.Column="0" Minimum="0.1" Maximum="10"
                            Value="{Binding IdleThrottleCpuThreshold}"/>
                    <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}"
                               Text="{Binding IdleThrottleCpuThreshold, StringFormat='{}{0:F1}%'}"
                               Foreground="{DynamicResource AccentBlueBrush}"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                  </Grid>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                  <TextBlock Text="Idle Ticks Required"
                             FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <NumericUpDown Value="{Binding IdleThrottleIdleTicks}"
                                 Minimum="1" Maximum="20" Increment="1" FormatString="0"/>
                </StackPanel>
              </Grid>
              <CheckBox IsChecked="{Binding IdleThrottleUseEfficiencyMode}"
                        Content="Also enable Efficiency Mode on throttled processes"
                        IsVisible="{Binding Platform.SupportsEfficiencyMode}"/>
              <StackPanel Spacing="4">
                <TextBlock Text="Excluded processes (comma-separated)"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox Text="{Binding IdleThrottleExclusionsText}"
                         Watermark="e.g. audiodg, svchost"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ══ MemoryReclaim ════════════════════════════════════════════════ -->
        <Border Padding="16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}"
                IsVisible="{Binding Platform.SupportsTrimMemory}">
          <StackPanel Spacing="12">
            <DockPanel>
              <ToggleSwitch DockPanel.Dock="Right"
                            IsChecked="{Binding MemoryReclaimEnabled}"
                            VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Left" Spacing="2">
                <TextBlock Text="MEMORY RECLAIM (AUTO)" FontSize="{DynamicResource NxFont10}"
                           FontWeight="Medium" LetterSpacing="0.6"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                <TextBlock Text="Automatically trims process working sets on a timer. Under RAM pressure, trims all background processes. Otherwise trims only large idle processes."
                           FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </DockPanel>
            <Grid ColumnDefinitions="*,14,*,14,*"
                  IsVisible="{Binding MemoryReclaimEnabled}">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Interval (seconds)"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <NumericUpDown Value="{Binding MemoryReclaimInterval}"
                               Minimum="10" Maximum="3600" Increment="10" FormatString="0"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="RAM Pressure Threshold (%)"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Grid ColumnDefinitions="*,Auto">
                  <Slider Grid.Column="0" Minimum="5" Maximum="50"
                          Value="{Binding MemoryReclaimPressurePercent}"/>
                  <TextBlock Grid.Column="1" FontSize="{DynamicResource NxFont11}"
                             Text="{Binding MemoryReclaimPressurePercent, StringFormat='{}{0:F0}%'}"
                             Foreground="{DynamicResource AccentBlueBrush}"
                             VerticalAlignment="Center" Margin="6,0,0,0"/>
                </Grid>
              </StackPanel>
              <StackPanel Grid.Column="4" Spacing="4">
                <TextBlock Text="Min Working Set (MB)"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <NumericUpDown Value="{Binding MemoryReclaimMinWorkingSetMb}"
                               Minimum="10" Maximum="4096" Increment="10" FormatString="0"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- ══ CPU Limiter ══════════════════════════════════════════════ -->
        <Border Padding="16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}"
                IsVisible="{Binding Platform.SupportsCpuAffinity}">
          <StackPanel Spacing="12">
            <DockPanel>
              <ToggleSwitch DockPanel.Dock="Right"
                            IsChecked="{Binding CpuLimiterEnabled}"
                            VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Left" Spacing="2">
                <TextBlock Text="CPU LIMITER" FontSize="{DynamicResource NxFont10}"
                           FontWeight="Medium" LetterSpacing="0.6"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                <TextBlock Text="Temporarily reduces CPU affinity of a process that exceeds a threshold for a sustained period, then restores it."
                           FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </DockPanel>

            <!-- Rules DataGrid -->
            <DataGrid ItemsSource="{Binding CpuLimiterRules}"
                      SelectedItem="{Binding SelectedCpuLimiterRule}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      MinHeight="120">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Process Pattern"
                                    Binding="{Binding ProcessNamePattern}"
                                    Width="*"/>
                <DataGridTextColumn Header="CPU %" Width="60"
                                    Binding="{Binding CpuThresholdPercent}"/>
                <DataGridTextColumn Header="Over (s)" Width="65"
                                    Binding="{Binding OverLimitSeconds}"/>
                <DataGridTextColumn Header="Reduce Cores" Width="90"
                                    Binding="{Binding ReduceByCores}"/>
                <DataGridTextColumn Header="Limit (s)" Width="65"
                                    Binding="{Binding LimitDurationSeconds}"/>
              </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="nx-btn"
                      Command="{Binding AddCpuLimiterRuleCommand}">
                <TextBlock Text="＋ Add Rule" FontSize="{DynamicResource NxFont12}"/>
              </Button>
              <Button Classes="nx-btn"
                      Command="{Binding RemoveCpuLimiterRuleCommand}"
                      CommandParameter="{Binding SelectedCpuLimiterRule}"
                      IsEnabled="{Binding SelectedCpuLimiterRule,
                                  Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="🗑 Remove" FontSize="{DynamicResource NxFont12}"/>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ══ Instance Balancer ════════════════════════════════════════ -->
        <Border Padding="16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}"
                IsVisible="{Binding Platform.SupportsCpuAffinity}">
          <StackPanel Spacing="12">
            <DockPanel>
              <ToggleSwitch DockPanel.Dock="Right"
                            IsChecked="{Binding InstanceBalancerEnabled}"
                            VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Left" Spacing="2">
                <TextBlock Text="INSTANCE BALANCER" FontSize="{DynamicResource NxFont10}"
                           FontWeight="Medium" LetterSpacing="0.6"
                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                <TextBlock Text="Distributes CPU affinity across multiple instances of the same process to prevent core contention."
                           FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </DockPanel>

            <DataGrid ItemsSource="{Binding InstanceBalancerRules}"
                      SelectedItem="{Binding SelectedInstanceBalancerRule}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      MinHeight="120">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Process Pattern"
                                    Binding="{Binding ProcessNamePattern}"
                                    Width="*"/>
                <DataGridTextColumn Header="Algorithm" Width="130"
                                    Binding="{Binding Algorithm}"/>
                <DataGridTextColumn Header="Cores/Instance" Width="100"
                                    Binding="{Binding CoresPerInstance}"/>
              </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="nx-btn"
                      Command="{Binding AddInstanceBalancerRuleCommand}">
                <TextBlock Text="＋ Add Rule" FontSize="{DynamicResource NxFont12}"/>
              </Button>
              <Button Classes="nx-btn"
                      Command="{Binding RemoveInstanceBalancerRuleCommand}"
                      CommandParameter="{Binding SelectedInstanceBalancerRule}"
                      IsEnabled="{Binding SelectedInstanceBalancerRule,
                                  Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="🗑 Remove" FontSize="{DynamicResource NxFont12}"/>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ══ Quiet Hours ══════════════════════════════════════════════════ -->
        <Border Padding="16"
                Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}">
          <StackPanel Spacing="12">
            <DockPanel>
              <ToggleSwitch DockPanel.Dock="Right"
                            IsChecked="{Binding QuietHoursEnabled}"
                            VerticalAlignment="Center"/>
              <StackPanel DockPanel.Dock="Left" Spacing="2">
                <TextBlock Text="QUIET HOURS" FontSize="{DynamicResource NxFont10}"
                           FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"
                           LetterSpacing="1.5"/>
                <TextBlock Text="Suppress notifications during scheduled time windows."
                           FontSize="{DynamicResource NxFont11}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </DockPanel>

            <StackPanel IsVisible="{Binding QuietHoursEnabled}" Spacing="10">

              <!-- Time range -->
              <Grid ColumnDefinitions="Auto,8,120,16,Auto,8,120" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="From"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="2"
                         Text="{Binding QuietHoursStart}"
                         Watermark="HH:mm"
                         Classes="nx-input"
                         FontSize="{DynamicResource NxFont12}"/>
                <TextBlock Grid.Column="4" Text="To"
                           FontSize="{DynamicResource NxFont12}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="6"
                         Text="{Binding QuietHoursEnd}"
                         Watermark="HH:mm"
                         Classes="nx-input"
                         FontSize="{DynamicResource NxFont12}"/>
              </Grid>

              <TextBlock Text="Enter times in 24-hour format (e.g., 22:00 to 07:00). Overnight windows are supported."
                         FontSize="{DynamicResource NxFont10}" TextWrapping="Wrap"
                         Foreground="{DynamicResource TextTertiaryBrush}"/>

              <!-- Days of week -->
              <StackPanel Spacing="4">
                <TextBlock Text="Active days (leave all unchecked for every day):"
                           FontSize="{DynamicResource NxFont11}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <WrapPanel Orientation="Horizontal">
                  <CheckBox Content="Mon" IsChecked="{Binding QuietHoursMon}" FontSize="{DynamicResource NxFont11}" Margin="0,0,8,4"/>
                  <CheckBox Content="Tue" IsChecked="{Binding QuietHoursTue}" FontSize="{DynamicResource NxFont11}" Margin="0,0,8,4"/>
                  <CheckBox Content="Wed" IsChecked="{Binding QuietHoursWed}" FontSize="{DynamicResource NxFont11}" Margin="0,0,8,4"/>
                  <CheckBox Content="Thu" IsChecked="{Binding QuietHoursThu}" FontSize="{DynamicResource NxFont11}" Margin="0,0,8,4"/>
                  <CheckBox Content="Fri" IsChecked="{Binding QuietHoursFri}" FontSize="{DynamicResource NxFont11}" Margin="0,0,8,4"/>
                  <CheckBox Content="Sat" IsChecked="{Binding QuietHoursSat}" FontSize="{DynamicResource NxFont11}" Margin="0,0,8,4"/>
                  <CheckBox Content="Sun" IsChecked="{Binding QuietHoursSun}" FontSize="{DynamicResource NxFont11}" Margin="0,0,0,4"/>
                </WrapPanel>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Bottom padding -->
        <Border Height="16"/>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>

</UserControl>
