<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             x:Class="NexusMonitor.UI.Views.StartupView"
             x:DataType="vm:StartupViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:BoolToEnabledTextConverter x:Key="BoolEnabled"/>
    <conv:BoolToEnabledBrushConverter x:Key="BoolEnabledBrush"/>
  </UserControl.Resources>

  <DockPanel>

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top"
            Padding="16,10"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="Startup Programs"
                   FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,16,0"/>

        <Button DockPanel.Dock="Right"
                Classes="nx-btn"
                Command="{Binding RefreshCommand}"
                Margin="8,0,0,0"
                ToolTip.Tip="Refresh list">
          <TextBlock Text="↺  Refresh" FontSize="{DynamicResource NxFont12}"/>
        </Button>

        <Button DockPanel.Dock="Right"
                Classes="nx-btn"
                Command="{Binding ToggleEnabledCommand}"
                IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                IsVisible="{Binding Platform.SupportsStartupToggle}"
                ToolTip.Tip="Enable or disable selected startup item">
          <TextBlock Text="Toggle" FontSize="{DynamicResource NxFont12}"/>
        </Button>

        <TextBox DockPanel.Dock="Right"
                 Name="SearchBox"
                 Classes="nx-input"
                 Text="{Binding SearchText}"
                 Watermark="Search name, publisher, command…"
                 Width="260"
                 VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <!-- macOS note — Enable/Disable toggle isn't wired up on this platform -->
    <Border DockPanel.Dock="Top"
            Padding="16,6"
            IsVisible="{Binding !Platform.SupportsStartupToggle}"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}">
        <Run Text="Note: "/>
        <Run Text="Enable/disable not yet supported on macOS."
             Foreground="{DynamicResource TextTertiaryBrush}"/>
      </TextBlock>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,6"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <DockPanel>

        <!-- Error message — right-aligned, hidden when empty -->
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding LastError}"
                   IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="{DynamicResource NxFont11}"
                   Foreground="{StaticResource ColorDangerBrush}"
                   VerticalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Spacing="24">
          <TextBlock FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}">
            <Run Text="Total: "/>
            <Run Text="{Binding TotalCount}"   Foreground="{DynamicResource TextPrimaryBrush}"  FontWeight="Medium"/>
          </TextBlock>
          <TextBlock FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextSecondaryBrush}">
            <Run Text="Enabled: "/>
            <Run Text="{Binding EnabledCount}" Foreground="{StaticResource ColorSuccessBrush}" FontWeight="Medium"/>
          </TextBlock>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Table + loading overlay -->
    <Panel>

      <DataGrid x:Name="StartupGrid"
                Classes="nx-grid"
                ItemsSource="{Binding Items}"
                SelectedItem="{Binding SelectedItem}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                CanUserResizeColumns="True"
                CanUserReorderColumns="True"
                IsReadOnly="True"
                ScrollViewer.HorizontalScrollBarVisibility="Auto">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Enable"             Command="{Binding EnableItemCommand}"
                      IsVisible="{Binding Platform.SupportsStartupToggle}"/>
            <MenuItem Header="Disable"            Command="{Binding DisableItemCommand}"
                      IsVisible="{Binding Platform.SupportsStartupToggle}"/>
            <Separator/>
            <MenuItem Header="{Binding Platform.OpenLocationMenuLabel}" Command="{Binding OpenFileLocationCommand}"/>
            <MenuItem Header="Open Registry Key"  Command="{Binding OpenRegistryKeyCommand}"
                      IsVisible="{Binding Platform.SupportsRegistry}"/>
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>

          <!-- Status badge -->
          <DataGridTemplateColumn Header="Status" Width="90" SortMemberPath="IsEnabled">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border CornerRadius="4"
                        Padding="6,2"
                        Margin="4,3"
                        HorizontalAlignment="Center"
                        Background="{Binding IsEnabled, Converter={StaticResource BoolEnabledBrush}}">
                  <TextBlock Text="{Binding IsEnabled, Converter={StaticResource BoolEnabled}}"
                             FontSize="{DynamicResource NxFont10}" FontWeight="Medium"
                             Foreground="White"
                             HorizontalAlignment="Center"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Name"           Binding="{Binding Name}"          SortMemberPath="Name"          Width="1.8*" MinWidth="100" IsReadOnly="True"/>
          <DataGridTextColumn Header="Publisher"      Binding="{Binding Publisher}"     SortMemberPath="Publisher"     Width="1.5*" MinWidth="90"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Location"       Binding="{Binding Location}"      SortMemberPath="Location"      Width="100"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Startup Impact" Binding="{Binding StartupImpact}" SortMemberPath="StartupImpact" Width="135"  IsReadOnly="True"/>
          <DataGridTextColumn Header="Command"        Binding="{Binding Command}"       SortMemberPath="Command"       Width="2.8*" MinWidth="120" IsReadOnly="True"/>

        </DataGrid.Columns>
      </DataGrid>

      <!-- Loading overlay -->
      <Border IsVisible="{Binding IsLoading}"
              Background="{DynamicResource OverlayBgBrush}">
        <TextBlock Text="Loading startup items…"
                   FontSize="{DynamicResource NxFont14}"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Border>

    </Panel>

  </DockPanel>

</UserControl>
