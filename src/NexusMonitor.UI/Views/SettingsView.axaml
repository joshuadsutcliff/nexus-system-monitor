<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <!-- Minimal control theme for circular colour-swatch buttons -->
    <ControlTheme x:Key="SwatchTheme" TargetType="Button">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Width="{TemplateBinding Width}"
                  Height="{TemplateBinding Height}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Background="{TemplateBinding Background}"
                  Cursor="Hand"
                  Opacity="{TemplateBinding Opacity}">
            <Border.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
              </Transitions>
            </Border.Transitions>
          </Border>
        </ControlTemplate>
      </Setter>
      <Style Selector="^:pointerover">
        <Setter Property="Opacity" Value="0.75"/>
      </Style>
      <Style Selector="^:pressed">
        <Setter Property="Opacity" Value="0.5"/>
      </Style>
    </ControlTheme>
  </UserControl.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
  <StackPanel Margin="24" Spacing="16">
    <TextBlock Text="Settings"
               FontSize="{DynamicResource NxFont16}" FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimaryBrush}"/>

    <!-- ===== APPEARANCE ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Appearance" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Dark / Light theme toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Theme" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Affects window chrome, text, and card backgrounds"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" MinWidth="120" VerticalAlignment="Center"
                    SelectedIndex="{Binding ThemeModeIndex}"
                    ItemsSource="{x:Static vm:SettingsViewModel.ThemeModeLabels}"/>
        </Grid>

        <!-- Theme Preset -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Theme Preset" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Apply a coordinated look across all appearance settings"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <ComboBox MinWidth="180"
                      SelectedIndex="{Binding SelectedPresetIndex}"
                      ItemsSource="{Binding PresetNames}"/>
            <Button Classes="nx-btn" Padding="8,5"
                    Click="OnSaveAsPresetClick"
                    ToolTip.Tip="Save current settings as a new preset">
              <TextBlock Text="Save…" FontSize="{DynamicResource NxFont11}"/>
            </Button>
            <Button Classes="nx-btn" Padding="8,5"
                    Command="{Binding DeleteSelectedPresetCommand}"
                    IsVisible="{Binding CanDeleteSelectedPreset}"
                    ToolTip.Tip="Delete this custom preset">
              <TextBlock Text="Delete" FontSize="{DynamicResource NxFont11}"/>
            </Button>
          </StackPanel>
        </Grid>

        <!-- Update Interval -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Metrics Update Interval" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Polling rate for all views and the overlay widget"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" MinWidth="120" VerticalAlignment="Center"
                    ItemsSource="{x:Static vm:SettingsViewModel.UpdateIntervalLabels}"
                    SelectedIndex="{Binding UpdateIntervalIndex}"/>
        </Grid>

      </StackPanel>
    </Border>

    <!-- ===== TYPOGRAPHY ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Typography" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Font family picker -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Font Family" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Applied to all windows and the overlay widget"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" MinWidth="180" VerticalAlignment="Center"
                    MaxDropDownHeight="260"
                    ItemsSource="{x:Static vm:SettingsViewModel.SystemFonts}"
                    SelectedItem="{Binding FontFamily}"/>
        </Grid>

        <!-- Current font preview -->
        <Border Padding="12,8"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="10">
          <TextBlock Text="The quick brown fox jumps over the lazy dog  0123456789"
                     FontSize="{DynamicResource NxFont12}"
                     FontFamily="{Binding FontFamily}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Font size multiplier -->
        <Grid ColumnDefinitions="*,Auto,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Font Size" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Scale all text relative to the default size"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <TextBlock Grid.Column="1"
                     Text="{Binding FontSizeMultiplier, StringFormat='{}{0:P0}'}"
                     FontSize="{DynamicResource NxFont12}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"/>
          <Slider Grid.Column="2"
                  Width="140"
                  Minimum="0.8" Maximum="1.5"
                  TickFrequency="0.05"
                  IsSnapToTickEnabled="True"
                  Value="{Binding FontSizeMultiplier}"
                  VerticalAlignment="Center"/>
        </Grid>

      </StackPanel>
    </Border>

    <!-- ===== ACCENT COLORS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Accent Colors" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Primary accent palette -->
        <TextBlock Text="PRIMARY ACCENT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="Affects: buttons, chart lines, active nav item, toggle state, selections"
                   FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,4"/>

        <!-- Row of accent swatches — dark palette -->
        <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#0A84FF"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#0A84FF"
                  ToolTip.Tip="Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#BF5AF2"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#BF5AF2"
                  ToolTip.Tip="Purple"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#FF375F"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#FF375F"
                  ToolTip.Tip="Pink"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#FF9F0A"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#FF9F0A"
                  ToolTip.Tip="Orange"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#FFD60A"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#FFD60A"
                  ToolTip.Tip="Yellow"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#30D158"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#30D158"
                  ToolTip.Tip="Green"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#5AC8FA"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#5AC8FA"
                  ToolTip.Tip="Teal"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#FF453A"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#FF453A"
                  ToolTip.Tip="Red"/>
          <Button Classes="nx-btn" Height="26" Padding="8,0" Margin="0,0,0,6"
                  Click="OnPickColorClick"
                  ToolTip.Tip="Open color wheel picker">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <!-- Row of accent swatches — light palette -->
        <WrapPanel Orientation="Horizontal" IsVisible="{Binding !IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#007AFF" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#007AFF"
                  ToolTip.Tip="Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#AF52DE" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#AF52DE"
                  ToolTip.Tip="Purple"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#E84393" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#E84393"
                  ToolTip.Tip="Pink"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#E8590C" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#E8590C"
                  ToolTip.Tip="Orange"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#D4A017" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#D4A017"
                  ToolTip.Tip="Amber"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#28A745" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#28A745"
                  ToolTip.Tip="Green"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#0288D1" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#0288D1"
                  ToolTip.Tip="Teal"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="26" Height="26" Margin="0,0,6,6"
                  CornerRadius="13" Background="#DC3545" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetAccentColorCommand}" CommandParameter="#DC3545"
                  ToolTip.Tip="Red"/>
          <Button Classes="nx-btn" Height="26" Padding="8,0" Margin="0,0,0,6"
                  Click="OnPickColorClick"
                  ToolTip.Tip="Open color wheel picker">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>

        <!-- Live preview row showing what the selected accent changes -->
        <Border Padding="12,8"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="10">
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
              <Border Width="10" Height="10" CornerRadius="5"
                      Background="{DynamicResource AccentBlueBrush}"
                      VerticalAlignment="Center"/>
              <TextBlock Text="Buttons" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
              <Border Width="10" Height="10" CornerRadius="2"
                      Background="{DynamicResource AccentBlueDimBrush}"
                      BorderBrush="{DynamicResource AccentBlueBrush}"
                      BorderThickness="1"
                      VerticalAlignment="Center"/>
              <TextBlock Text="Selections" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
              <Border Width="28" Height="10" CornerRadius="5"
                      Background="{DynamicResource AccentBlueBrush}"
                      VerticalAlignment="Center"/>
              <TextBlock Text="Nav" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Aa" FontSize="{DynamicResource NxFont11}" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="Links" FontSize="{DynamicResource NxFont10}"
                         Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
          </WrapPanel>
        </Border>

        <!-- Text accent sub-theme -->
        <TextBlock Text="TEXT ACCENT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,8,0,4"/>
        <TextBlock Text="Separate color for highlighted text, links, and active labels. Leave empty to derive from primary accent."
                   FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,4"/>
        <!-- Text accent swatches — dark palette -->
        <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter=""
                  ToolTip.Tip="Derive from Primary (default)">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#0A84FF"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#0A84FF" ToolTip.Tip="Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#BF5AF2"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#BF5AF2" ToolTip.Tip="Purple"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FF375F"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#FF375F" ToolTip.Tip="Pink"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FF9F0A"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#FF9F0A" ToolTip.Tip="Orange"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FFD60A"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#FFD60A" ToolTip.Tip="Yellow"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#30D158"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#30D158" ToolTip.Tip="Green"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#5AC8FA"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#5AC8FA" ToolTip.Tip="Teal"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FF453A"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#FF453A" ToolTip.Tip="Red"/>
          <Button Classes="nx-btn" Height="22" Padding="8,0" Margin="0,0,0,5"
                  Click="OnPickTextColorClick"
                  ToolTip.Tip="Open color wheel picker for text accent">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <!-- Text accent swatches — light palette -->
        <WrapPanel Orientation="Horizontal" IsVisible="{Binding !IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter=""
                  ToolTip.Tip="Derive from Primary (default)">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#007AFF" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#007AFF" ToolTip.Tip="Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#AF52DE" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#AF52DE" ToolTip.Tip="Purple"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#E84393" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#E84393" ToolTip.Tip="Pink"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#E8590C" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#E8590C" ToolTip.Tip="Orange"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#D4A017" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#D4A017" ToolTip.Tip="Amber"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#28A745" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#28A745" ToolTip.Tip="Green"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#0288D1" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#0288D1" ToolTip.Tip="Teal"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#DC3545" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetTextAccentColorCommand}" CommandParameter="#DC3545" ToolTip.Tip="Red"/>
          <Button Classes="nx-btn" Height="22" Padding="8,0" Margin="0,0,0,5"
                  Click="OnPickTextColorClick"
                  ToolTip.Tip="Open color wheel picker for text accent">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <!-- Text accent preview -->
        <TextBlock FontSize="{DynamicResource NxFont11}" Margin="0,2,0,0">
          <Run Text="Sample text — " Foreground="{DynamicResource TextSecondaryBrush}"/>
          <Run Text="highlighted text uses TextAccent"
               Foreground="{DynamicResource TextAccentBrush}"
               FontWeight="SemiBold"/>
        </TextBlock>


      </StackPanel>
    </Border>

    <!-- ===== BACKGROUND & SURFACE COLORS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Background &amp; Surface Colors" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <TextBlock Text="Override each UI surface independently. Leave a surface empty to use the built-in theme default."
                   FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                   TextWrapping="Wrap"/>

        <!-- WINDOW CHROME row — dark palette (dynamic, preset-aware) -->
        <WrapPanel Orientation="Horizontal" Margin="0,4,0,2"
                   IsVisible="{Binding IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  Command="{Binding SetWindowBgCommand}" CommandParameter=""
                  ToolTip.Tip="Reset to theme default">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <ItemsControl ItemsSource="{Binding DarkSurfaceSwatches}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                        CornerRadius="11" Background="{Binding Hex}"
                        Command="{Binding DataContext.SetWindowBgCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding Hex}" ToolTip.Tip="{Binding Name}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Classes="nx-btn" Height="22" Padding="8,0" Margin="0,0,0,5"
                  Click="OnPickWindowBgClick">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <!-- WINDOW CHROME row — light palette -->
        <WrapPanel Orientation="Horizontal" Margin="0,4,0,2"
                   IsVisible="{Binding !IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  Command="{Binding SetWindowBgCommand}" CommandParameter=""
                  ToolTip.Tip="Reset to theme default">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F5F5FA" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetWindowBgCommand}" CommandParameter="#F5F5FA" ToolTip.Tip="Cloud"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FAF8F5" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetWindowBgCommand}" CommandParameter="#FAF8F5" ToolTip.Tip="Warm Linen"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F0F6FF" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetWindowBgCommand}" CommandParameter="#F0F6FF" ToolTip.Tip="Sky Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F5F0FF" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetWindowBgCommand}" CommandParameter="#F5F0FF" ToolTip.Tip="Lavender"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F0FAF5" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetWindowBgCommand}" CommandParameter="#F0FAF5" ToolTip.Tip="Mint"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FFF0F4" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetWindowBgCommand}" CommandParameter="#FFF0F4" ToolTip.Tip="Rose Quartz"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FFF5EE" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetWindowBgCommand}" CommandParameter="#FFF5EE" ToolTip.Tip="Peach Cream"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#ECEEF2" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetWindowBgCommand}" CommandParameter="#ECEEF2" ToolTip.Tip="Cool Slate"/>
          <Button Classes="nx-btn" Height="22" Padding="8,0" Margin="0,0,0,5"
                  Click="OnPickWindowBgClick">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <Grid ColumnDefinitions="28,10,*,8,Auto" Margin="0,0,0,4">
          <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                  Background="{DynamicResource BgBaseBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"/>
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Window Chrome" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock FontSize="{DynamicResource NxFont10}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       Text="{Binding CustomWindowBgHex}"
                       IsVisible="{Binding CustomWindowBgHex, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="using theme default"
                       FontSize="{DynamicResource NxFont10}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       IsVisible="{Binding CustomWindowBgHex, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
          </StackPanel>
          <Button Grid.Column="4" Classes="nx-btn"
                  Command="{Binding ResetWindowBgCommand}"
                  IsEnabled="{Binding CustomWindowBgHex, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Padding="8,5">
            <TextBlock Text="Reset" FontSize="{DynamicResource NxFont11}"/>
          </Button>
        </Grid>

        <!-- CARDS & CONTENT PANELS row — dark palette (dynamic, preset-aware) -->
        <WrapPanel Orientation="Horizontal" Margin="0,4,0,2"
                   IsVisible="{Binding IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter=""
                  ToolTip.Tip="Reset to theme default">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <ItemsControl ItemsSource="{Binding DarkSurfaceSwatches}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                        CornerRadius="11" Background="{Binding Hex}"
                        Command="{Binding DataContext.SetSurfaceBgCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding Hex}" ToolTip.Tip="{Binding Name}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Classes="nx-btn" Height="22" Padding="8,0" Margin="0,0,0,5"
                  Click="OnPickSurfaceBgClick">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <!-- CARDS & CONTENT PANELS row — light palette -->
        <WrapPanel Orientation="Horizontal" Margin="0,4,0,2"
                   IsVisible="{Binding !IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter=""
                  ToolTip.Tip="Reset to theme default">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F5F5FA" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter="#F5F5FA" ToolTip.Tip="Cloud"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FAF8F5" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter="#FAF8F5" ToolTip.Tip="Warm Linen"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F0F6FF" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter="#F0F6FF" ToolTip.Tip="Sky Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F5F0FF" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter="#F5F0FF" ToolTip.Tip="Lavender"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F0FAF5" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter="#F0FAF5" ToolTip.Tip="Mint"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FFF0F4" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter="#FFF0F4" ToolTip.Tip="Rose Quartz"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FFF5EE" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter="#FFF5EE" ToolTip.Tip="Peach Cream"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#ECEEF2" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSurfaceBgCommand}" CommandParameter="#ECEEF2" ToolTip.Tip="Cool Slate"/>
          <Button Classes="nx-btn" Height="22" Padding="8,0" Margin="0,0,0,5"
                  Click="OnPickSurfaceBgClick">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <Grid ColumnDefinitions="28,10,*,8,Auto" Margin="0,0,0,4">
          <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                  Background="{DynamicResource BgPrimaryBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"/>
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Cards &amp; Content Panels" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock FontSize="{DynamicResource NxFont10}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       Text="{Binding CustomSurfaceBgHex}"
                       IsVisible="{Binding CustomSurfaceBgHex, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="using theme default"
                       FontSize="{DynamicResource NxFont10}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       IsVisible="{Binding CustomSurfaceBgHex, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
          </StackPanel>
          <Button Grid.Column="4" Classes="nx-btn"
                  Command="{Binding ResetSurfaceBgCommand}"
                  IsEnabled="{Binding CustomSurfaceBgHex, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Padding="8,5">
            <TextBlock Text="Reset" FontSize="{DynamicResource NxFont11}"/>
          </Button>
        </Grid>

        <!-- SIDEBAR & NAVIGATION row — dark palette (dynamic, preset-aware) -->
        <WrapPanel Orientation="Horizontal" Margin="0,4,0,2"
                   IsVisible="{Binding IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter=""
                  ToolTip.Tip="Reset to theme default">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <ItemsControl ItemsSource="{Binding DarkSurfaceSwatches}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                        CornerRadius="11" Background="{Binding Hex}"
                        Command="{Binding DataContext.SetSidebarBgCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding Hex}" ToolTip.Tip="{Binding Name}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Classes="nx-btn" Height="22" Padding="8,0" Margin="0,0,0,5"
                  Click="OnPickSidebarBgClick">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <!-- SIDEBAR & NAVIGATION row — light palette -->
        <WrapPanel Orientation="Horizontal" Margin="0,4,0,2"
                   IsVisible="{Binding !IsDarkActive}">
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="Transparent"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter=""
                  ToolTip.Tip="Reset to theme default">
            <Button.Styles>
              <Style Selector="Button">
                <Setter Property="BorderThickness" Value="1"/>
              </Style>
            </Button.Styles>
          </Button>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F5F5FA" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter="#F5F5FA" ToolTip.Tip="Cloud"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FAF8F5" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter="#FAF8F5" ToolTip.Tip="Warm Linen"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F0F6FF" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter="#F0F6FF" ToolTip.Tip="Sky Blue"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F5F0FF" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter="#F5F0FF" ToolTip.Tip="Lavender"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#F0FAF5" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter="#F0FAF5" ToolTip.Tip="Mint"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FFF0F4" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter="#FFF0F4" ToolTip.Tip="Rose Quartz"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#FFF5EE" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter="#FFF5EE" ToolTip.Tip="Peach Cream"/>
          <Button Theme="{StaticResource SwatchTheme}" Width="22" Height="22" Margin="0,0,5,5"
                  CornerRadius="11" Background="#ECEEF2" BorderBrush="#DDDDDD" BorderThickness="1"
                  Command="{Binding SetSidebarBgCommand}" CommandParameter="#ECEEF2" ToolTip.Tip="Cool Slate"/>
          <Button Classes="nx-btn" Height="22" Padding="8,0" Margin="0,0,0,5"
                  Click="OnPickSidebarBgClick">
            <TextBlock Text="Pick Color…" FontSize="{DynamicResource NxFont11}" VerticalAlignment="Center"/>
          </Button>
        </WrapPanel>
        <Grid ColumnDefinitions="28,10,*,8,Auto" Margin="0,0,0,4">
          <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                  Background="{DynamicResource GlassBgBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"/>
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="Sidebar &amp; Navigation" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock FontSize="{DynamicResource NxFont10}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       Text="{Binding CustomSidebarBgHex}"
                       IsVisible="{Binding CustomSidebarBgHex, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="using theme default"
                       FontSize="{DynamicResource NxFont10}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       IsVisible="{Binding CustomSidebarBgHex, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
          </StackPanel>
          <Button Grid.Column="4" Classes="nx-btn"
                  Command="{Binding ResetSidebarBgCommand}"
                  IsEnabled="{Binding CustomSidebarBgHex, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Padding="8,5">
            <TextBlock Text="Reset" FontSize="{DynamicResource NxFont11}"/>
          </Button>
        </Grid>

      </StackPanel>
    </Border>

    <!-- ===== CRYSTAL GLASS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Crystal Glass" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Main glass toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Crystal Glass Effect" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Full-window refraction with specular rim lights and OS backdrop blur"
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle" IsChecked="{Binding IsGlassEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>

        <!-- Glass Opacity slider -->
        <StackPanel IsEnabled="{Binding IsGlassEnabled}" Spacing="2">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Glass Opacity" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="1" Text="{Binding GlassOpacity, StringFormat='{}{0:P0}'}"
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"/>
          </Grid>
          <Slider Minimum="0.0" Maximum="1.0" Value="{Binding GlassOpacity}"
                  TickFrequency="0.05" IsSnapToTickEnabled="True"
                  Margin="0,2,0,0"/>
          <TextBlock Text="0% = fully see-through  ·  100% = solid"
                     FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                     Margin="0,0,0,4"/>
        </StackPanel>

        <!-- Backdrop blur mode -->
        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding IsGlassEnabled}">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Backdrop Blur Mode" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="Acrylic  ·  Mica  ·  Blur  ·  None"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" MinWidth="110" VerticalAlignment="Center"
                    ItemsSource="{x:Static vm:SettingsViewModel.BackdropModes}"
                    SelectedItem="{Binding BackdropBlurMode}"/>
        </Grid>

        <!-- Specular highlights sub-section -->
        <TextBlock Text="SPECULAR HIGHLIGHTS" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,4"/>
        <StackPanel IsEnabled="{Binding IsGlassEnabled}" Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="Specular Rim Lights" FontSize="{DynamicResource NxFont13}"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Text="3-layer white edge glow (wash + sharp rim + prismatic shimmer)"
                         FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                         TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>
            <ToggleButton Grid.Column="1" Classes="nx-toggle" IsChecked="{Binding IsSpecularEnabled}"
                          VerticalAlignment="Center"/>
          </Grid>
          <StackPanel IsEnabled="{Binding IsSpecularEnabled}" Spacing="2">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Intensity" FontSize="{DynamicResource NxFont12}"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock Grid.Column="1" Text="{Binding SpecularIntensity, StringFormat='{}{0:P0}'}"
                         FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"/>
            </Grid>
            <Slider Minimum="0.0" Maximum="1.0" Value="{Binding SpecularIntensity}"
                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                    Margin="0,2,0,4"/>
          </StackPanel>
        </StackPanel>

        <!-- Smart wallpaper tint -->
        <TextBlock Text="SMART TINT" FontSize="{DynamicResource NxFont11}" FontWeight="Medium" LetterSpacing="0.6"
                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,4"/>
        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding IsGlassEnabled}">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Smart Wallpaper Tint" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Automatically adjusts glass opacity based on wallpaper brightness"
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle" IsChecked="{Binding SmartTintEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>

      </StackPanel>
    </Border>

    <!-- ===== DESKTOP OVERLAY ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Desktop Overlay" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Floating Monitor Widget" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Always-on-top overlay — CPU, RAM, network, GPU. Mirrors main glass settings."
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle" IsChecked="{Binding ShowOverlayWidget}"
                        VerticalAlignment="Center"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- ===== NOTIFICATIONS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Notifications" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Desktop Alert Notifications" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Show a Windows toast when an alert rule threshold is triggered"
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding DesktopNotificationsEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- ===== SYSTEM TRAY ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="System Tray" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Close behaviour -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="When Pressing the Close Button" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Default action when you click the × button on the main window"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" MinWidth="180" VerticalAlignment="Center"
                    ItemsSource="{x:Static vm:SettingsViewModel.CloseActionLabels}"
                    SelectedIndex="{Binding CloseActionIndex}"/>
        </Grid>

        <!-- Show tray icon -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Show System Tray Icon" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Enables the tray icon and minimize-to-tray behavior"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding MinimizeToTray}"
                        VerticalAlignment="Center"/>
        </Grid>

        <!-- Hide widget on minimize -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Hide Widget When Minimizing to Tray" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Hides the desktop overlay widget when the app goes to tray"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding HideWidgetOnMinimize}"
                        VerticalAlignment="Center"/>
        </Grid>

        <!-- Default tab on launch -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Default Tab on Launch" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Which tab to show when the app starts"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" MinWidth="180" VerticalAlignment="Center"
                    ItemsSource="{x:Static vm:SettingsViewModel.DefaultTabLabels}"
                    SelectedIndex="{Binding DefaultTabIndex}"/>
        </Grid>

        <TextBlock Text="Tip: Right-click the tray icon for quick access to Show / Widget / Exit"
                   FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                   TextWrapping="Wrap"/>

      </StackPanel>
    </Border>

    <!-- ===== METRICS & HISTORY ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Metrics &amp; History" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Record System Metrics" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Saves CPU, memory, disk, network, and GPU data to a local SQLite database for the History tab. Uses ~50–100 MB steady state."
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding MetricsEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>

      </StackPanel>
    </Border>

    <!-- ===== ANOMALY DETECTION ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Anomaly Detection" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Enable toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Automatic Anomaly Detection" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Detects CPU/memory/GPU spikes, network anomalies, and new connections via statistical analysis"
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding AnomalyDetectionEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>

        <!-- In-app anomaly notifications -->
        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding AnomalyDetectionEnabled}">
          <StackPanel Grid.Column="0">
            <TextBlock Text="In-App Notifications" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="Show pill notifications inside the app when anomalies are detected"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding AnomalyNotificationsEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>

        <!-- Sensitivity -->
        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding AnomalyDetectionEnabled}">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Sensitivity" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="Low = fewer alerts  ·  High = more alerts (may include false positives)"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,2,0,0"/>
          </StackPanel>
          <ComboBox Grid.Column="1" MinWidth="110" VerticalAlignment="Center"
                    ItemsSource="{x:Static vm:SettingsViewModel.AnomalySensitivities}"
                    SelectedItem="{Binding AnomalySensitivity}"/>
        </Grid>

        <!-- Cooldown -->
        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding AnomalyDetectionEnabled}">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Cooldown (seconds)" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="Minimum time between repeated events for the same metric"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,2,0,0"/>
          </StackPanel>
          <NumericUpDown Grid.Column="1" Width="110" VerticalAlignment="Center"
                         Value="{Binding AnomalyCooldownSeconds}"
                         Minimum="10" Maximum="3600" Increment="10"
                         FormatString="0"/>
        </Grid>

        <!-- Events retention -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Events Retention (days)" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="How long to keep detected events in the database"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,2,0,0"/>
          </StackPanel>
          <NumericUpDown Grid.Column="1" Width="110" VerticalAlignment="Center"
                         Value="{Binding MetricsEventsRetentionDays}"
                         Minimum="1" Maximum="3650" Increment="30"
                         FormatString="0"/>
        </Grid>

        <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                   TextWrapping="Wrap">
          <Run Text="Note: "/>
          <Run Text="All changes take effect immediately. View detected anomalies in the History tab."
               Foreground="{DynamicResource TextTertiaryBrush}"/>
        </TextBlock>

      </StackPanel>
    </Border>

    <!-- ===== TELEMETRY ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Telemetry" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Prometheus endpoint toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Prometheus Endpoint" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Exposes system metrics at /metrics for Telegraf, Grafana, or any Prometheus scraper"
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding PrometheusEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>

        <!-- Port picker -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Port" FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="Default: 9182  ·  Range: 1024–65535"
                       FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,2,0,0"/>
          </StackPanel>
          <NumericUpDown Grid.Column="1"
                         Width="110" VerticalAlignment="Center"
                         Value="{Binding PrometheusPort}"
                         Minimum="1024" Maximum="65535" Increment="1"
                         FormatString="0"
                         IsEnabled="{Binding PrometheusEnabled}"/>
        </Grid>

        <!-- Status indicator -->
        <Border Padding="10,6"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="8">
          <TextBlock Text="{Binding PrometheusStatusText}"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     FontFamily="Consolas,Menlo,monospace"/>
        </Border>

        <!-- Setup Guide button -->
        <Button Classes="nx-btn" Click="OnOpenSetupGuideClick" HorizontalAlignment="Left">
          <TextBlock Text="Open Setup Guide — Telegraf &amp; Grafana" FontSize="{DynamicResource NxFont11}"/>
        </Button>

        <!-- Metric list hint -->
        <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                   TextWrapping="Wrap">
          <Run Text="Exported metrics: "/>
          <Run Text="nexus_cpu_*  nexus_memory_*  nexus_disk_*  nexus_network_*  nexus_gpu_*  nexus_alert_events_total"
               FontFamily="Consolas,Menlo,monospace" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </TextBlock>

        <!-- ── Telegraf Integration ──────────────────────────────────────── -->
        <Separator Margin="0,6,0,0"/>

        <TextBlock Text="TELEGRAF INTEGRATION" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                   LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,4"/>

        <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,6">
          Paste the snippet below into your <Run Text="telegraf.conf" FontFamily="Consolas,Menlo,monospace"
               Foreground="{DynamicResource TextSecondaryBrush}"/> or save it as a file
          in Telegraf's <Run Text="conf.d" FontFamily="Consolas,Menlo,monospace"
               Foreground="{DynamicResource TextSecondaryBrush}"/> directory.
          The port updates automatically if you change it above.
        </TextBlock>

        <!-- Config preview box -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="2">
          <TextBox IsReadOnly="True"
                   AcceptsReturn="True"
                   Text="{Binding TelegrafConfig}"
                   FontFamily="Consolas,Menlo,monospace"
                   FontSize="{DynamicResource NxFont10}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Background="Transparent"
                   BorderThickness="0"
                   MaxHeight="210"
                   TextWrapping="NoWrap"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   Padding="8,6"/>
        </Border>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="nx-btn" Click="OnCopyTelegrafConfigClick">
            <TextBlock Text="Copy to Clipboard" FontSize="{DynamicResource NxFont11}"/>
          </Button>
          <Button Classes="nx-btn" Click="OnSaveTelegrafConfigClick">
            <TextBlock Text="Save .conf…" FontSize="{DynamicResource NxFont11}"/>
          </Button>
        </StackPanel>

        <!-- ── Grafana Dashboard ──────────────────────────────────────────── -->
        <Separator Margin="0,6,0,0"/>

        <TextBlock Text="GRAFANA DASHBOARD" FontSize="{DynamicResource NxFont11}" FontWeight="Medium"
                   LetterSpacing="0.6" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,4"/>

        <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,8">
          A pre-built dashboard covering CPU, memory, disk, network, GPU, and alerts.
          Save the JSON file, then import it in Grafana via
          <Run Text="Dashboards → Import → Upload JSON file" FontWeight="Medium"
               Foreground="{DynamicResource TextSecondaryBrush}"/>.
          When prompted, select your Prometheus datasource pointed at the endpoint above.
        </TextBlock>

        <!-- Step list -->
        <Border Padding="12,8"
                Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="8"
                Margin="0,0,0,8">
          <StackPanel Spacing="5">
            <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}">
              <Run Text="1." FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Run Text=" Enable the Prometheus endpoint above and note the port."/>
            </TextBlock>
            <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}">
              <Run Text="2." FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Run Text=" In Grafana, add a Prometheus datasource pointed at "/>
              <Run Text="http://localhost:{port}/metrics" FontFamily="Consolas,Menlo,monospace"
                   Foreground="{DynamicResource TextSecondaryBrush}"/><Run Text="."/>
            </TextBlock>
            <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}">
              <Run Text="3." FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Run Text=" Save the dashboard JSON below and import it into Grafana."/>
            </TextBlock>
            <TextBlock FontSize="{DynamicResource NxFont10}" Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="0,2,0,0">
              <Run Text="Panels: " FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Run Text="CPU total + per core · Memory bytes + gauge · Disk I/O + activity + space · Network throughput · GPU usage + memory · Alert events + process/thread/temp stats"/>
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- Export buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="nx-btn" Click="OnSaveGrafanaDashboardClick">
            <TextBlock Text="Save Dashboard JSON…" FontSize="{DynamicResource NxFont11}"/>
          </Button>
          <Button Classes="nx-btn" Click="OnCopyGrafanaDashboardClick">
            <TextBlock Text="Copy JSON to Clipboard" FontSize="{DynamicResource NxFont11}"/>
          </Button>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- ===== WEBHOOK NOTIFICATIONS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Webhook Notifications" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Enable toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Enable Webhook" FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Send alert events via HTTP POST to Discord, Slack, or any webhook endpoint"
                       FontSize="{DynamicResource NxFont11}" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" Margin="0,2,0,0"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding WebhookEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>

        <!-- URL -->
        <StackPanel Spacing="4" IsEnabled="{Binding WebhookEnabled}">
          <TextBlock Text="Webhook URL" FontSize="{DynamicResource NxFont12}"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBox Text="{Binding WebhookUrl}"
                   Watermark="https://discord.com/api/webhooks/..."
                   FontSize="{DynamicResource NxFont12}"/>
        </StackPanel>

        <!-- Secret -->
        <StackPanel Spacing="4" IsEnabled="{Binding WebhookEnabled}">
          <TextBlock Text="Secret Header (optional)" FontSize="{DynamicResource NxFont12}"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBox Text="{Binding WebhookSecret}"
                   PasswordChar="&#x2022;"
                   Watermark="Sent as X-Webhook-Secret header"
                   FontSize="{DynamicResource NxFont12}"/>
        </StackPanel>

        <!-- Event type checkboxes -->
        <StackPanel Spacing="6" IsEnabled="{Binding WebhookEnabled}">
          <TextBlock Text="Forward Events" FontSize="{DynamicResource NxFont12}"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <CheckBox IsChecked="{Binding WebhookAlerts}"
                    Content="Threshold alerts" FontSize="{DynamicResource NxFont12}"/>
          <CheckBox IsChecked="{Binding WebhookAnomalies}"
                    Content="Anomaly detections" FontSize="{DynamicResource NxFont12}"/>
        </StackPanel>

        <!-- Test button + status -->
        <StackPanel Spacing="6">
          <Button Classes="nx-btn" Command="{Binding SendTestWebhookCommand}"
                  IsEnabled="{Binding WebhookEnabled}"
                  HorizontalAlignment="Left">
            <TextBlock Text="Send Test Webhook" FontSize="{DynamicResource NxFont11}"/>
          </Button>
          <TextBlock Text="{Binding WebhookTestStatus}"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     IsVisible="{Binding WebhookTestStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- ===== RESOURCE PREDICTIONS ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Resource Predictions" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Enable toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="2">
            <TextBlock Text="Enable Resource Predictions"
                       FontSize="{DynamicResource NxFont13}" FontWeight="Medium"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Forecast disk and memory depletion from historical trends (requires metrics collection)"
                       FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding PredictionsEnabled}"
                        VerticalAlignment="Center"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- ===== SAVED PROCESS PREFERENCES ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Saved Process Preferences"
                   FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="These settings are applied automatically each time the process launches. Right-click a process to remember its priority."
                   FontSize="{DynamicResource NxFont10}"
                   Foreground="{DynamicResource TextTertiaryBrush}"/>
        <Separator/>

        <DataGrid ItemsSource="{Binding SavedPreferences}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  MinHeight="80"
                  MaxHeight="280"
                  Background="Transparent"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource BorderSubtleBrush}">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Process" Binding="{Binding ExeName}" Width="*" IsReadOnly="True"/>
            <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="100" IsReadOnly="True"/>
            <DataGridTextColumn Header="IO Priority" Binding="{Binding IoPriority}" Width="90" IsReadOnly="True"/>
            <DataGridTextColumn Header="Efficiency" Binding="{Binding EfficiencyMode}" Width="80" IsReadOnly="True"/>
            <DataGridTextColumn Header="Modified" Binding="{Binding ModifiedUtc, StringFormat='{}{0:yyyy-MM-dd}'}" Width="90" IsReadOnly="True"/>
            <DataGridTemplateColumn Width="36" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Classes="nx-btn-icon"
                          Command="{Binding $parent[UserControl].DataContext.DeletePreferenceCommand}"
                          CommandParameter="{Binding}"
                          ToolTip.Tip="Remove this preference">
                    <TextBlock Text="✕" Foreground="{DynamicResource ColorDangerBrush}"
                               FontSize="{DynamicResource NxFont11}"/>
                  </Button>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="nx-btn"
                  Command="{Binding RefreshPreferencesCommand}">
            <TextBlock Text="↻ Refresh" FontSize="{DynamicResource NxFont11}"/>
          </Button>
          <Button Classes="nx-btn-danger"
                  Command="{Binding ClearAllPreferencesCommand}"
                  IsEnabled="{Binding SavedPreferences.Count, Converter={x:Static ObjectConverters.IsNotNull}}"
                  ToolTip.Tip="Remove all saved process preferences">
            <TextBlock Text="Clear All" FontSize="{DynamicResource NxFont11}"/>
          </Button>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- ===== UPDATES ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <StackPanel Spacing="12">
        <TextBlock Text="Updates" FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Separator/>

        <!-- Enable toggle -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="2">
            <TextBlock Text="Check for Updates"
                       FontSize="{DynamicResource NxFont13}" FontWeight="Medium"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Periodically checks GitHub for newer releases. Never downloads or installs anything automatically."
                       FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
          </StackPanel>
          <ToggleButton Grid.Column="1" Classes="nx-toggle"
                        IsChecked="{Binding CheckForUpdates}"
                        VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Text="{Binding UpdateAvailableText}"
                   FontSize="{DynamicResource NxFont11}"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding UpdateAvailableText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
      </StackPanel>
    </Border>

    <!-- Experimental -->
    <TextBlock Text="Experimental" FontSize="{DynamicResource NxFont14}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,16,0,4"/>
    <CheckBox IsChecked="{Binding EnablePageEngine}"
              Content="Enable page engine — Dashboard renders via the new layout engine (takes effect after restart)"
              FontSize="{DynamicResource NxFont12}"/>

    <!-- ===== ABOUT ===== -->
    <Border Padding="16"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerLG}">
      <Grid ColumnDefinitions="Auto,16,*">
        <!-- Icon -->
        <Image Grid.Column="0"
               Source="avares://NexusMonitor/Assets/nexus-icon-256.png"
               Width="48" Height="48"
               VerticalAlignment="Center"/>
        <!-- Info + button -->
        <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
          <TextBlock Text="Nexus System Monitor"
                     FontSize="{DynamicResource NxFont14}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="AboutVersionText"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
          <TextBlock Text="MIT License · Open Source · Cross-Platform"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
          <Button Classes="nx-btn" Click="OnAboutClick"
                  HorizontalAlignment="Left" Padding="10,4" Margin="0,8,0,0">
            <TextBlock Text="About Nexus System Monitor…" FontSize="{DynamicResource NxFont11}"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

  </StackPanel>
  </ScrollViewer>

</UserControl>
