<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:conv="using:NexusMonitor.UI.Converters"
             xmlns:models="using:NexusMonitor.Core.Models"
             x:Class="NexusMonitor.UI.Views.HistoryView"
             x:DataType="vm:HistoryViewModel"
             x:CompileBindings="False">

  <Grid RowDefinitions="Auto,*">

    <!-- ===== TOOLBAR ===== -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgSecondaryBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto">

        <!-- Range selector -->
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="Range:"
                     FontSize="{DynamicResource NxFont12}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0"/>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is1hActive}"
                  Command="{Binding Load1hCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 1 hour (raw data)">
            <TextBlock Text="1h" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is6hActive}"
                  Command="{Binding Load6hCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 6 hours (1-min rollups)">
            <TextBlock Text="6h" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is24hActive}"
                  Command="{Binding Load24hCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 24 hours (1-min rollups)">
            <TextBlock Text="24h" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is7dActive}"
                  Command="{Binding Load7dCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 7 days (5-min rollups)">
            <TextBlock Text="7d" FontSize="{DynamicResource NxFont12}"/>
          </Button>
          <Button Classes="nx-btn-ghost" Classes.active="{Binding Is30dActive}"
                  Command="{Binding Load30dCommand}"
                  Padding="12,6" CornerRadius="8"
                  ToolTip.Tip="Last 30 days (1-hour rollups)">
            <TextBlock Text="30d" FontSize="{DynamicResource NxFont12}"/>
          </Button>

          <Border Width="1" Background="{DynamicResource GlassBorderBrush}"
                  Margin="6,0" VerticalAlignment="Stretch"/>

          <!-- Refresh -->
          <Button Classes="nx-btn-ghost"
                  Command="{Binding RefreshCommand}"
                  Padding="10,6" CornerRadius="8"
                  ToolTip.Tip="Refresh">
            <TextBlock Text="↺" FontSize="{DynamicResource NxFont13}"/>
          </Button>
        </StackPanel>

        <!-- Right: status + DB size -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <!-- Loading indicator -->
          <TextBlock Text="Loading…"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource AccentBlueBrush}"
                     IsVisible="{Binding IsLoading}"
                     VerticalAlignment="Center"/>
          <!-- DB size -->
          <TextBlock Text="{Binding DbInfoText}"
                     FontSize="{DynamicResource NxFont11}"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     IsVisible="{Binding DbInfoText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     VerticalAlignment="Center"/>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ===== CONTENT ===== -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="16,12" Spacing="10">

        <!-- Metrics not enabled banner -->
        <Border IsVisible="{Binding MetricsEnabled, Converter={x:Static BoolConverters.Not}}"
                Padding="16"
                Background="#200A84FF"
                BorderBrush="{DynamicResource AccentBlueBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerLG}">
          <StackPanel Spacing="6">
            <TextBlock Text="Metrics recording is not enabled"
                       FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBlueBrush}"/>
            <TextBlock Text="Enable 'Record System Metrics' in Settings → Metrics &amp; History to start collecting historical data. Charts and the top-process table will populate after a minute of recording."
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <!-- Status text -->
        <TextBlock Text="{Binding StatusText}"
                   FontSize="{DynamicResource NxFont12}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,4"
                   TextWrapping="Wrap"/>

        <!-- ── CPU ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="CPU Usage"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding CpuSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding CpuYAxes}"
                                Height="130"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── Memory ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="Memory Used (GB)"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding MemSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding MemYAxes}"
                                Height="130"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── Disk I/O ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Disk I/O (MB/s)"
                         FontSize="{DynamicResource NxFont13}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <!-- Legend -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <Border Width="10" Height="3" Background="{StaticResource ColorWarningBrush}" CornerRadius="2"/>
                  <TextBlock Text="Read" FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <Border Width="10" Height="3" Background="{StaticResource ColorDangerBrush}" CornerRadius="2"/>
                  <TextBlock Text="Write" FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
              </StackPanel>
            </Grid>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding DiskSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding DiskYAxes}"
                                Height="130"
                                Margin="0,8,0,0"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── Network ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Network (MB/s)"
                         FontSize="{DynamicResource NxFont13}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <!-- Legend -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <Border Width="10" Height="3" Background="{StaticResource ColorInfoBrush}" CornerRadius="2"/>
                  <TextBlock Text="Send" FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <Border Width="10" Height="3" Background="{StaticResource ProcDotNetBrush}" CornerRadius="2"/>
                  <TextBlock Text="Recv" FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
              </StackPanel>
            </Grid>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding NetSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding NetYAxes}"
                                Height="130"
                                Margin="0,8,0,0"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── GPU ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="GPU Usage"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding GpuSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding GpuYAxes}"
                                Height="130"
                                Background="Transparent"
                                AnimationsSpeed="0:0:0.15"/>
          </Grid>
        </Border>

        <!-- ── Top Processes ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12"
                IsVisible="{Binding HasData}">
          <StackPanel Spacing="8">
            <TextBlock Text="Top Processes (by avg CPU)"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>

            <!-- Column headers -->
            <Grid ColumnDefinitions="*,80,80,90" Margin="0,4,0,0">
              <TextBlock Grid.Column="0" Text="Process"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="Avg CPU"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         FontWeight="SemiBold"
                         TextAlignment="Right"/>
              <TextBlock Grid.Column="2" Text="Peak CPU"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         FontWeight="SemiBold"
                         TextAlignment="Right"/>
              <TextBlock Grid.Column="3" Text="Avg Mem"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         FontWeight="SemiBold"
                         TextAlignment="Right"/>
            </Grid>

            <Border Height="1" Background="{DynamicResource GlassBorderBrush}"/>

            <!-- Process rows -->
            <ItemsControl ItemsSource="{Binding TopProcesses}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,80,80,90" Margin="0,3">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Name}"
                               FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding AvgCpuPercent, StringFormat='{}{0:F1}%'}"
                               FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource AccentBlueBrush}"
                               TextAlignment="Right"
                               FontFamily="{StaticResource FontMono}"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding PeakCpuPercent, StringFormat='{}{0:F1}%'}"
                               FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Right"
                               FontFamily="{StaticResource FontMono}"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding AvgMemMb, StringFormat='{}{0:F0} MB'}"
                               FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Right"
                               FontFamily="{StaticResource FontMono}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>

        <!-- ── Resource Incidents (classified bottleneck events) ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <StackPanel Spacing="8">

            <!-- Card header -->
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Resource Incidents"
                           FontSize="{DynamicResource NxFont13}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <!-- Count badge -->
                <Border Background="{DynamicResource AccentBlueDimBrush}"
                        BorderBrush="{DynamicResource AccentBlueBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8,2"
                        IsVisible="{Binding IncidentCount}">
                  <TextBlock Text="{Binding IncidentCount}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource AccentBlueBrush}"
                             FontFamily="{StaticResource FontMono}"/>
                </Border>
              </StackPanel>

              <!-- Classification filter -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Filter:"
                           FontSize="{DynamicResource NxFont11}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
                <ComboBox Width="160"
                          ItemsSource="{x:Static vm:HistoryViewModel.ClassificationFilters}"
                          SelectedItem="{Binding ClassificationFilter}"
                          FontSize="{DynamicResource NxFont11}"/>
              </StackPanel>
            </Grid>

            <!-- Sub-header explanation -->
            <TextBlock Text="Classified resource incidents: each entry covers a full spike from start to resolution."
                       FontSize="{DynamicResource NxFont11}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- Empty state -->
            <TextBlock Text="No resource incidents recorded in this time range."
                       FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       IsVisible="{Binding !HasIncidents}"
                       Margin="0,4,0,4"/>

            <!-- Column headers -->
            <Grid ColumnDefinitions="130,55,130,70,*"
                  Margin="0,4,0,0"
                  IsVisible="{Binding ResourceIncidents.Count}">
              <TextBlock Grid.Column="0" Text="Time"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="Res"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="Classification"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="3" Text="Peak / Dur"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="4" Text="Summary"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="SemiBold"/>
            </Grid>

            <Border Height="1"
                    Background="{DynamicResource GlassBorderBrush}"
                    IsVisible="{Binding ResourceIncidents.Count}"/>

            <!-- Incident rows -->
            <ItemsControl ItemsSource="{Binding ResourceIncidents}"
                          IsVisible="{Binding ResourceIncidents.Count}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:ResourceEvent">
                  <Grid ColumnDefinitions="130,55,130,70,*" Margin="0,4">
                    <!-- Time -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding Timestamp.LocalDateTime, StringFormat='{}{0:MM/dd HH:mm:ss}'}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{StaticResource FontMono}"
                               VerticalAlignment="Center"/>
                    <!-- Resource badge -->
                    <Border Grid.Column="1"
                            CornerRadius="4" Padding="5,2"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Background="{DynamicResource BorderSubtleBrush}">
                      <TextBlock Text="{Binding Resource,
                                     Converter={x:Static conv:ResourceTypeToLabelConverter.Instance}}"
                                 FontSize="9" FontWeight="Bold"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                    <!-- Classification badge -->
                    <Border Grid.Column="2"
                            CornerRadius="4" Padding="5,2"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Background="{Binding Classification,
                                Converter={x:Static conv:EventClassificationToBrushConverter.Instance},
                                ConverterParameter=dim}">
                      <TextBlock Text="{Binding Classification,
                                     Converter={x:Static conv:EventClassificationToLabelConverter.Instance}}"
                                 FontSize="9" FontWeight="Bold"
                                 Foreground="White"/>
                    </Border>
                    <!-- Peak / Duration -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="1">
                      <TextBlock Text="{Binding PeakUsagePercent, StringFormat='{}{0:F0}% peak'}"
                                 FontSize="{DynamicResource NxFont10}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 FontFamily="{StaticResource FontMono}"/>
                      <TextBlock Text="{Binding Duration.TotalSeconds, StringFormat='{}{0:F0}s'}"
                                 FontSize="{DynamicResource NxFont10}"
                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                 FontFamily="{StaticResource FontMono}"/>
                    </StackPanel>
                    <!-- Summary -->
                    <TextBlock Grid.Column="4"
                               Text="{Binding Summary}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Summary}"
                               VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>

        <!-- ── Events Timeline (anomaly alerts) ── -->
        <Border Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="{StaticResource CornerLG}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1"
                Padding="16,12">
          <StackPanel Spacing="8">

            <!-- Card header: title + event count + type filter -->
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Anomaly Alerts"
                           FontSize="{DynamicResource NxFont13}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <!-- Count badge -->
                <Border Background="{DynamicResource AccentBlueDimBrush}"
                        BorderBrush="{DynamicResource AccentBlueBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8,2"
                        IsVisible="{Binding HasEvents}">
                  <TextBlock Text="{Binding EventCount}"
                             FontSize="{DynamicResource NxFont11}"
                             Foreground="{DynamicResource AccentBlueBrush}"
                             FontFamily="{StaticResource FontMono}"/>
                </Border>
              </StackPanel>

              <!-- Event type filter -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Filter:"
                           FontSize="{DynamicResource NxFont11}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
                <ComboBox Width="140"
                          ItemsSource="{x:Static vm:HistoryViewModel.EventTypeFilters}"
                          SelectedItem="{Binding EventTypeFilter}"
                          FontSize="{DynamicResource NxFont11}"/>
              </StackPanel>
            </Grid>

            <!-- Empty state -->
            <TextBlock Text="No events detected in this time range."
                       FontSize="{DynamicResource NxFont12}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       IsVisible="{Binding !HasEvents}"
                       Margin="0,4,0,4"/>

            <!-- Column headers -->
            <Grid ColumnDefinitions="120,50,120,*"
                  Margin="0,4,0,0"
                  IsVisible="{Binding Events.Count}">
              <TextBlock Grid.Column="0" Text="Time"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="Sev"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="Type"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         FontWeight="SemiBold"/>
              <TextBlock Grid.Column="3" Text="Description"
                         FontSize="{DynamicResource NxFont11}"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         FontWeight="SemiBold"/>
            </Grid>

            <Border Height="1"
                    Background="{DynamicResource GlassBorderBrush}"
                    IsVisible="{Binding Events.Count}"/>

            <!-- Event rows -->
            <ItemsControl ItemsSource="{Binding Events}"
                          IsVisible="{Binding Events.Count}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="120,50,120,*" Margin="0,3">
                    <!-- Time -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding Timestamp.LocalDateTime, StringFormat='{}{0:MM/dd HH:mm:ss}'}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{StaticResource FontMono}"/>
                    <!-- Severity badge -->
                    <Border Grid.Column="1"
                            CornerRadius="4"
                            Padding="4,1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="{Binding Severity,
                                Converter={x:Static conv:EventSeverityToBrushConverter.Instance},
                                ConverterParameter=dim}">
                      <TextBlock Text="{Binding Severity,
                                     Converter={x:Static conv:EventSeverityToLabelConverter.Instance}}"
                                 FontSize="9"
                                 FontWeight="Bold"
                                 Foreground="White"/>
                    </Border>
                    <!-- Type -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding EventType}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{StaticResource FontMono}"
                               TextTrimming="CharacterEllipsis"/>
                    <!-- Description -->
                    <TextBlock Grid.Column="3"
                               Text="{Binding Description}"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Description}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>

        <!-- Bottom spacer -->
        <Border Height="16"/>

      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
