<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Views.DiagnosticsView"
             x:DataType="vm:DiagnosticsViewModel">

  <ScrollViewer>
    <StackPanel Spacing="24" Margin="32,24,32,32">

      <!-- Header -->
      <StackPanel Spacing="4">
        <TextBlock Text="Diagnostics"
                   FontSize="{DynamicResource NxFont24}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="Monitor processes for sustained memory growth"
                   FontSize="{DynamicResource NxFont13}"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>

      <!-- Status Card -->
      <Border Background="{DynamicResource BgElevatedBrush}"
              CornerRadius="{DynamicResource CornerLG}"
              Padding="20">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <ToggleSwitch IsChecked="{Binding IsDetectionEnabled}"
                            OnContent="Detection Active" OffContent="Detection Paused"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusText}"
                       FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </StackPanel>
          <Border Grid.Column="1"
                  IsVisible="{Binding HasSuspects}"
                  Background="{DynamicResource ColorDangerBrush}"
                  CornerRadius="12"
                  Padding="8,4"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding SuspectCount}"
                       FontSize="{DynamicResource NxFont13}"
                       FontWeight="SemiBold"
                       Foreground="White"/>
          </Border>
        </Grid>
      </Border>

      <!-- Empty State -->
      <Border Background="{DynamicResource BgElevatedBrush}"
              CornerRadius="{DynamicResource CornerLG}"
              Padding="48"
              IsVisible="{Binding !HasSuspects}">
        <StackPanel Spacing="12" HorizontalAlignment="Center">
          <TextBlock Text="✓"
                     FontSize="36"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource ColorSuccessBrush}"/>
          <TextBlock Text="{Binding EmptyStateHeadline}"
                     FontSize="{DynamicResource NxFont14}"
                     FontWeight="Medium"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="{Binding EmptyStateSubtitle}"
                     FontSize="{DynamicResource NxFont13}"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
      </Border>

      <!-- Suspects List -->
      <ItemsControl ItemsSource="{Binding Suspects}"
                    IsVisible="{Binding HasSuspects}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:LeakSuspectCardViewModel">
            <Border Background="{DynamicResource BgElevatedBrush}"
                    CornerRadius="{DynamicResource CornerMD}"
                    Padding="20"
                    Margin="0,0,0,12">
              <StackPanel Spacing="16">

                <!-- Row 0: Name + leak rate badge -->
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel>
                    <TextBlock Text="{Binding ProcessName}"
                               FontSize="{DynamicResource NxFont14}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock FontSize="{DynamicResource NxFont12}"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                      <Run Text="PID "/>
                      <Run Text="{Binding Pid}"/>
                    </TextBlock>
                  </StackPanel>
                  <Border Grid.Column="1"
                          CornerRadius="6"
                          Padding="10,4"
                          VerticalAlignment="Center"
                          Background="#261E1E1E">
                    <TextBlock Text="{Binding LeakRateLabel}"
                               FontSize="{DynamicResource NxFont13}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ColorDangerBrush}"/>
                  </Border>
                </Grid>

                <!-- Row 1: 3-column metrics -->
                <Grid ColumnDefinitions="*,*,*">

                  <!-- Confidence -->
                  <StackPanel Spacing="6">
                    <TextBlock Text="Confidence"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ConfidenceLabel}"
                               FontSize="{DynamicResource NxFont18}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                  </StackPanel>

                  <!-- Working Set Sparkline -->
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="Working Set Trend"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Canvas Width="120" Height="44">
                      <Polyline Points="{Binding WorkingSetSparkPoints}"
                                Stroke="{DynamicResource ColorWarningBrush}"
                                StrokeThickness="1.5"/>
                    </Canvas>
                  </StackPanel>

                  <!-- Handle leak rate -->
                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="Handle Rate"
                               FontSize="{DynamicResource NxFont11}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding HandleRateLabel}" ToolTip.Tip="{Binding HandleRateUnavailableTooltip}"
                               FontSize="{DynamicResource NxFont14}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                  </StackPanel>

                </Grid>

                <!-- Row 2: observation time + dismiss -->
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center">
                    <Run Text="Observed for "/>
                    <Run Text="{Binding ObservationTimeLabel}"/>
                  </TextBlock>
                  <Button Grid.Column="1"
                          Content="Dismiss"
                          Classes="nx-btn-ghost"
                          Command="{Binding $parent[ItemsControl].((vm:DiagnosticsViewModel)DataContext).DismissSuspectCommand}"
                          CommandParameter="{Binding ProcessName}"/>
                </Grid>

              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Settings Card -->
      <Border Background="{DynamicResource BgElevatedBrush}"
              CornerRadius="{DynamicResource CornerLG}"
              Padding="20">
        <StackPanel Spacing="20">
          <TextBlock Text="Detection Settings"
                     FontSize="{DynamicResource NxFont14}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>

          <!-- Observation Window -->
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Observation Window"
                         FontSize="{DynamicResource NxFont13}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                         FontSize="{DynamicResource NxFont13}"
                         Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="{Binding ObservationWindowMinutes}"/>
                <Run Text=" min"/>
              </TextBlock>
            </Grid>
            <Slider Minimum="5" Maximum="30"
                    Value="{Binding ObservationWindowMinutes}"
                    TickFrequency="5" IsSnapToTickEnabled="True"/>
          </StackPanel>

          <!-- Memory Threshold -->
          <Grid ColumnDefinitions="*,120">
            <TextBlock Text="Memory leak threshold (MB/hr)"
                       FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="1"
                           Value="{Binding LeakRateThresholdMbPerHour}"
                           Minimum="10" Maximum="500" Increment="10"
                           FormatString="F0"/>
          </Grid>

          <!-- Handle Threshold -->
          <Grid ColumnDefinitions="*,120">
            <TextBlock Text="Handle leak threshold (/hr)"
                       FontSize="{DynamicResource NxFont13}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <NumericUpDown Grid.Column="1"
                           Value="{Binding HandleLeakThresholdPerHour}"
                           Minimum="10" Maximum="1000" Increment="10"
                           FormatString="F0"/>
          </Grid>

        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
