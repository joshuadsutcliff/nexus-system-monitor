<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:NexusMonitor.UI.Controls">

  <!--
    Phase 8 UI polish (Task 3): every hardcoded micro-transition Duration in this file (button/
    toggle background fades, DataGrid row + ListBox item hover fades) has been migrated to
    {DynamicResource MotionFast}/MotionBase — MotionSettingsService.Apply scales these from
    AppSettings.AnimationSpeed and collapses them to TimeSpan.Zero at speed 0 ("everything
    instant"). Per the Phase 8 Task 3 conductor ruling, this duration-zeroing alone is sufficient
    gating for these micro-transitions — they are NOT additionally class-gated by
    AnimateHoverEffects the way Border.nx-widget-chrome's hover LIFT is below (that's the
    "hover-lift-enabled" PageHostControl class gate; these plain color/background fades have no
    equivalent shared ancestor to gate through cheaply, and unlike the lift they carry no motion/
    shadow — just a brush swap — so leaving them token-driven only was judged an acceptable,
    pragmatic scope boundary rather than plumbing a new cross-cutting gate for micro-fades this
    task did not explicitly require gated per-toggle.
  -->

  <!-- ===== BUTTON — Elevated ===== -->
  <Style Selector="Button.nx-btn">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontMd}" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.nx-btn /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{DynamicResource MotionBase}"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.nx-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
  </Style>
  <Style Selector="Button.nx-btn:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgSelectedBrush}" />
  </Style>

  <!-- ===== BUTTON — Accent (Primary action) ===== -->
  <Style Selector="Button.nx-btn-accent">
    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.nx-btn-accent /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{DynamicResource MotionBase}"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.nx-btn-accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBlueHoverBrush}" />
  </Style>

  <!-- ===== BUTTON — Ghost (Transparent) ===== -->
  <Style Selector="Button.nx-btn-ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.nx-btn-ghost /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{DynamicResource MotionBase}"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.nx-btn-ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
  </Style>

  <!-- Sidebar nav rows — System Settings parity (Phase 8 UI polish, Task 6):
       p8-macos-ref.md line 16 measured NO hover treatment on unselected System Settings sidebar
       rows ("moved the pointer onto multiple unselected rows... no highlight rectangle
       appeared"). ".nav-item" (set alongside "nx-btn-ghost" only on MainWindow.axaml's nav
       Button, see comment there) lets this override win over the general
       "Button.nx-btn-ghost:pointerover" hover rule above by selector specificity, WITHOUT
       touching that shared rule — every other nx-btn-ghost consumer (titlebar buttons, Settings
       "Save…"/"Delete" buttons, etc.) keeps its hover unchanged.
       ":not(.active)" is required: the active row's own accent-pill Background (below) is set
       unconditionally by ".active" (no ":pointerover" in its selector), and ".nav-item:pointerover"
       would otherwise outrank it by specificity (3 selector-parts vs. 2) and incorrectly flash the
       active pill back to transparent on hover. -->
  <Style Selector="Button.nx-btn-ghost.nav-item:pointerover:not(.active) /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- Active nav item — System Settings parity (Phase 8 UI polish, Task 6): p8-macos-ref.md
       line 12 — "solid accent blue ... with white label when the item is the direct sidebar
       selection". Previously a light accent-tint pill (AccentBlueDimBrush) with accent-colored
       text; now a SOLID accent fill with a white label, matching the Settings grammar. Reuses
       the existing AccentBlueBrush resource (not a hardcoded blue) per the brief's "preserve the
       theme system" directive — the nav icon chip (MainWindow.axaml) already shares this same
       token. Foreground="White" cascades to the icon-chip glyph's sibling label TextBlock via
       inherited Foreground (the chip glyph itself is explicitly white regardless of selection,
       see MainWindow.axaml). -->
  <Style Selector="Button.nx-btn-ghost.active">
    <Setter Property="Foreground" Value="White" />
  </Style>
  <Style Selector="Button.nx-btn-ghost.active /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
  </Style>
  <Style Selector="Button.nx-btn-ghost.active TextBlock">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <!-- ===== TEXT INPUT ===== -->
  <Style Selector="TextBox.nx-input">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontMd}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource AccentBlueDimBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource AccentBlueBrush}" />
  </Style>
  <Style Selector="TextBox.nx-input:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
  </Style>

  <!-- ===== SCROLLBAR ===== -->
  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Opacity" Value="0.5" />
  </Style>
  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource BorderDefaultBrush}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="MinWidth" Value="3" />
  </Style>

  <!-- ===== DATA GRID ===== -->
  <Style Selector="DataGrid.nx-grid">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="RowBackground" Value="Transparent" />
    <Setter Property="GridLinesVisibility" Value="None" />
    <Setter Property="HeadersVisibility" Value="Column" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontBase}" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DataGridHeaderFgBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="Padding" Value="10,9" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontSm}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="MinHeight" Value="36" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridRow /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Fill" Duration="{DynamicResource MotionFast}"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Fill" Value="{DynamicResource BgHoverBrush}" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Fill" Value="{DynamicResource AccentBlueDimBrush}" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridRow">
    <Setter Property="MinHeight" Value="32" />
  </Style>
  <Style Selector="DataGrid.nx-grid DataGridCell">
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource DataGridCellFgBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontSm}" />
  </Style>

  <!-- ===== LIST BOX ===== -->
  <Style Selector="ListBox.nx-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBox.nx-list ListBoxItem">
    <Setter Property="Padding" Value="10,7" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Margin" Value="2,1" />
  </Style>
  <Style Selector="ListBox.nx-list ListBoxItem /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{DynamicResource MotionFast}"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ListBox.nx-list ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
  </Style>
  <Style Selector="ListBox.nx-list ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBlueDimBrush}" />
  </Style>

  <!-- ===== CONTEXT MENU ===== -->
  <!--
    Background and border use DynamicResource so both adapt to Light/Dark theme.
    ContextMenuBgBrush and ContextMenuBorderBrush are defined in Colors.axaml
    ThemeDictionaries with ~94% opaque fills so they stay visible regardless of
    glass opacity settings.
  -->
  <Style Selector="ContextMenu">
    <Setter Property="BorderBrush" Value="{DynamicResource ContextMenuBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="5" />
    <Setter Property="Background" Value="{DynamicResource ContextMenuBgBrush}" />
  </Style>
  <Style Selector="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontBase}" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>
  <Style Selector="MenuItem:pointerover /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>
  <Style Selector="MenuItem:pointerover">
    <Setter Property="Foreground" Value="White" />
  </Style>
  <!-- Separator styling -->
  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource SeparatorBrush}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="8,4" />
  </Style>

  <!-- ===== TOGGLE BUTTON — original accent/gray PILL =====
       Unchanged (Phase 8 UI polish, Task 6): this "nx-toggle" class is still used, WITH literal
       text Content, by 9 call sites outside Settings — NetworkView, ServicesView, ProcessesView
       (x4: Simplified/Tree/Info Panel/Groups), GamingModeView, ProBalanceView, AlertsView. An
       earlier pass of this task redefined "nx-toggle" itself into the bare macOS-switch template
       below on the (incorrect) assumption that "Content is never set at any call site" — false;
       those 9 sites set a TextBlock as Content, and the switch template has no ContentPresenter,
       so that would have silently deleted their labels app-wide. Left byte-for-byte as it was
       before Task 6 and re-scoped the macOS-switch restyle onto a NEW "nx-switch" class (below),
       applied only to SettingsView.axaml's 21 bare (contentless) toggles — zero risk to the other
       9 call sites since they're untouched here and in their own view files. -->
  <Style Selector="ToggleButton.nx-toggle">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9999" />
    <Setter Property="Padding" Value="14,6" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontSm}" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="ToggleButton.nx-toggle /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{DynamicResource MotionBase}"/>
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.nx-toggle:checked">
    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ToggleButton.nx-toggle:checked:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBlueHoverBrush}" />
  </Style>

  <!-- ===== TOGGLE SWITCH — macOS-style switch (Settings only) =====
       Phase 8 UI polish (Task 6): new "nx-switch" class, applied only to SettingsView.axaml's
       bare (contentless) ToggleButtons — kept separate from "nx-toggle" (see comment above) so
       the 9 non-Settings call sites that rely on nx-toggle's original text-pill look/Content
       keep working unchanged. Restyles the actual System Settings switch grammar: pill TRACK +
       sliding circular KNOB. Reference: p8-macos-ref.md "Toggle switches" section (measured on
       the Notifications pane), cited per value below. Requires a full custom ControlTemplate
       (PART_Track/PART_Knob) since Avalonia's default ToggleButton template has no such parts —
       same "Setter Property=Template" idiom SettingsView.axaml's own SwatchTheme ControlTheme
       already uses in this codebase.
       Size: kept the packet's measured 36x15 exactly (p8-macos-ref.md line 21) rather than
       scaling up for Nexus's density — Settings row labels sit at NxFont13(15)/NxFont11(13),
       the same order of magnitude as native System Settings labels, so the 2.4:1 track
       ratio reads at a comparable relative size; verified visually via the Task 6 before/after
       switches screenshot (see task-6-report.md). -->
  <Style Selector="ToggleButton.nx-switch">
    <Setter Property="Width" Value="36"/>
    <Setter Property="Height" Value="15"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <ControlTemplate TargetType="ToggleButton">
        <!-- Track — OFF: packet measured neutral dark gray rgb(69,69,72) (p8-macos-ref.md
             line 22). A literal hardcoded gray would only be correct for Dark mode, so this
             uses BgSelectedBrush — the nearest existing theme-aware token in BOTH palettes
             (Dark #38384A / Light #D0D0DD) per the "match nearest existing token" rule, since
             the packet itself was captured in Dark mode only and Nexus must support Light too.
             CornerRadius reuses the existing CornerFull(9999) idiom (already the pre-change
             value on this same control) — Avalonia clamps it to min(Width,Height)/2, giving an
             exact radius=height/2 capsule per packet line 21 without hand-computing 7.5. -->
        <Border x:Name="PART_Track"
                Background="{DynamicResource BgSelectedBrush}"
                CornerRadius="{StaticResource CornerFull}">
          <Border.Transitions>
            <Transitions>
              <BrushTransition Property="Background" Duration="{DynamicResource MotionFast}"/>
            </Transitions>
          </Border.Transitions>
          <!-- Knob — packet: near-circular, ~1px inset from track edge, essentially fills
               track height (p8-macos-ref.md line 24); white in both OFF (measured
               rgb(227,227,228)) and ON (white) states (line 22-23), so a literal White brush
               is correct in both themes rather than a DynamicResource text-color token.
               Margin="1" on a Height=15 track yields the 13x13 near-circle. RenderTransform
               (not Margin/HorizontalAlignment) drives left/right travel so it can animate on
               MotionFast — packet couldn't observe live motion in static screenshots ("could
               not observe... static screenshots can't show slide animation"), so duration
               follows the conductor's existing speed-0-is-instant ruling (MotionSettingsService
               zeroes MotionFast at AnimationSpeed=0) rather than inventing a new value. -->
          <Border x:Name="PART_Knob"
                  Width="13" Height="13"
                  Margin="1,0,0,0"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Background="White"
                  CornerRadius="{StaticResource CornerFull}"
                  RenderTransform="none">
            <Border.Transitions>
              <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="{DynamicResource MotionFast}"/>
              </Transitions>
            </Border.Transitions>
          </Border>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <!-- ON state — packet: saturated accent track, white knob, right-aligned (p8-macos-ref.md
       line 23). Reuses AccentBlueBrush — the SAME token as the sidebar selection pill/icon
       chip — rather than the packet's literal, slightly-more-saturated rgb(7,124,253): Nexus
       has exactly one configurable accent resource, not two, so per the brief's "preserve the
       theme system" directive both consumers intentionally share it (flagged, not a missed
       nuance — see task-6-report.md). Knob travel = track width(36) - 2*inset(2) - knob(13)
       = 21px. -->
  <Style Selector="ToggleButton.nx-switch:checked /template/ Border#PART_Track">
    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
  </Style>
  <Style Selector="ToggleButton.nx-switch:checked /template/ Border#PART_Knob">
    <Setter Property="RenderTransform" Value="translateX(21px)"/>
  </Style>
  <Style Selector="ToggleButton.nx-switch:checked:pointerover /template/ Border#PART_Track">
    <Setter Property="Background" Value="{DynamicResource AccentBlueHoverBrush}" />
  </Style>

  <!-- ===== TOOL TIP ===== -->
  <Style Selector="ToolTip">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="FontSize" Value="{DynamicResource NxFontSm}" />
  </Style>

  <!-- ===== PROCESS DETAIL PANEL LABELS ===== -->
  <Style Selector="TextBlock.detail-label">
    <Setter Property="FontSize" Value="{DynamicResource NxFont10}" />
    <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Margin" Value="0,4,12,4" />
    <Setter Property="MinWidth" Value="72" />
  </Style>
  <Style Selector="TextBlock.detail-value">
    <Setter Property="FontSize" Value="{DynamicResource NxFont11}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Margin" Value="0,4,0,4" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <!-- ===== DATAGRID — column sizing ===== -->
  <Style Selector="DataGrid">
    <Setter Property="UseLayoutRounding" Value="True"/>
  </Style>
  <Style Selector="DataGridColumnHeader">
    <Setter Property="MinWidth" Value="60"/>
  </Style>

  <!-- ===== SETTINGS CARD — Phase 8 elevation ===== -->
  <!-- Applied alongside SettingsView.axaml's own explicit Background/BorderBrush/CornerRadius
       (17 identical card Borders) — this style only adds the one thing none of them set inline:
       the resting elevation. -->
  <Style Selector="Border.nx-settings-card">
    <Setter Property="BoxShadow" Value="{DynamicResource ElevationRaised}" />
  </Style>

  <!-- ===== WIDGET TILE CHROME — Phase 8 elevation + hover lift ===== -->
  <!--
    Shared chrome style for every dashboard widget tile's root Border (WidgetTile.axaml,
    Widgets/*.axaml, Views/HealthTrendsView.axaml) — applied via Classes="nx-widget-chrome"
    alongside each file's own existing Background/BorderBrush/CornerRadius (left untouched; those
    already vary slightly — CornerMD vs CornerLG — so this style only owns the NEW elevation/lift
    behavior, not the pre-existing chrome properties).

    Hover lift is gated two ways, both required:
      - "hover-lift-enabled" class on the ancestor PageHostControl — reflects
        MotionSettingsService.EffectEnabled(settings, MotionEffect.HoverEffects) (see
        DashboardViewModel.HoverEffectsEnabled / PageHostControl.HoverLiftEnabled).
      - ":not(.edit-mode)" on the same PageHostControl — reflects DashboardViewModel.IsEditMode.
        Belt-and-suspenders: EditAdornerControl already becomes hit-test-visible over the whole
        page in edit mode ("adorner owns gestures"), which independently prevents the pointer from
        ever reaching a tile's Border to trigger :pointerover in the first place — this class gate
        makes that guarantee explicit/structural rather than relying solely on that hit-testing
        side effect.
    PageHostControl is the single visual-tree ancestor common to every tile regardless of the
    tile's own DataContext (several widget types rebind DataContext away from DashboardViewModel),
    so gating there — rather than a per-tile {Binding !IsEditMode} — works uniformly. See
    PageHostControl.IsEditModeProperty's doc for the full rationale.
  -->
  <Style Selector="Border.nx-widget-chrome">
    <Setter Property="BoxShadow" Value="{DynamicResource ElevationRaised}" />
    <Setter Property="RenderTransform" Value="none" />
    <Setter Property="Transitions">
      <Transitions>
        <BoxShadowsTransition Property="BoxShadow" Duration="{DynamicResource MotionFast}" />
        <TransformOperationsTransition Property="RenderTransform" Duration="{DynamicResource MotionFast}" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="controls|PageHostControl.hover-lift-enabled:not(.edit-mode) Border.nx-widget-chrome:pointerover">
    <Setter Property="BoxShadow" Value="{DynamicResource ElevationFloating}" />
    <Setter Property="RenderTransform" Value="translateY(-1px) scale(1.005)" />
  </Style>

</Styles>
