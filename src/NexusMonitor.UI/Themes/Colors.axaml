<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <!-- ===== DARK PALETTE — Glassmorphism + Vibrant ===== -->
    <ResourceDictionary x:Key="Dark">

      <!-- Background layers — deep blue-black with cool undertones -->
      <Color x:Key="BgBase">#0A0A12</Color>
      <Color x:Key="BgPrimary">#131318</Color>
      <Color x:Key="BgSecondary">#1B1B22</Color>
      <Color x:Key="BgElevated">#24242E</Color>
      <Color x:Key="BgHover">#2E2E3A</Color>
      <Color x:Key="BgSelected">#38384A</Color>

      <!-- Glass surface colors — cool-tinted frosted panels -->
      <Color x:Key="GlassBg">#A8161622</Color>
      <Color x:Key="GlassBorder">#38FFFFFF</Color>
      <Color x:Key="GlassHighlight">#22FFFFFF</Color>
      <Color x:Key="GlassShadow">#50000000</Color>

      <!-- Text hierarchy -->
      <Color x:Key="TextPrimary">#F5F5FA</Color>
      <Color x:Key="TextSecondary">#EBEBF5</Color>
      <Color x:Key="TextTertiary">#C0EBEBF5</Color>
      <Color x:Key="TextDisabled">#60EBEBF5</Color>

      <!-- Borders — refined for glass surfaces -->
      <Color x:Key="BorderSubtle">#20FFFFFF</Color>
      <Color x:Key="BorderDefault">#35FFFFFF</Color>
      <Color x:Key="BorderStrong">#55FFFFFF</Color>

      <!-- Phase 8 UI polish — elevation/depth tokens (design-time/preview defaults, DepthIntensity
           == 0.5). MotionSettingsService.Apply overwrites these three keys at runtime with the
           value scaled by AppSettings.DepthIntensity (see NexusMonitor.Core.Motion.MotionMath.
           DepthMultiplier) — the service hardcodes its own copy of these exact BoxShadow stops as
           the scaling BASE (mirroring how Themes/Motion.axaml's duration tokens relate to
           MotionSettingsService's FastBaseDuration/etc. constants), so these XAML values only ever
           back a design-time render or a frame drawn before Apply() has run.
           Reference: p8-macos-ref.md (2026-07 macOS Tahoe capture) — dark mode carries almost no
           drop shadow ("Apple uses shadow almost nowhere... nearly imperceptible"; delineation
           relies on hairline separators + subtle fill contrast, not shadow) — ElevationRaised-Dark
           is deliberately barely-there. ElevationModal is aligned to the pre-existing
           CommandPaletteControl/WidgetGalleryControl BoxShadow value (unchanged, both themes) per
           the Task 2 reconciliation: "keep their current visual weight via ElevationModal."
           ElevationToast (Phase 8 Task 3 carryover A) is a SEPARATE, lighter token restoring
           NotificationToast's own pre-Task-2 shadow weight — Task 2 had consolidated the toast
           onto ElevationModal too, making it visibly heavier than before (flagged as an
           uncertainty in that task's report); this token undoes that specifically for the toast
           while CommandPalette/Gallery stay on ElevationModal. -->
      <BoxShadows x:Key="ElevationRaised">0 1 2 0 #14000000</BoxShadows>
      <BoxShadows x:Key="ElevationFloating">0 3 10 0 #2E000000, 0 1 3 0 #1F000000</BoxShadows>
      <BoxShadows x:Key="ElevationModal">0 8 40 0 #66000000, 0 2 8 0 #33000000</BoxShadows>
      <BoxShadows x:Key="ElevationToast">0 4 24 0 #44000000, 0 1 4 0 #22000000</BoxShadows>

      <!-- ── Brushes ── -->
      <SolidColorBrush x:Key="BgBaseBrush"      Color="#0A0A12" />
      <SolidColorBrush x:Key="BgPrimaryBrush"   Color="#131318" />
      <SolidColorBrush x:Key="BgSecondaryBrush" Color="#1B1B22" />
      <SolidColorBrush x:Key="BgElevatedBrush"  Color="#24242E" />
      <SolidColorBrush x:Key="BgHoverBrush"     Color="#2E2E3A" />
      <SolidColorBrush x:Key="BgSelectedBrush"     Color="#38384A" />
      <SolidColorBrush x:Key="BgBaseOpaqueBrush"   Color="#0A0A12" />

      <SolidColorBrush x:Key="GlassBgBrush"        Color="#A8161622" />
      <SolidColorBrush x:Key="GlassBorderBrush"    Color="#38FFFFFF" />
      <SolidColorBrush x:Key="GlassHighlightBrush" Color="#22FFFFFF" />

      <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#F5F5FA"   />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="#EBEBF5"   />
      <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#C0EBEBF5" />
      <SolidColorBrush x:Key="TextDisabledBrush"  Color="#60EBEBF5" />

      <SolidColorBrush x:Key="BorderSubtleBrush"  Color="#20FFFFFF" />
      <SolidColorBrush x:Key="BorderDefaultBrush" Color="#35FFFFFF" />

      <SolidColorBrush x:Key="OverlayBgBrush" Color="#CC050508" />

      <LinearGradientBrush x:Key="ContextMenuBgBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#F0222230" Offset="0.0"/>
        <GradientStop Color="#F0121218" Offset="1.0"/>
      </LinearGradientBrush>
      <SolidColorBrush x:Key="ContextMenuBorderBrush" Color="#45FFFFFF" />
      <SolidColorBrush x:Key="SeparatorBrush"         Color="#25FFFFFF" />

      <!-- ── Semantic danger brushes — Dark ── -->
      <SolidColorBrush x:Key="DangerBgBrush"   Color="#20FF453A" />
      <SolidColorBrush x:Key="DangerTextBrush" Color="#FF6B35"   />

      <!-- ── DataGrid brushes — Dark ── -->
      <SolidColorBrush x:Key="DataGridHeaderFgBrush" Color="#A0A0B0" />
      <SolidColorBrush x:Key="DataGridCellFgBrush"   Color="#DDDDE8" />

      <!-- ── Process category brushes — Dark ── -->
      <SolidColorBrush x:Key="ProcSystemBrush"       Color="#5E5CE6" />
      <SolidColorBrush x:Key="ProcSystemBgBrush"     Color="#1A5E5CE6" />
      <SolidColorBrush x:Key="ProcServiceBrush"      Color="#32ADE6" />
      <SolidColorBrush x:Key="ProcServiceBgBrush"    Color="#1A32ADE6" />
      <SolidColorBrush x:Key="ProcUserBrush"         Color="#34C759" />
      <SolidColorBrush x:Key="ProcUserBgBrush"       Color="#1434C759" />
      <SolidColorBrush x:Key="ProcDotNetBrush"       Color="#BF5AF2" />
      <SolidColorBrush x:Key="ProcDotNetBgBrush"     Color="#1ABF5AF2" />
      <SolidColorBrush x:Key="ProcSuspiciousBrush"   Color="#FF453A" />
      <SolidColorBrush x:Key="ProcSuspiciousBgBrush" Color="#1AFF453A" />
      <SolidColorBrush x:Key="ProcSuspendedBrush"    Color="#8E8E93" />
      <SolidColorBrush x:Key="ProcSuspendedBgBrush"  Color="#148E8E93" />
      <SolidColorBrush x:Key="ProcGpuBrush"          Color="#64D2FF" />
      <SolidColorBrush x:Key="ProcGpuBgBrush"        Color="#1A64D2FF" />
      <SolidColorBrush x:Key="ProcCurrentBrush"      Color="#FFD60A" />
      <SolidColorBrush x:Key="ProcCurrentBgBrush"    Color="#1AFFD60A" />

    </ResourceDictionary>

    <!-- ===== LIGHT PALETTE ===== -->
    <ResourceDictionary x:Key="Light">

      <!-- Background layers — cool-white with subtle blue tint -->
      <Color x:Key="BgBase">#F5F5FA</Color>
      <Color x:Key="BgPrimary">#FFFFFF</Color>
      <Color x:Key="BgSecondary">#F0F0F5</Color>
      <Color x:Key="BgElevated">#E8E8F0</Color>
      <Color x:Key="BgHover">#DDDDE8</Color>
      <Color x:Key="BgSelected">#D0D0DD</Color>

      <!-- Glass surface colors — frosted light panels -->
      <Color x:Key="GlassBg">#A8E8E8F0</Color>
      <Color x:Key="GlassBorder">#35000000</Color>
      <Color x:Key="GlassHighlight">#15000000</Color>
      <Color x:Key="GlassShadow">#20000000</Color>

      <!-- Text hierarchy -->
      <Color x:Key="TextPrimary">#1A1A2E</Color>
      <Color x:Key="TextSecondary">#2D2D44</Color>
      <Color x:Key="TextTertiary">#B840405A</Color>
      <Color x:Key="TextDisabled">#5040405A</Color>

      <!-- Borders -->
      <Color x:Key="BorderSubtle">#18000000</Color>
      <Color x:Key="BorderDefault">#28000000</Color>
      <Color x:Key="BorderStrong">#40000000</Color>

      <!-- Phase 8 UI polish — elevation/depth tokens (design-time/preview defaults, DepthIntensity
           == 0.5). See the Dark variant's comment for the full rationale/reference. Light mode
           gets a visibly softer card shadow than Dark's near-invisible one (Apple's light-mode
           System Settings-family surfaces DO show a soft card shadow, unlike the near-shadowless
           dark captures in p8-macos-ref.md) — ElevationModal stays numerically identical to Dark's
           to preserve the pre-existing CommandPalette/Gallery shadow weight in both themes.
           ElevationToast (Phase 8 Task 3 carryover A) — see the Dark variant's comment — is also
           numerically identical to Dark's, restoring the toast's original theme-invariant
           pre-Task-2 weight. -->
      <BoxShadows x:Key="ElevationRaised">0 1 3 0 #1F000000, 0 2 6 0 #14000000</BoxShadows>
      <BoxShadows x:Key="ElevationFloating">0 4 14 0 #29000000, 0 1 4 0 #1A000000</BoxShadows>
      <BoxShadows x:Key="ElevationModal">0 8 40 0 #66000000, 0 2 8 0 #33000000</BoxShadows>
      <BoxShadows x:Key="ElevationToast">0 4 24 0 #44000000, 0 1 4 0 #22000000</BoxShadows>

      <!-- ── Brushes ── -->
      <SolidColorBrush x:Key="BgBaseBrush"      Color="#F5F5FA" />
      <SolidColorBrush x:Key="BgPrimaryBrush"   Color="#FFFFFF" />
      <SolidColorBrush x:Key="BgSecondaryBrush" Color="#F0F0F5" />
      <SolidColorBrush x:Key="BgElevatedBrush"  Color="#E8E8F0" />
      <SolidColorBrush x:Key="BgHoverBrush"     Color="#DDDDE8" />
      <SolidColorBrush x:Key="BgSelectedBrush"     Color="#D0D0DD" />
      <SolidColorBrush x:Key="BgBaseOpaqueBrush"   Color="#F5F5FA" />

      <SolidColorBrush x:Key="GlassBgBrush"        Color="#A8E8E8F0" />
      <SolidColorBrush x:Key="GlassBorderBrush"    Color="#35000000" />
      <SolidColorBrush x:Key="GlassHighlightBrush" Color="#15000000" />

      <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1A1A2E"   />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="#2D2D44"   />
      <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#B840405A" />
      <SolidColorBrush x:Key="TextDisabledBrush"  Color="#5040405A" />

      <SolidColorBrush x:Key="BorderSubtleBrush"  Color="#18000000" />
      <SolidColorBrush x:Key="BorderDefaultBrush" Color="#28000000" />

      <SolidColorBrush x:Key="OverlayBgBrush" Color="#CCF0F0F5" />

      <LinearGradientBrush x:Key="ContextMenuBgBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#F0F4F4F9" Offset="0.0"/>
        <GradientStop Color="#F0EBEBF3" Offset="1.0"/>
      </LinearGradientBrush>
      <SolidColorBrush x:Key="ContextMenuBorderBrush" Color="#45000000" />
      <SolidColorBrush x:Key="SeparatorBrush"         Color="#25000000" />

      <!-- ── Semantic danger brushes — Light ── -->
      <SolidColorBrush x:Key="DangerBgBrush"   Color="#20C0392B" />
      <SolidColorBrush x:Key="DangerTextBrush" Color="#C0392B"   />

      <!-- ── DataGrid brushes — Light ── -->
      <SolidColorBrush x:Key="DataGridHeaderFgBrush" Color="#6B6B80" />
      <SolidColorBrush x:Key="DataGridCellFgBrush"   Color="#2D2D44" />

      <!-- ── Process category brushes — Light (darker/higher-contrast variants) ── -->
      <SolidColorBrush x:Key="ProcSystemBrush"       Color="#3F3DBF" />
      <SolidColorBrush x:Key="ProcSystemBgBrush"     Color="#203F3DBF" />
      <SolidColorBrush x:Key="ProcServiceBrush"      Color="#0078C8" />
      <SolidColorBrush x:Key="ProcServiceBgBrush"    Color="#200078C8" />
      <SolidColorBrush x:Key="ProcUserBrush"         Color="#1A7A35" />
      <SolidColorBrush x:Key="ProcUserBgBrush"       Color="#201A7A35" />
      <SolidColorBrush x:Key="ProcDotNetBrush"       Color="#7B2FBE" />
      <SolidColorBrush x:Key="ProcDotNetBgBrush"     Color="#207B2FBE" />
      <SolidColorBrush x:Key="ProcSuspiciousBrush"   Color="#C0392B" />
      <SolidColorBrush x:Key="ProcSuspiciousBgBrush" Color="#20C0392B" />
      <SolidColorBrush x:Key="ProcSuspendedBrush"    Color="#636366" />
      <SolidColorBrush x:Key="ProcSuspendedBgBrush"  Color="#14636366" />
      <SolidColorBrush x:Key="ProcGpuBrush"          Color="#007AB8" />
      <SolidColorBrush x:Key="ProcGpuBgBrush"        Color="#20007AB8" />
      <SolidColorBrush x:Key="ProcCurrentBrush"      Color="#B87A00" />
      <SolidColorBrush x:Key="ProcCurrentBgBrush"    Color="#20B87A00" />

    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- ===== SHARED — theme-independent ===== -->

  <!-- Crystal Glass runtime token (0 = invisible, 1 = full intensity) — written from code -->
  <x:Double x:Key="GlassSpecularOpacity">0.35</x:Double>

  <!-- Text accent — written from code; defaults to AccentBlue -->
  <SolidColorBrush x:Key="TextAccentBrush" Color="{StaticResource AccentBlue}" />

  <!-- Accent — macOS Blue -->
  <Color x:Key="AccentBlue">#0A84FF</Color>
  <Color x:Key="AccentBlueDim">#250A84FF</Color>
  <Color x:Key="AccentBlueHover">#3D9FFF</Color>

  <!-- Status / semantic colors -->
  <Color x:Key="ColorSuccess">#34C759</Color>
  <Color x:Key="ColorWarning">#FF9F0A</Color>
  <Color x:Key="ColorDanger">#FF453A</Color>
  <Color x:Key="ColorInfo">#64D2FF</Color>

  <!-- CPU heat gradient stops -->
  <Color x:Key="HeatLow">#34C759</Color>
  <Color x:Key="HeatMid">#FF9F0A</Color>
  <Color x:Key="HeatHigh">#FF453A</Color>

  <!-- ===== SHARED BRUSHES (non-theme) ===== -->
  <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentBlue}" />
  <SolidColorBrush x:Key="AccentBlueBrush"      Color="{StaticResource AccentBlue}" />
  <SolidColorBrush x:Key="AccentBlueDimBrush"   Color="{StaticResource AccentBlueDim}" />
  <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="{StaticResource AccentBlueHover}" />

  <SolidColorBrush x:Key="ColorSuccessBrush" Color="{StaticResource ColorSuccess}" />
  <SolidColorBrush x:Key="ColorWarningBrush" Color="{StaticResource ColorWarning}" />
  <SolidColorBrush x:Key="ColorDangerBrush"  Color="{StaticResource ColorDanger}" />
  <SolidColorBrush x:Key="ColorInfoBrush"    Color="{StaticResource ColorInfo}" />

</ResourceDictionary>
