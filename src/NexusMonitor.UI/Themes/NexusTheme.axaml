<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Merge resource dictionaries (colors, typography tokens, motion durations, AccentBlueHover) -->
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://NexusMonitor/Themes/Colors.axaml" />
        <ResourceInclude Source="avares://NexusMonitor/Themes/Typography.axaml" />
        <ResourceInclude Source="avares://NexusMonitor/Themes/Motion.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="#3D9FFF" />
    </ResourceDictionary>
  </Styles.Resources>

  <!-- Control style rules -->
  <StyleInclude Source="avares://NexusMonitor/Themes/Controls.axaml" />

</Styles>
