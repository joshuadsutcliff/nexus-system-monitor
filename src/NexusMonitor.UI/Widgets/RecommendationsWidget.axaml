<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             xmlns:controls="using:NexusMonitor.UI.Controls"
             x:Class="NexusMonitor.UI.Widgets.RecommendationsWidget"
             x:DataType="vm:DashboardViewModel"
             x:CompileBindings="False">

  <!-- Phase 8 UI polish (Task 4): DynamicTypeScale.IsHost measures this Border's own arranged
       bounds to drive the "Recommendations" title below (list-style widget, no single big
       "value" — per-item Title/Body text is body/detail, out of dynamic-type scope). -->
  <Border Classes="nx-widget-chrome"
          Padding="20,16"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Background="{DynamicResource BgElevatedBrush}"
          BorderBrush="{DynamicResource GlassBorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource CornerLG}"
          controls:DynamicTypeScale.IsHost="True">
    <StackPanel Spacing="10">
      <TextBlock Text="Recommendations"
                 controls:DynamicTypeScale.FontSizeKey="NxFont14" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>

      <ItemsControl ItemsSource="{Binding Recommendations}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:RecommendationViewModel">
            <Border Padding="12,10" Margin="0,3,0,0"
                    Background="{DynamicResource BgPrimaryBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerSM}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <!-- Icon -->
                <TextBlock Text="{Binding Icon}"
                           FontFamily="{StaticResource NexusIcons}"
                           FontSize="{DynamicResource NxFont18}"
                           Foreground="{Binding IconBrush}"
                           VerticalAlignment="Top"/>
                <!-- Text -->
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding Title}"
                             FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding Body}"
                             FontSize="{DynamicResource NxFont12}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</UserControl>
