<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NexusMonitor.UI.ViewModels"
             x:Class="NexusMonitor.UI.Widgets.SubsystemCardWidget"
             x:DataType="vm:SubsystemCardViewModel"
             x:CompileBindings="False">

  <Border Padding="16"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Background="{DynamicResource BgElevatedBrush}"
          BorderBrush="{DynamicResource GlassBorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource CornerMD}">
    <StackPanel Spacing="6">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="{Binding Icon}"
                   FontFamily="{StaticResource NexusIcons}"
                   FontSize="{DynamicResource NxFont16}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"/>
        <TextBlock Text="{Binding Name}"
                   FontSize="{DynamicResource NxFont13}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
        <TextBlock Text="{Binding TrendArrow}"
                   FontSize="{DynamicResource NxFont13}"
                   Foreground="{Binding LevelBrush}"
                   VerticalAlignment="Center"
                   Margin="4,0,0,0"/>
      </StackPanel>
      <TextBlock Text="{Binding Level}"
                 FontSize="{DynamicResource NxFont20}" FontWeight="Bold"
                 Foreground="{Binding LevelBrush}"/>
      <TextBlock Text="{Binding Summary}"
                 FontSize="{DynamicResource NxFont12}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap"/>
    </StackPanel>
  </Border>
</UserControl>
