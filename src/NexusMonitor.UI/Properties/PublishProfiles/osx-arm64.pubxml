<?xml version="1.0" encoding="utf-8"?>
<!--
  macOS Apple Silicon (arm64) — Self-contained portable build
  NOTE: Must be run on macOS or in a macOS CI environment.
  Usage: dotnet publish src/NexusMonitor.UI /p:PublishProfile=osx-arm64
  Output: src/NexusMonitor.UI/publish/osx-arm64/
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>osx-arm64</RuntimeIdentifier>
    <TargetFramework>net8.0</TargetFramework>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>publish/osx-arm64/</PublishDir>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>
</Project>
