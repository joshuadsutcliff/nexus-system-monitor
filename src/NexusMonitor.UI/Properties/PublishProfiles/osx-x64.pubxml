<?xml version="1.0" encoding="utf-8"?>
<!--
  macOS Intel (x64) — Self-contained portable build
  NOTE: Must be run on macOS or in a macOS CI environment.
  Usage: dotnet publish src/NexusMonitor.UI /p:PublishProfile=osx-x64
  Output: src/NexusMonitor.UI/publish/osx-x64/
  To create a .app bundle, run installer/macos/create-app-bundle.sh after publishing.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>osx-x64</RuntimeIdentifier>
    <TargetFramework>net8.0</TargetFramework>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>publish/osx-x64/</PublishDir>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>
</Project>
